{
    "metadata": {
        "version": "1.0.4.1",
        "description": "Integrated uDOS Command System v1.0.4.1 - Commands with shortcode syntax support",
        "last_updated": "2025-08-26",
        "system": "uDOS-v1.0.4.1",
        "format": "uDATA-v1",
        "integration_note": "Merged commands and shortcodes systems",
        "syntax_support": [
            "COMMAND ARG",
            "[COMMAND|ARG]",
            "[COMMAND|ARG*param]"
        ]
    }
}
{
    "command": "BACKUP",
    "category": "backup",
    "description": "Backup and restore operations",
    "args": [
        "CREATE",
        "LIST",
        "RESTORE"
    ],
    "examples": [
        "[BACKUP|CREATE]",
        "[BACKUP|LIST]",
        "[BACKUP|RESTORE*filename]"
    ],
    "help": "Create and manage system backups"
}
