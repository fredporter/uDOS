{
  "vb_command_system": {
    "name": "Visual Basic-Style Command Language",
    "version": "2.0.0",
    "description": "Complete VB-style command language implementation for uDOS",
    "last_updated": "2025-07-18",
    "features": [
      "Variable declaration and type checking",
      "Control structures (IF, FOR, WHILE)",
      "Procedure definitions and calls",
      "Error handling modes",
      "Persistent variable storage",
      "Debugging capabilities",
      "uDOS system integration"
    ]
  },
  "data_types": [
    {
      "name": "String",
      "description": "Text data type",
      "example": "\"Hello World\"",
      "default": "\"\""
    },
    {
      "name": "Integer", 
      "description": "32-bit signed integer",
      "example": "42",
      "range": "-2147483648 to 2147483647",
      "default": "0"
    },
    {
      "name": "Long",
      "description": "64-bit signed integer", 
      "example": "9223372036854775807",
      "range": "-9223372036854775808 to 9223372036854775807",
      "default": "0"
    },
    {
      "name": "Single",
      "description": "Single-precision floating point",
      "example": "3.14159",
      "precision": "7 decimal digits",
      "default": "0.0"
    },
    {
      "name": "Double",
      "description": "Double-precision floating point",
      "example": "3.14159265358979",
      "precision": "15-17 decimal digits", 
      "default": "0.0"
    },
    {
      "name": "Boolean",
      "description": "True or False value",
      "example": "True",
      "values": ["True", "False"],
      "default": "False"
    },
    {
      "name": "Date",
      "description": "Date and time value",
      "example": "2025-07-18",
      "format": "YYYY-MM-DD",
      "default": "1900-01-01"
    },
    {
      "name": "Variant",
      "description": "Can hold any data type",
      "example": "Any value",
      "note": "Automatically converts between types",
      "default": "Empty"
    }
  ],
  "commands": [
    {
      "command": "DIM",
      "category": "variables",
      "syntax": "DIM <variable> As <type> [= <initial_value>]",
      "description": "Declare a variable with optional initialization",
      "examples": [
        "DIM userName As String",
        "DIM counter As Integer = 0", 
        "DIM isActive As Boolean = True"
      ],
      "parameters": [
        {"name": "variable", "type": "identifier", "required": true},
        {"name": "type", "type": "datatype", "required": true},
        {"name": "initial_value", "type": "variant", "required": false}
      ],
      "notes": "Variables must be declared before use. Type checking is enforced."
    },
    {
      "command": "SET",
      "category": "variables", 
      "syntax": "SET <variable> = <value>",
      "description": "Assign a value to a declared variable",
      "examples": [
        "SET userName = \"Agent Digital\"",
        "SET counter = 42",
        "SET isActive = False"
      ],
      "parameters": [
        {"name": "variable", "type": "identifier", "required": true},
        {"name": "value", "type": "variant", "required": true}
      ],
      "notes": "Type conversion and validation performed automatically."
    },
    {
      "command": "PRINT", 
      "category": "output",
      "syntax": "PRINT <expression> [; <expression> ...]",
      "description": "Display output to console",
      "examples": [
        "PRINT \"Hello World\"",
        "PRINT \"Name: \"; $userName",
        "PRINT $counter; \" items processed\""
      ],
      "parameters": [
        {"name": "expression", "type": "variant", "required": true, "multiple": true}
      ],
      "notes": "Use $variableName to reference variables. Semicolon separates expressions."
    },
    {
      "command": "INPUT",
      "category": "input",
      "syntax": "INPUT \"<prompt>\", <variable>",
      "description": "Get input from user and store in variable", 
      "examples": [
        "INPUT \"Enter your name: \", userName",
        "INPUT \"How many items? \", itemCount"
      ],
      "parameters": [
        {"name": "prompt", "type": "string", "required": true},
        {"name": "variable", "type": "identifier", "required": true}
      ],
      "notes": "Variable must be declared before use. Type conversion applied."
    },
    {
      "command": "IF",
      "category": "control",
      "syntax": "IF <condition> THEN <statement>",
      "description": "Conditional execution of statements",
      "examples": [
        "IF $counter > 10 THEN PRINT \"Counter is high\"",
        "IF $isActive = True THEN CALL StartProcess"
      ],
      "parameters": [
        {"name": "condition", "type": "expression", "required": true},
        {"name": "statement", "type": "command", "required": true}
      ],
      "notes": "Supports comparison operators: =, <>, <, >, <=, >="
    },
    {
      "command": "FOR",
      "category": "control",
      "syntax": "FOR <variable> = <start> TO <end> [STEP <increment>]",
      "description": "Start a FOR loop with specified range",
      "examples": [
        "FOR i = 1 TO 10",
        "FOR counter = 0 TO 100 STEP 5"
      ],
      "parameters": [
        {"name": "variable", "type": "identifier", "required": true},
        {"name": "start", "type": "numeric", "required": true},
        {"name": "end", "type": "numeric", "required": true},
        {"name": "increment", "type": "numeric", "required": false, "default": "1"}
      ],
      "notes": "Must be paired with NEXT statement. Loop variable automatically managed."
    },
    {
      "command": "NEXT",
      "category": "control",
      "syntax": "NEXT <variable>",
      "description": "End of FOR loop, increment and test condition",
      "examples": [
        "NEXT i",
        "NEXT counter"
      ],
      "parameters": [
        {"name": "variable", "type": "identifier", "required": true}
      ],
      "notes": "Must match corresponding FOR statement variable name."
    },
    {
      "command": "SUB",
      "category": "procedures",
      "syntax": "SUB <name>([<parameter_list>])",
      "description": "Define a procedure (subroutine)",
      "examples": [
        "SUB DisplayMessage",
        "SUB ProcessData(fileName As String, count As Integer)"
      ],
      "parameters": [
        {"name": "name", "type": "identifier", "required": true},
        {"name": "parameter_list", "type": "parameter_definition", "required": false}
      ],
      "notes": "Procedures are saved as separate files for reuse."
    },
    {
      "command": "CALL",
      "category": "procedures",
      "syntax": "CALL <procedure_name>([<argument_list>])",
      "description": "Execute a defined procedure",
      "examples": [
        "CALL DisplayMessage",
        "CALL ProcessData(\"data.txt\", 100)"
      ],
      "parameters": [
        {"name": "procedure_name", "type": "identifier", "required": true},
        {"name": "argument_list", "type": "expression_list", "required": false}
      ],
      "notes": "Procedure must be defined before calling."
    },
    {
      "command": "REM",
      "category": "documentation", 
      "syntax": "REM <comment_text>",
      "description": "Add comments to code (alternative: ')",
      "examples": [
        "REM This is a comment",
        "' This is also a comment"
      ],
      "parameters": [
        {"name": "comment_text", "type": "text", "required": false}
      ],
      "notes": "Comments are ignored during execution."
    },
    {
      "command": "END",
      "category": "control",
      "syntax": "END",
      "description": "Terminate program execution",
      "examples": [
        "END"
      ],
      "parameters": [],
      "notes": "Immediately stops program execution and exits."
    }
  ],
  "system_commands": [
    {
      "command": "VB.DEBUG",
      "category": "system",
      "syntax": "VB.DEBUG [ON|OFF]",
      "description": "Control debug mode for detailed execution tracing",
      "examples": [
        "VB.DEBUG ON",
        "VB.DEBUG OFF",
        "VB.DEBUG"
      ],
      "notes": "Shows detailed execution information when enabled."
    },
    {
      "command": "VB.ERROR",
      "category": "system", 
      "syntax": "VB.ERROR [HALT|CONTINUE|IGNORE]",
      "description": "Set error handling mode",
      "examples": [
        "VB.ERROR HALT",
        "VB.ERROR CONTINUE", 
        "VB.ERROR IGNORE"
      ],
      "modes": {
        "HALT": "Stop execution on any error (default)",
        "CONTINUE": "Report error but continue execution",
        "IGNORE": "Silently ignore errors"
      }
    },
    {
      "command": "VB.SAVE",
      "category": "system",
      "syntax": "VB.SAVE",
      "description": "Save all variables to persistent storage",
      "examples": ["VB.SAVE"],
      "notes": "Variables are saved to uMemory/state/vb-variables.json"
    },
    {
      "command": "VB.LOAD", 
      "category": "system",
      "syntax": "VB.LOAD",
      "description": "Load variables from persistent storage",
      "examples": ["VB.LOAD"],
      "notes": "Restores previously saved variables and their types."
    },
    {
      "command": "VB.VARS",
      "category": "system",
      "syntax": "VB.VARS",
      "description": "List all declared variables and their values",
      "examples": ["VB.VARS"],
      "notes": "Shows variable name, type, and current value."
    },
    {
      "command": "VB.CLEAR",
      "category": "system",
      "syntax": "VB.CLEAR", 
      "description": "Clear all variables and procedures from memory",
      "examples": ["VB.CLEAR"],
      "notes": "Does not affect saved variables on disk."
    },
    {
      "command": "VB.HELP",
      "category": "system",
      "syntax": "VB.HELP [<command>]",
      "description": "Show help information for VB commands",
      "examples": [
        "VB.HELP",
        "VB.HELP DIM",
        "VB.HELP FOR"
      ],
      "notes": "Provides detailed syntax and usage information."
    }
  ],
  "operators": {
    "arithmetic": [
      {"operator": "+", "description": "Addition", "example": "$a + $b"},
      {"operator": "-", "description": "Subtraction", "example": "$a - $b"},
      {"operator": "*", "description": "Multiplication", "example": "$a * $b"},
      {"operator": "/", "description": "Division", "example": "$a / $b"},
      {"operator": "MOD", "description": "Modulus", "example": "$a MOD $b"}
    ],
    "comparison": [
      {"operator": "=", "description": "Equal to", "example": "$a = $b"},
      {"operator": "<>", "description": "Not equal to", "example": "$a <> $b"},
      {"operator": "<", "description": "Less than", "example": "$a < $b"},
      {"operator": ">", "description": "Greater than", "example": "$a > $b"},
      {"operator": "<=", "description": "Less than or equal", "example": "$a <= $b"},
      {"operator": ">=", "description": "Greater than or equal", "example": "$a >= $b"}
    ],
    "logical": [
      {"operator": "AND", "description": "Logical AND", "example": "$a > 0 AND $b < 100"},
      {"operator": "OR", "description": "Logical OR", "example": "$a = 0 OR $b = 0"},
      {"operator": "NOT", "description": "Logical NOT", "example": "NOT $isFinished"}
    ]
  },
  "integration": {
    "udos_features": [
      "Access to uDOS datasets via special functions",
      "Integration with uMemory for persistent storage",
      "Procedure library in uMemory/scripts/vb-procedures",
      "Module system for code organization",
      "Error logging to uDOS error system",
      "Dashboard integration for monitoring"
    ],
    "special_variables": [
      {"name": "$UDOS_VERSION", "description": "Current uDOS version"},
      {"name": "$CURRENT_USER", "description": "Current uDOS user"},
      {"name": "$UHOME", "description": "uDOS home directory"},
      {"name": "$CURRENT_MISSION", "description": "Active mission name"},
      {"name": "$DATETIME", "description": "Current date and time"}
    ]
  },
  "examples": {
    "basic_program": [
      "' Simple VB program example",
      "DIM userName As String",
      "DIM age As Integer",
      "",
      "INPUT \"Enter your name: \", userName",
      "INPUT \"Enter your age: \", age",
      "",
      "PRINT \"Hello, \"; $userName",
      "IF $age >= 18 THEN PRINT \"You are an adult\"",
      "",
      "FOR i = 1 TO $age",
      "  PRINT \"Year \"; $i",
      "NEXT i",
      "",
      "END"
    ],
    "procedure_example": [
      "' Procedure definition example",
      "SUB CalculateArea(length As Double, width As Double)",
      "  DIM area As Double",
      "  SET area = $length * $width",
      "  PRINT \"Area: \"; $area",
      "END SUB",
      "",
      "' Main program",
      "CALL CalculateArea(10.5, 8.2)"
    ],
    "udos_integration": [
      "' uDOS integration example",
      "DIM missionName As String = $CURRENT_MISSION",
      "DIM logEntry As String",
      "",
      "PRINT \"Working on mission: \"; $missionName",
      "",
      "' Save progress to uDOS memory",
      "SET logEntry = \"VB program executed for \" + $missionName",
      "CALL UDOS.LogMove($logEntry)",
      "",
      "' Access uDOS datasets",
      "CALL UDOS.SearchLocation(\"London\")",
      "",
      "VB.SAVE"
    ]
  }
}
