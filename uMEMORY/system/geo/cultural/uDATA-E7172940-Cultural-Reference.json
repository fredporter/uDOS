  "schema": {
    "currencies": {
      "code": {
        "type": "string",
        "description": "ISO 4217 currency code",
        "pattern": "^[A-Z]{3}$",
        "required": true
      },
      "name": {
        "type": "string",
        "description": "Full currency name",
        "required": true
      },
      "symbol": {
        "type": "string",
        "description": "Currency symbol",
        "required": true
      },
      "country": {
        "type": "string",
        "description": "Primary country/region",
        "required": true
      },
      "numeric_code": {
        "type": "integer",
        "description": "ISO 4217 numeric code",
        "required": true
      }
    },
    "languages": {
      "code": {
        "type": "string",
        "description": "ISO 639-1 language code",
        "pattern": "^[a-z]{2}$",
        "required": true
      },
      "name": {
        "type": "string",
        "description": "English language name",
        "required": true
      },
      "native_name": {
        "type": "string",
        "description": "Native language name",
        "required": true
      },
      "speakers": {
        "type": "integer",
        "description": "Total number of speakers worldwide"
      }
    }
  },
