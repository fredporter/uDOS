            "required": false
        },
        "PROJECT-NAME": {
            "type": "string",
            "default": "",
            "description": "Current project identifier",
            "scope": "project",
            "required": false
        },
        "SESSION-ID": {
            "type": "string",
            "default": "",
            "pattern": "^[A-F0-9]{8}$",
            "description": "Current session identifier",
            "scope": "session",
            "required": false
        }
    }
