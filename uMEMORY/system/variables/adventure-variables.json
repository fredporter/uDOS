            "scope": "adventure",
            "required": false
        },
        "TOTAL-ACHIEVEMENTS": {
            "type": "string",
            "default": "0",
            "pattern": "^[0-9]+$",
            "description": "Total achievements unlocked",
            "scope": "adventure",
