# Test script for uCODE functions (v1.0.16)
# Tests: function definition, calls, parameters, return values, recursion

# Test 1: Simple function with no parameters
FUNCTION greet()
  SET message = "Hello from function!"
  RETURN ${message}
ENDFUNCTION

CALL greet()

# Test 2: Function with parameters
FUNCTION add(a, b)
  SET result = ${a} + ${b}
  RETURN ${result}
ENDFUNCTION

CALL add(5, 3)
CALL add(10, 20)

# Test 3: Function with multiple operations
FUNCTION calculate(x, y)
  SET sum = ${x} + ${y}
  SET product = ${x} * ${y}
  RETURN Product: ${product}, Sum: ${sum}
ENDFUNCTION

CALL calculate(4, 7)

# Test 4: Recursive function (factorial)
FUNCTION factorial(n)
  IF ${n} <= 1
    RETURN 1
  ELSE
    SET n_minus_1 = ${n} - 1
    CALL factorial(${n_minus_1})
    SET prev_result = ${RETURN_VALUE}
    SET result = ${n} * ${prev_result}
    RETURN ${result}
  ENDIF
ENDFUNCTION

# Commenting out recursion for now until we handle RETURN_VALUE properly
# CALL factorial(5)

# Test 5: Function calling another function
FUNCTION double(num)
  SET doubled = ${num} * 2
  RETURN ${doubled}
ENDFUNCTION

FUNCTION quadruple(num)
  CALL double(${num})
  SET temp = ${RETURN_VALUE}
  CALL double(${temp})
  RETURN ${RETURN_VALUE}
ENDFUNCTION

# This will work once we implement proper return value capture
# CALL quadruple(3)

# Test 6: Local scope test
SET global_var = "I am global"

FUNCTION test_scope(param)
  SET local_var = "I am local"
  SET global_var = "Modified in function"
  RETURN ${local_var}
ENDFUNCTION

CALL test_scope("test")
GET global_var

# Test 7: Function with string operations
FUNCTION make_greeting(name)
  SET greeting = "Welcome, ${name}!"
  RETURN ${greeting}
ENDFUNCTION

CALL make_greeting("Alice")
CALL make_greeting("Bob")

# Test 8: Simple math function
FUNCTION multiply(x, y)
  SET result = ${x} * ${y}
  RETURN ${result}
ENDFUNCTION

CALL multiply(6, 7)
CALL multiply(12, 3)
