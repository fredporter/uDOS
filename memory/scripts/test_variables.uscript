# uCODE Variables System Test Script
# Tests SET, GET, DELETE, VARS commands and ${var} substitution

# Test 1: Set string variable
SET name = Alice

# Test 2: Get variable
GET name

# Test 3: Set number variables
SET age = 25
SET height = 5.8

# Test 4: Set boolean variable
SET active = true

# Test 5: Set list variable
SET colors = red, green, blue

# Test 6: List all variables
VARS

# Test 7: Variable substitution
SET greeting = Hello, ${name}!
GET greeting

# Test 8: Persistent variable (survives sessions)
SET favorite_color = purple PERSISTENT

# Test 9: More substitution
SET message = ${name} is ${age} years old
GET message

# Test 10: Delete variable
DELETE height
VARS

# Test 11: Complex substitution
SET info = Name: ${name}, Age: ${age}, Active: ${active}
GET info

# End of test
