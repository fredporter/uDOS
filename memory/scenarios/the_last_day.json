{
  "metadata": {
    "name": "the_last_day",
    "title": "The Last Day",
    "type": "story",
    "difficulty": 1,
    "estimated_minutes": 30,
    "description": "A zombie outbreak has begun in the city. You must escape to the countryside safe zone before it's too late.",
    "author": "uDOS",
    "version": "1.0",
    "xp_reward": 150,
    "tags": ["zombie", "escape", "beginner", "urban"]
  },

  "initial_variables": {
    "player_name": "Survivor",
    "location": "apartment",
    "supplies_collected": 0,
    "civilians_saved": 0,
    "time_remaining": 60
  },

  "quests": [
    {
      "quest_name": "escape_city",
      "title": "Escape the City",
      "description": "Reach the evacuation point before the military lockdown",
      "objectives": [
        "Gather emergency supplies",
        "Help other survivors (optional)",
        "Reach the evacuation zone"
      ],
      "quest_type": "main",
      "rewards": {
        "xp": 100,
        "achievement": "first_escape"
      }
    }
  ],

  "events": [
    {
      "type": "narrative",
      "text": "=== THE LAST DAY ===\n\nYou wake to the sound of sirens and screaming. Your phone buzzes with an emergency alert:\n\n'EMERGENCY BROADCAST: Stay indoors. Avoid contact with infected individuals. Evacuation zones opening in 60 minutes.'\n\nThrough your apartment window, you see chaos in the streets below. People running. Others stumbling with strange, jerking movements.\n\nThis is it. The outbreak everyone said would never happen."
    },

    {
      "type": "narrative",
      "speaker": "You",
      "text": "I need to get out of the city. But first, supplies..."
    },

    {
      "type": "xp_award",
      "amount": 10,
      "category": "usage",
      "reason": "Started The Last Day scenario"
    },

    {
      "type": "choice",
      "prompt": "What do you grab first?",
      "options": [
        {
          "text": "Water bottles from the kitchen",
          "variable": "first_choice",
          "value": "water",
          "next": "choice_water"
        },
        {
          "text": "First aid kit from bathroom",
          "variable": "first_choice",
          "value": "medical",
          "next": "choice_medical"
        },
        {
          "text": "Backpack and flashlight from closet",
          "variable": "first_choice",
          "value": "gear",
          "next": "choice_gear"
        }
      ]
    },

    {
      "type": "condition",
      "condition": "{first_choice} == water",
      "if_true": [
        {
          "type": "narrative",
          "text": "You rush to the kitchen and grab three water bottles. Smart - hydration is critical in survival situations."
        },
        {
          "type": "item_give",
          "item": "Water Bottle",
          "quantity": 3,
          "category": "water",
          "weight": 1.5,
          "volume": 1.5
        },
        {
          "type": "stat_change",
          "stat": "thirst",
          "change": -10
        },
        {
          "type": "xp_award",
          "amount": 15,
          "category": "information",
          "reason": "Prioritized water in emergency"
        }
      ]
    },

    {
      "type": "condition",
      "condition": "{first_choice} == medical",
      "if_true": [
        {
          "type": "narrative",
          "text": "You grab the first aid kit. Bandages, antiseptic, painkillers - these could save your life."
        },
        {
          "type": "item_give",
          "item": "First Aid Kit",
          "quantity": 1,
          "category": "medical",
          "weight": 2.0,
          "volume": 2.0
        },
        {
          "type": "xp_award",
          "amount": 20,
          "category": "information",
          "reason": "Prioritized medical supplies"
        }
      ]
    },

    {
      "type": "condition",
      "condition": "{first_choice} == gear",
      "if_true": [
        {
          "type": "narrative",
          "text": "You grab your sturdy backpack and flashlight. Organization and visibility - essential for survival."
        },
        {
          "type": "item_give",
          "item": "Backpack",
          "quantity": 1,
          "category": "tool",
          "weight": 1.0,
          "volume": 0.5
        },
        {
          "type": "item_give",
          "item": "Flashlight",
          "quantity": 1,
          "category": "tool",
          "weight": 0.5,
          "volume": 0.3
        },
        {
          "type": "xp_award",
          "amount": 15,
          "category": "usage",
          "reason": "Chose practical gear"
        }
      ]
    },

    {
      "type": "narrative",
      "text": "You hear pounding on your apartment door. A voice calls out:"
    },

    {
      "type": "narrative",
      "speaker": "Neighbor",
      "text": "Please! Let me in! They're coming up the stairs!"
    },

    {
      "type": "choice",
      "prompt": "Your neighbor is outside. What do you do?",
      "options": [
        {
          "text": "Open the door and help them",
          "variable": "help_neighbor",
          "value": "yes",
          "next": "help_neighbor_yes"
        },
        {
          "text": "Tell them to go to the roof evacuation point",
          "variable": "help_neighbor",
          "value": "redirect",
          "next": "help_neighbor_redirect"
        },
        {
          "text": "Stay quiet and don't answer",
          "variable": "help_neighbor",
          "value": "no",
          "next": "help_neighbor_no"
        }
      ]
    },

    {
      "type": "condition",
      "condition": "{help_neighbor} == yes",
      "if_true": [
        {
          "type": "narrative",
          "text": "You open the door. Your neighbor stumbles in, terrified but unharmed. They thank you profusely."
        },
        {
          "type": "narrative",
          "speaker": "Neighbor",
          "text": "Thank you! I have some supplies we can share..."
        },
        {
          "type": "item_give",
          "item": "Canned Food",
          "quantity": 2,
          "category": "food",
          "weight": 1.0,
          "volume": 0.5
        },
        {
          "type": "xp_award",
          "amount": 30,
          "category": "connection",
          "reason": "Helped survivor in need"
        }
      ]
    },

    {
      "type": "condition",
      "condition": "{help_neighbor} == redirect",
      "if_true": [
        {
          "type": "narrative",
          "text": "You shout through the door about the roof evacuation point. You hear them run toward the stairs."
        },
        {
          "type": "xp_award",
          "amount": 15,
          "category": "information",
          "reason": "Shared evacuation information"
        }
      ]
    },

    {
      "type": "condition",
      "condition": "{help_neighbor} == no",
      "if_true": [
        {
          "type": "narrative",
          "text": "You remain silent. After a moment, you hear running footsteps fade away. You're alone with your guilt."
        },
        {
          "type": "effect_add",
          "effect": "anxious",
          "duration": 2
        }
      ]
    },

    {
      "type": "time_pass",
      "hours": 1
    },

    {
      "type": "narrative",
      "text": "You make your way down to the street. The scene is nightmarish. Abandoned cars block the roads. In the distance, you see the green smoke marking the evacuation zone.\n\nYou have a choice of routes:"
    },

    {
      "type": "choice",
      "prompt": "Which route to the evacuation zone?",
      "options": [
        {
          "text": "Main street - direct but exposed",
          "variable": "route",
          "value": "main",
          "next": "route_main"
        },
        {
          "text": "Back alleys - longer but safer",
          "variable": "route",
          "value": "alleys",
          "next": "route_alleys"
        },
        {
          "text": "Through the subway - dark and risky",
          "variable": "route",
          "value": "subway",
          "next": "route_subway"
        }
      ]
    },

    {
      "type": "condition",
      "condition": "{route} == main",
      "if_true": [
        {
          "type": "narrative",
          "text": "You sprint down Main Street. Halfway there, you encounter a small group of infected. You manage to dodge around them, but it's a close call."
        },
        {
          "type": "stat_change",
          "stat": "fatigue",
          "change": 20
        },
        {
          "type": "stat_change",
          "stat": "health",
          "change": -5
        },
        {
          "type": "xp_award",
          "amount": 25,
          "category": "usage",
          "reason": "Successfully navigated danger"
        }
      ]
    },

    {
      "type": "condition",
      "condition": "{route} == alleys",
      "if_true": [
        {
          "type": "narrative",
          "text": "You navigate the back alleys carefully. It takes longer, but you avoid most of the chaos. You even find some abandoned supplies in a loading dock."
        },
        {
          "type": "item_give",
          "item": "Energy Bar",
          "quantity": 3,
          "category": "food",
          "weight": 0.3,
          "volume": 0.2
        },
        {
          "type": "stat_change",
          "stat": "fatigue",
          "change": 10
        },
        {
          "type": "xp_award",
          "amount": 35,
          "category": "information",
          "reason": "Found efficient safe route"
        }
      ]
    },

    {
      "type": "condition",
      "condition": "{route} == subway",
      "if_true": [
        {
          "type": "narrative",
          "text": "The subway is dark and terrifying. You use your flashlight to navigate the tunnels. Halfway through, you hear moaning in the darkness. You run."
        },
        {
          "type": "stat_change",
          "stat": "fatigue",
          "change": 30
        },
        {
          "type": "effect_add",
          "effect": "anxious",
          "duration": 1
        },
        {
          "type": "xp_award",
          "amount": 40,
          "category": "usage",
          "reason": "Survived high-risk route"
        }
      ]
    },

    {
      "type": "checkpoint",
      "name": "reached_evacuation_zone"
    },

    {
      "type": "narrative",
      "text": "You reach the evacuation zone. Military vehicles form a perimeter. Soldiers are checking survivors and directing them to transport trucks."
    },

    {
      "type": "narrative",
      "speaker": "Soldier",
      "text": "Are you bitten? Any symptoms? Fever? Nausea?"
    },

    {
      "type": "narrative",
      "text": "You pass the health screening. As you board the truck, you look back at the city. Smoke rises from multiple districts. This was home. Now it's lost."
    },

    {
      "type": "narrative",
      "speaker": "You",
      "text": "I survived the first day. But this is just the beginning..."
    },

    {
      "type": "xp_award",
      "amount": 50,
      "category": "usage",
      "reason": "Reached evacuation zone"
    },

    {
      "type": "end",
      "outcome": "survived",
      "message": "=== SCENARIO COMPLETE ===\n\nYou escaped the city and reached safety. Your survival skills have been tested, and you've learned valuable lessons about emergency preparedness.\n\nTotal XP Earned: Check your XP status\nItems Collected: Check your inventory\n\nThe apocalypse has begun. Your journey continues...",
      "xp": 50
    }
  ]
}
