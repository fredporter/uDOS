{
  "template_system": "uDOS Knowledge Bank Linking & Tagging",
  "version": "1.4.0",
  "description": "Functional cross-referencing and tag system for knowledge guides",

  "linking_syntax": {
    "internal_link": "[[topic_name]]",
    "category_link": "[[category/topic_name]]",
    "diagram_link": "[[diagram:diagram_name]]",
    "external_link": "[Display Text](URL)",
    "anchor_link": "[[#section-name]]"
  },

  "tag_categories": {
    "difficulty": {
      "tags": ["beginner", "intermediate", "advanced", "expert"],
      "prefix": "level:",
      "examples": ["level:beginner", "level:advanced"]
    },
    "season": {
      "tags": ["spring", "summer", "fall", "winter", "year-round"],
      "prefix": "season:",
      "examples": ["season:winter", "season:year-round"]
    },
    "environment": {
      "tags": ["desert", "forest", "mountain", "coastal", "urban", "tropical", "arctic"],
      "prefix": "env:",
      "examples": ["env:desert", "env:forest"]
    },
    "skill_type": {
      "tags": ["procurement", "construction", "crafting", "medical", "navigation", "preservation"],
      "prefix": "skill:",
      "examples": ["skill:procurement", "skill:crafting"]
    },
    "time_sensitive": {
      "tags": ["emergency", "routine", "preparation", "long-term"],
      "prefix": "time:",
      "examples": ["time:emergency", "time:preparation"]
    },
    "resources": {
      "tags": ["minimal-tools", "specialized-tools", "no-tools", "natural-materials"],
      "prefix": "res:",
      "examples": ["res:minimal-tools", "res:natural-materials"]
    }
  },

  "cross_reference_types": {
    "prerequisite": {
      "description": "Skills needed before attempting this guide",
      "syntax": "Prerequisites: [[topic1]], [[topic2]]",
      "display": "🔑 Prerequisites"
    },
    "next_steps": {
      "description": "Skills to learn after mastering this guide",
      "syntax": "Next Steps: [[topic1]], [[topic2]]",
      "display": "➡️ Next Steps"
    },
    "related": {
      "description": "Similar or complementary topics",
      "syntax": "Related: [[topic1]], [[topic2]]",
      "display": "🔗 Related Topics"
    },
    "alternatives": {
      "description": "Different methods for same goal",
      "syntax": "Alternatives: [[topic1]], [[topic2]]",
      "display": "🔄 Alternative Methods"
    },
    "complements": {
      "description": "Topics that work well together",
      "syntax": "Complements: [[topic1]], [[topic2]]",
      "display": "🤝 Complementary Skills"
    },
    "cross_category": {
      "description": "Related topics from other categories",
      "syntax": "See Also: [[category/topic]]",
      "display": "📚 Cross-Category"
    }
  },

  "metadata_schema": {
    "required_fields": [
      "id",
      "title",
      "category",
      "difficulty",
      "created_date",
      "tags"
    ],
    "optional_fields": [
      "subcategory",
      "time_required",
      "skill_level",
      "season",
      "environment",
      "ok_assist",
      "version",
      "author",
      "related_topics",
      "prerequisites",
      "diagrams"
    ],
    "example": {
      "id": "water_001_finding_sources",
      "title": "Finding Water Sources",
      "category": "water",
      "subcategory": "procurement",
      "difficulty": "beginner",
      "time_required": "1-2 hours",
      "skill_level": "basic",
      "season": "year-round",
      "environment": ["forest", "mountain", "desert"],
      "ok_assist": true,
      "version": "1.0",
      "created_date": "2025-11-24",
      "tags": ["water", "procurement", "survival", "beginner"],
      "related_topics": ["water_purification", "water_storage"],
      "prerequisites": [],
      "diagrams": ["water_sources_diagram"]
    }
  },

  "navigation_structure": {
    "category_index": {
      "purpose": "Main category landing page",
      "location": "knowledge/{category}/README.md",
      "contains": [
        "Category overview",
        "List of all guides",
        "Difficulty progression path",
        "Quick reference chart"
      ]
    },
    "topic_index": {
      "purpose": "Subcategory organization",
      "location": "knowledge/{category}/{subcategory}/README.md",
      "contains": [
        "Subcategory guides",
        "Related diagrams",
        "Recommended learning order"
      ]
    },
    "master_index": {
      "purpose": "Complete knowledge bank catalog",
      "location": "knowledge/README.md",
      "contains": [
        "All categories",
        "Statistics",
        "Tag cloud",
        "Search tips"
      ]
    }
  },

  "search_capabilities": {
    "tag_search": {
      "command": "SEARCH --tags level:beginner,skill:procurement",
      "description": "Find all guides matching tag criteria"
    },
    "category_search": {
      "command": "SEARCH water --difficulty beginner",
      "description": "Search within category with filters"
    },
    "full_text": {
      "command": "SEARCH \"fire starting\" --category all",
      "description": "Full-text search across all guides"
    },
    "related_topics": {
      "command": "LINKS water_purification",
      "description": "Show all linked topics"
    }
  },

  "linking_examples": {
    "simple_internal": {
      "syntax": "See [[water_purification]] for next steps.",
      "renders": "See water_purification for next steps.",
      "action": "Creates clickable link to water_purification.md"
    },
    "category_explicit": {
      "syntax": "Also check [[fire/bow_drill_technique]]",
      "renders": "Also check bow_drill_technique",
      "action": "Links to fire category guide"
    },
    "with_display_text": {
      "syntax": "Learn about [[water_purification|purification methods]]",
      "renders": "Learn about purification methods",
      "action": "Links to water_purification with custom text"
    },
    "diagram_reference": {
      "syntax": "Review [[diagram:water_filtration]]",
      "renders": "Review water_filtration diagram",
      "action": "Embeds or links to SVG diagram"
    }
  },

  "tagging_examples": {
    "multi_tag": {
      "syntax": "`beginner` `water` `procurement` `year-round`",
      "purpose": "Multiple tag application",
      "searchable": true
    },
    "hierarchical": {
      "syntax": "`level:beginner` `env:forest` `skill:procurement`",
      "purpose": "Structured categorization",
      "searchable": true
    },
    "composite": {
      "syntax": "`emergency-water` `time:critical`",
      "purpose": "Context-specific tagging",
      "searchable": true
    }
  },

  "automation_tools": {
    "link_generator": {
      "description": "Auto-generate related topic links",
      "command": "LINK GENERATE knowledge/water/finding_sources.md",
      "function": "Analyzes content and suggests related topics"
    },
    "tag_suggester": {
      "description": "AI-powered tag suggestions",
      "command": "TAG SUGGEST knowledge/water/finding_sources.md",
      "function": "OK Assist analyzes content and recommends tags"
    },
    "link_validator": {
      "description": "Check all links are valid",
      "command": "LINK VALIDATE knowledge/",
      "function": "Finds broken links and missing targets"
    },
    "tag_normalizer": {
      "description": "Standardize tag format",
      "command": "TAG NORMALIZE knowledge/",
      "function": "Ensures consistent tag syntax"
    }
  },

  "template_variables": {
    "auto_generated": [
      "{date}",
      "{guide_id}",
      "{category}",
      "{ok_assist_status}"
    ],
    "user_provided": [
      "{title}",
      "{difficulty}",
      "{tags}",
      "{overview_paragraph}"
    ],
    "computed": [
      "{related_topics_list}",
      "{tag_cloud}",
      "{difficulty_badge}"
    ]
  },

  "usage_workflows": {
    "create_new_guide": [
      "1. Copy memory/templates/guide_template.md",
      "2. Fill in required fields",
      "3. Add content to sections",
      "4. Run TAG SUGGEST for tag recommendations",
      "5. Run LINK GENERATE for related topics",
      "6. Save to knowledge/{category}/{topic}.md",
      "7. Run LINK VALIDATE to verify"
    ],
    "add_cross_references": [
      "1. Open guide in editor",
      "2. Identify related topics",
      "3. Add [[topic]] links in Related Skills section",
      "4. Categorize as prerequisite/next-step/related",
      "5. Run LINK VALIDATE",
      "6. Update category index"
    ],
    "tag_management": [
      "1. Review guide content",
      "2. Apply difficulty tag (level:*)",
      "3. Apply environment tags (env:*)",
      "4. Apply skill type tags (skill:*)",
      "5. Apply custom contextual tags",
      "6. Run TAG NORMALIZE to verify format"
    ]
  },

  "best_practices": [
    "Use lowercase for all tags",
    "Separate multi-word tags with hyphens (water-procurement)",
    "Link to at least 3-5 related topics per guide",
    "Include both prerequisites and next steps",
    "Cross-reference between categories for comprehensive learning",
    "Update category README when adding new guides",
    "Validate links after bulk changes",
    "Use descriptive link text for accessibility",
    "Tag for discoverability (environment, season, skill level)",
    "Keep tag lists concise (5-10 tags per guide)"
  ]
}
