{
  "version": "1.7.1",
  "description": "uDOS Shortcode Configuration",
  "shortcodes": [
    {
      "name": "run",
      "type": "script_execution",
      "description": "Execute a uScript file",
      "script": "uScript/system/enhanced-script-runner.sh",
      "permissions": ["read", "execute"],
      "examples": [
        "[run:hello-world]",
        "[run:data-analysis mission=test]",
        "[run:enhanced-features-demo]"
      ]
    },
    {
      "name": "bash",
      "type": "shell_execution", 
      "description": "Execute bash commands in containerized environment",
      "script": "uScript/system/bash-container.sh",
      "permissions": ["read", "write", "execute"],
      "examples": [
        "[bash:ls -la]",
        "[bash:find . -name '*.md']",
        "[bash:echo 'Hello World']"
      ]
    },
    {
      "name": "mission",
      "type": "mission_management",
      "description": "Create or manage missions",
      "script": "uScript/automation/mission-manager.sh",
      "permissions": ["read", "write"],
      "examples": [
        "[mission:create name=test]",
        "[mission:status]",
        "[mission:list]"
      ]
    },
    {
      "name": "check",
      "type": "system_check",
      "description": "Perform system checks",
      "script": "uCode/check.sh",
      "permissions": ["read"],
      "examples": [
        "[check:health]",
        "[check:setup]",
        "[check:errors]"
      ]
    },
    {
      "name": "data",
      "type": "data_processing",
      "description": "Process data files",
      "script": "uScript/utilities/data-processor.sh",
      "permissions": ["read", "write"],
      "examples": [
        "[data:csv file=data.csv]",
        "[data:json file=config.json]",
        "[data:analyze dataset=users]"
      ]
    },
    {
      "name": "error",
      "type": "error_management",
      "description": "Error handling and reporting",
      "script": "uCode/error-handler.sh",
      "permissions": ["read"],
      "examples": [
        "[error:stats]",
        "[error:cleanup]",
        "[error:report type=daily]"
      ]
    },
    {
      "name": "container",
      "type": "container_management",
      "description": "Manage container environments",
      "script": "uScript/system/bash-container.sh",
      "permissions": ["read", "execute"],
      "examples": [
        "[container:status]",
        "[container:cleanup]",
        "[container:init]"
      ]
    },
    {
      "name": "dashboard",
      "type": "system_info",
      "description": "Generate dashboard information",
      "script": "uCode/dash.sh",
      "permissions": ["read"],
      "examples": [
        "[dashboard:generate]",
        "[dashboard:status]",
        "[dashboard:sync]"
      ]
    },
    {
      "name": "log",
      "type": "logging",
      "description": "Log information to uMemory",
      "script": "uCode/log.sh",
      "permissions": ["read", "write"],
      "examples": [
        "[log:move 'Completed task']",
        "[log:milestone 'Phase 1 done']",
        "[log:mission 'Started project']"
      ]
    },
    {
      "name": "tree",
      "type": "navigation",
      "description": "Generate file tree visualization",
      "script": "uCode/make-tree.sh",
      "permissions": ["read"],
      "examples": [
        "[tree:generate]",
        "[tree:show depth=3]",
        "[tree:save file=structure.md]"
      ]
    }
  ],
  "security": {
    "max_execution_time": 300,
    "allowed_paths": [
      "uDOS/uScript",
      "uDOS/uMemory",
      "uDOS/uTemplate",
      "uDOS/uKnowledge"
    ],
    "blocked_commands": [
      "sudo", "su", "passwd", "rm -rf /",
      "mkfs", "fdisk", "mount", "umount"
    ],
    "container_limits": {
      "memory": "1GB",
      "cpu": "50%",
      "timeout": 300
    }
  },
  "performance": {
    "enable_logging": true,
    "log_execution_time": true,
    "track_resource_usage": true,
    "auto_cleanup": true
  }
}
