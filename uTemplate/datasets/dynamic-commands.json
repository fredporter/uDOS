{
  "dynamic_commands": {
    "system_info": {
      "name": "Dynamic Command System",
      "version": "1.0.0",
      "description": "Dataset-driven command extension system for uDOS",
      "last_updated": "2025-07-17"
    }
  },
  "commands": [
    {
      "command": "INSTALL",
      "category": "packages",
      "function": "cmd_install_package",
      "syntax": "INSTALL <package-name>",
      "description": "Install a package from the uDOS package ecosystem",
      "examples": ["INSTALL ripgrep", "INSTALL micro", "INSTALL figlet"],
      "script": "packages/install-{package}.sh",
      "validation": {
        "args_required": 1,
        "arg_pattern": "^[a-zA-Z0-9-]+$"
      },
      "help_text": "Installs packages defined in the uCode/packages/ directory",
      "version": "1.0.0",
      "enabled": true
    },
    {
      "command": "SEARCH",
      "category": "data",
      "function": "cmd_search_datasets",
      "syntax": "SEARCH <query> [dataset]",
      "description": "Search across all datasets or specific dataset",
      "examples": ["SEARCH London", "SEARCH timezone AX14", "SEARCH city Europe"],
      "script": "json-processor.sh search",
      "validation": {
        "args_required": 1,
        "arg_pattern": "^.+$"
      },
      "help_text": "Searches locationMap, timezoneMap, and other datasets for information",
      "version": "1.0.0",
      "enabled": true
    },
    {
      "command": "EXPORT",
      "category": "data",
      "function": "cmd_export_data",
      "syntax": "EXPORT <dataset> [format]",
      "description": "Export dataset to specified format (csv, yaml, txt)",
      "examples": ["EXPORT locationMap csv", "EXPORT timezoneMap yaml", "EXPORT countryMap"],
      "script": "json-processor.sh export",
      "validation": {
        "args_required": 1,
        "arg_pattern": "^[a-zA-Z0-9-]+$"
      },
      "help_text": "Exports datasets in various formats for external use",
      "version": "1.0.0",
      "enabled": true
    },
    {
      "command": "BACKUP",
      "category": "system",
      "function": "cmd_backup_system",
      "syntax": "BACKUP [target]",
      "description": "Create backup of uDOS memory, missions, or entire system",
      "examples": ["BACKUP", "BACKUP memory", "BACKUP missions", "BACKUP all"],
      "script": "system/backup.sh",
      "validation": {
        "args_required": 0,
        "arg_pattern": "^(memory|missions|all)?$"
      },
      "help_text": "Creates timestamped backups in uMemory/backups/",
      "version": "1.0.0",
      "enabled": true
    },
    {
      "command": "RESTORE",
      "category": "system", 
      "function": "cmd_restore_system",
      "syntax": "RESTORE <backup-file>",
      "description": "Restore system from backup file",
      "examples": ["RESTORE backup-2025-07-17.tar.gz", "RESTORE latest"],
      "script": "system/restore.sh",
      "validation": {
        "args_required": 1,
        "arg_pattern": "^.+$"
      },
      "help_text": "Restores system state from backup files",
      "version": "1.0.0",
      "enabled": true
    },
    {
      "command": "HEALTH",
      "category": "system",
      "function": "cmd_health_check",
      "syntax": "HEALTH [component]",
      "description": "Run comprehensive health check on system components",
      "examples": ["HEALTH", "HEALTH memory", "HEALTH templates", "HEALTH packages"],
      "script": "system/health.sh",
      "validation": {
        "args_required": 0,
        "arg_pattern": "^(memory|templates|packages|datasets)?$"
      },
      "help_text": "Validates system integrity and reports issues",
      "version": "1.0.0",
      "enabled": true
    },
    {
      "command": "UPDATE",
      "category": "system",
      "function": "cmd_update_system",
      "syntax": "UPDATE [component]",
      "description": "Update system components or entire system",
      "examples": ["UPDATE", "UPDATE packages", "UPDATE templates", "UPDATE datasets"],
      "script": "system/update.sh",
      "validation": {
        "args_required": 0,
        "arg_pattern": "^(packages|templates|datasets)?$"
      },
      "help_text": "Updates components to latest versions",
      "version": "1.0.0",
      "enabled": true
    },
    {
      "command": "CONFIG",
      "category": "system",
      "function": "cmd_config_system",
      "syntax": "CONFIG [key] [value]",
      "description": "Get or set system configuration values",
      "examples": ["CONFIG", "CONFIG timezone UTC", "CONFIG theme dark", "CONFIG debug true"],
      "script": "system/config.sh",
      "validation": {
        "args_required": 0,
        "arg_pattern": "^[a-zA-Z0-9_-]*$"
      },
      "help_text": "Manages system configuration and preferences",
      "version": "1.0.0",
      "enabled": true
    },
    {
      "command": "PACKAGE",
      "category": "packages",
      "function": "cmd_package_manager",
      "syntax": "PACKAGE <action> [package]",
      "description": "Manage packages (list, info, remove, update)",
      "examples": ["PACKAGE list", "PACKAGE info ripgrep", "PACKAGE remove micro", "PACKAGE update"],
      "script": "packages/manager.sh",
      "validation": {
        "args_required": 1,
        "arg_pattern": "^(list|info|remove|update)$"
      },
      "help_text": "Complete package management system",
      "version": "1.0.0",
      "enabled": true
    },
    {
      "command": "GENERATE",
      "category": "templates",
      "function": "cmd_generate_content",
      "syntax": "GENERATE <template> <name> [vars]",
      "description": "Generate content from templates with variables",
      "examples": ["GENERATE mission \"New Project\"", "GENERATE milestone \"Phase 1\""],
      "script": "template-generator.sh generate",
      "validation": {
        "args_required": 2,
        "arg_pattern": "^[a-zA-Z0-9-_]+$"
      },
      "help_text": "Generates content using the template system",
      "version": "1.0.0",
      "enabled": true
    },
    {
      "command": "WORKFLOW",
      "category": "automation",
      "function": "cmd_workflow_manager",
      "syntax": "WORKFLOW <action> [name]",
      "description": "Manage automated workflows and processes",
      "examples": ["WORKFLOW list", "WORKFLOW run daily-backup", "WORKFLOW create new-flow"],
      "script": "automation/workflow.sh",
      "validation": {
        "args_required": 1,
        "arg_pattern": "^(list|run|create|edit|remove)$"
      },
      "help_text": "Automation and workflow management system",
      "version": "1.0.0",
      "enabled": true
    },
    {
      "command": "MONITOR",
      "category": "system",
      "function": "cmd_monitor_system",
      "syntax": "MONITOR [component] [duration]",
      "description": "Monitor system performance and resource usage",
      "examples": ["MONITOR", "MONITOR memory 60", "MONITOR disk", "MONITOR network"],
      "script": "system/monitor.sh",
      "validation": {
        "args_required": 0,
        "arg_pattern": "^(memory|disk|network|cpu)?$"
      },
      "help_text": "Real-time system monitoring and diagnostics",
      "version": "1.0.0",
      "enabled": true
    }
  ]
}
