      {"name": "country", "type": "country", "required": false, "description": "Country from countryMap dataset", "dataset_ref": "countryMap"},
      {"name": "language", "type": "language", "required": false, "description": "Preferred language from languageMap", "default": "EN", "dataset_ref": "languageMap"},
      {"name": "currency", "type": "currency", "required": false, "description": "Local currency from currencyMap", "dataset_ref": "currencyMap"}
