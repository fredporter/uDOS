{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "🚀 Start uDOS Development",
            "type": "shell",
            "command": "./uCORE/launcher/vscode/start-vscode-dev.sh",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "dedicated",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": [],
            "runOptions": {
                "runOn": "folderOpen"
            }
        },
        {
            "label": "🔄 Restart uDOS Server",
            "type": "shell",
            "command": "./uCORE/launcher/vscode/restart-server.sh",
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "silent",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "🌐 Open UI Preview",
            "type": "shell",
            "command": "open",
            "args": [
                "http://localhost:8080"
            ],
            "group": "test"
        },
        {
            "label": "🧪 Run Quick Tests",
            "type": "shell",
            "command": "./uCORE/launcher/universal/test-udos.sh",
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "📝 Quick Commit",
            "type": "shell",
            "command": "git",
            "args": [
                "add",
                "-A",
                "&&",
                "git",
                "commit",
                "-m",
                "Development update - ${input:commitMessage}"
            ],
            "group": "build"
        },
        {
            "label": "🛑 Stop uDOS Server",
            "type": "shell",
            "command": "pkill",
            "args": [
                "-f",
                "uSERVER/server.py"
            ],
            "group": "build"
        },
        {
            "label": "🌀 Start uDOS",
            "type": "shell",
            "command": "./uCORE/code/ucode.sh",
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "🧠 Development Mode",
            "type": "shell",
            "command": "./uCORE/launcher/universal/start-dev.sh",
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "🔍 Check Installation",
            "type": "shell",
            "command": "./uCORE/code/check.sh",
            "args": [
                "all"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "📊 Generate Dashboard",
            "type": "shell",
            "command": "./uCORE/code/dash.sh",
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "💾 Setup User Memory",
            "type": "shell",
            "command": "./uMEMORY/setup.sh",
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "🏗️ Platform Detection",
            "type": "shell",
            "command": "./uCORE/launcher/universal/detect-platform.sh",
            "args": [
                "--verbose"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "🔌 Install VS Code Extensions",
            "type": "shell",
            "command": "./uCORE/launcher/vscode/setup-vscode.sh",
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "🔄 Convert JSON to uDATA",
            "type": "shell",
            "command": "./dev/scripts/convert-to-udata.sh",
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "🧪 Test JSON Parser",
            "type": "shell",
            "command": "./dev/scripts/test-json-parser.sh",
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "⚙️ Setup Local Development",
            "type": "shell",
            "command": "./dev/scripts/setup-local.sh",
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "🤖 Workflow Manager - Interactive",
            "type": "shell",
            "command": "./dev/workflow.sh",
            "args": [
                "interactive"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "🧠 Enter Assist Mode",
            "type": "shell",
            "command": "./dev/workflow.sh",
            "args": [
                "assist",
                "enter"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "👤 Exit Assist Mode",
            "type": "shell",
            "command": "./dev/workflow.sh",
            "args": [
                "assist",
                "exit"
            ],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "🔍 Analyze Context & Recommend",
            "type": "shell",
            "command": "./dev/workflow.sh",
            "args": [
                "assist",
                "analyze"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "📋 List Roadmaps",
            "type": "shell",
            "command": "./dev/workflow.sh",
            "args": [
                "list",
                "roadmaps"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "📝 View Recent Logs",
            "type": "shell",
            "command": "./dev/workflow.sh",
            "args": [
                "logs"
            ],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "commitMessage",
            "description": "Commit message",
            "default": "Development update",
            "type": "promptString"
        }
    ]
}
