        },
        {
            "label": "📦 Install All Packages",
            "type": "shell",
            "command": "./uCode/packages/consolidated-manager.sh",
            "args": ["install-all"],
            "group": "build",
            "detail": "Install all uDOS packages"
        },
        {
            "label": "🔍 Search with ripgrep",
            "type": "shell",
            "command": "rg",
            "args": ["${input:searchTerm}", "${workspaceFolder}"],
            "group": "test",
            "detail": "Fast text search with ripgrep"
        },
        {
            "label": "📄 View with bat",
            "type": "shell",
            "command": "bat",
            "args": ["${file}"],
            "group": "test",
            "detail": "Syntax-highlighted file viewing"
        },
        {
            "label": "🔍 Find files with fd",
            "type": "shell",
            "command": "fd",
            "args": ["${input:searchPattern}", "${workspaceFolder}"],
            "group": "test",
            "detail": "Fast file finding"
        },
        {
            "label": "📖 View markdown with glow",
            "type": "shell",
            "command": "glow",
            "args": ["${file}"],
            "group": "test",
            "detail": "Beautiful markdown rendering"
        },
        {
            "label": "🎯 Compile VS Code Extension",
            "type": "shell",
            "command": "npx",
            "args": ["tsc"],
            "options": {
                "cwd": "${workspaceFolder}/uDOS-Extension"
            },
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always"
            },
            "problemMatcher": ["$tsc"],
            "detail": "Compile uDOS VS Code Extension TypeScript"
        },
        {
            "label": "📦 Install Extension Dependencies",
            "type": "shell",
            "command": "npm",
            "args": ["install"],
            "options": {
                "cwd": "${workspaceFolder}/uDOS-Extension"
            },
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always"
            },
            "problemMatcher": [],
            "detail": "Install uDOS VS Code Extension dependencies"
