        {
            "label": "🔍 Search with ripgrep",
            "type": "shell",
            "command": "./uCode/packages/run-ripgrep.sh",
            "args": ["${input:searchTerm}", "${input:searchPath}"],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "new"
            },
            "problemMatcher": [],
            "detail": "Fast text search across uDOS files"
        },
        {
            "label": "📦 Package Manager",
            "type": "shell",
            "command": "./uCode/packages/consolidated-manager.sh",
