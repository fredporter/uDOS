    "inputs": [
        {
            "id": "searchTerm",
            "description": "Enter search term for ripgrep",
            "default": "TODO",
            "type": "promptString"
        },
        {
            "id": "searchPattern",
            "description": "Enter file pattern for fd",
            "default": "*.md",
            "type": "promptString"
        },
        {
            "id": "searchPath",
            "description": "Enter search path",
            "default": "./uMemory/",
            "type": "promptString"
        }
