{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "🌀 Start uDOS",
            "type": "shell",
            "command": "./dev/vscode/udos-terminal-integration.sh",
            "args": ["terminal"],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "dedicated",
                "showReuseMessage": false,
                "clear": true
            },
            "isBackground": false,
            "problemMatcher": []
        },
        {
            "label": "🎛️ uDOS Output Stream",
            "type": "shell",
            "command": "./dev/vscode/udos-terminal-integration.sh",
            "args": ["monitor"],
            "group": "build",
            "presentation": {
                "echo": false,
                "reveal": "always",
                "focus": false,
                "panel": "dedicated",
                "showReuseMessage": false,
                "clear": false
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "🔗 VS Code + uDOS Integration",
            "type": "shell",
            "command": "./dev/vscode/udos-terminal-integration.sh",
            "args": ["integration"],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "dedicated",
                "showReuseMessage": false,
                "clear": true
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "🧠 Development Mode",
            "type": "shell",
            "command": "./uCORE/launcher/universal/start-dev.sh",
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "🔍 Check Installation",
            "type": "shell",
            "command": "./uCORE/code/utilities/check.sh",
            "args": ["all"],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "📊 Generate Dashboard",
            "type": "shell",
            "command": "./uCORE/code/utilities/dash.sh",
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "💾 Setup User Memory",
            "type": "shell",
            "command": "./uMEMORY/setup.sh",
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "🏗️ Platform Detection",
            "type": "shell",
            "command": "./uCORE/launcher/universal/detect-platform.sh",
            "args": ["--verbose"],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "🔌 Install VS Code Extensions",
            "type": "shell",
            "command": "./uSCRIPT/integration/vscode/setup-vscode.sh",
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "🏗️ Setup Desktop Development",
            "type": "shell",
            "command": "./dev/scripts/setup-desktop-dev.sh",
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "new"
            },
            "problemMatcher": []
        },
        {
            "label": "🖥️ Start Desktop App Dev",
            "type": "shell",
            "command": "./uNETWORK/desktop/dev-desktop.sh",
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "new"
            },
            "problemMatcher": [],
            "dependsOn": "🌐 Start Web Export"
        },
        {
            "label": "🌐 Start Web Export",
            "type": "shell",
            "command": "./uNETWORK/display/udos-display.sh",
            "args": ["export", "dashboard"],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "🌐 Open uDOS Web UI",
            "type": "shell",
            "command": "code",
            "args": ["--command", "simpleBrowser.show", "http://localhost:8080"],
            "group": "build",
            "presentation": {
                "echo": false,
                "reveal": "never",
                "focus": false,
                "panel": "shared"
            },
            "dependsOn": "🌐 Start Web Export",
            "problemMatcher": []
        }
    ]
}
