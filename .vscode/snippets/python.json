{
    "uDOS Python Script Template": {
        "prefix": "udos-python",
        "body": [
            "#!/usr/bin/env python3",
            "\"\"\"",
            "${1:Script Description}",
            "Part of uDOS ${2:Component} System",
            "\"\"\"",
            "",
            "import os",
            "import sys",
            "import json",
            "from pathlib import Path",
            "",
            "# Add uDOS paths",
            "UDOS_ROOT = Path(__file__).parent.parent.parent",
            "sys.path.insert(0, str(UDOS_ROOT / 'uSCRIPT' / 'library'))",
            "",
            "# uDOS imports",
            "try:",
            "    from udos_common import log_info, log_error, log_success",
            "except ImportError:",
            "    # Fallback logging",
            "    def log_info(msg): print(f\"ℹ️  {msg}\")",
            "    def log_error(msg): print(f\"❌ {msg}\")",
            "    def log_success(msg): print(f\"✅ {msg}\")",
            "",
            "def main():",
            "    \"\"\"Main function\"\"\"",
            "    log_info(\"${1:Script Description}\")",
            "    ",
            "    ${3:# Implementation here}",
            "    ",
            "    log_success(\"Complete\")",
            "",
            "if __name__ == '__main__':",
            "    try:",
            "        main()",
            "    except KeyboardInterrupt:",
            "        log_info(\"Operation cancelled\")",
            "        sys.exit(0)",
            "    except Exception as e:",
            "        log_error(f\"Error: {e}\")",
            "        sys.exit(1)"
        ],
        "description": "uDOS Python script template with standard structure"
    },
    "uDOS Flask Route": {
        "prefix": "udos-route",
        "body": [
            "@app.route('/${1:endpoint}', methods=['${2:GET}'])",
            "def ${3:function_name}():",
            "    \"\"\"${4:Route description}\"\"\"",
            "    try:",
            "        ${5:# Implementation here}",
            "        return jsonify({",
            "            'status': 'success',",
            "            'data': ${6:result}",
            "        })",
            "    except Exception as e:",
            "        return jsonify({",
            "            'status': 'error',",
            "            'message': str(e)",
            "        }), 500"
        ],
        "description": "uDOS Flask route template"
    },
    "uDOS SocketIO Event": {
        "prefix": "udos-socket",
        "body": [
            "@socketio.on('${1:event_name}')",
            "def handle_${2:event_function}(data):",
            "    \"\"\"${3:Event description}\"\"\"",
            "    try:",
            "        ${4:# Implementation here}",
            "        emit('${5:response_event}', {",
            "            'status': 'success',",
            "            'data': ${6:result}",
            "        })",
            "    except Exception as e:",
            "        emit('error', {",
            "            'message': str(e)",
            "        })"
        ],
        "description": "uDOS SocketIO event handler template"
    }
}
