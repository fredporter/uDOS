{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run VS Code Extension",
            "type": "extensionHost",
            "request": "launch",
            "args": [
                "--extensionDevelopmentPath=${workspaceFolder}/extensions/vscode-udos"
            ],
            "outFiles": [
                "${workspaceFolder}/extensions/vscode-udos/out/**/*.js"
            ],
            "preLaunchTask": "npm: compile - extensions/vscode-udos"
        },
        {
            "name": "uDOS: Interactive Mode",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/uDOS.py",
            "console": "integratedTerminal",
            "justMyCode": true,
            "envFile": "${workspaceFolder}/.env",
            "python": "${workspaceFolder}/.venv/bin/python",
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Check Virtual Environment"
        },
        {
            "name": "uDOS: Run Shakedown Script",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/uDOS.py",
            "args": ["memory/tests/shakedown.uscript"],
            "console": "integratedTerminal",
            "justMyCode": true,
            "envFile": "${workspaceFolder}/.env",
            "python": "${workspaceFolder}/.venv/bin/python",
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Check Virtual Environment"
        },
        {
            "name": "uDOS: Integration Tests v1.0.2",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/memory/tests/integration/test_v1_0_2_integration.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "python": "${workspaceFolder}/.venv/bin/python",
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Check Virtual Environment"
        },
        {
            "name": "uDOS: Standalone Tests v1.0.2",
            "type": "python",
            "request": "launch",
            "program": "${workspaceFolder}/sandbox/tests/test_v1_0_2_standalone.py",
            "console": "integratedTerminal",
            "justMyCode": false,
            "python": "${workspaceFolder}/.venv/bin/python",
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Check Virtual Environment"
        },
        {
            "name": "Python: Debug Current File",
            "type": "python",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "python": "${workspaceFolder}/.venv/bin/python",
            "cwd": "${workspaceFolder}",
            "preLaunchTask": "Check Virtual Environment"
        }
    ]
}
