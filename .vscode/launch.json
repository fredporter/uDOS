{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "🐍 Debug uDOS Server",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/uSERVER/server.py",
            "console": "integratedTerminal",
            "env": {
                "UDOS_ROOT": "${workspaceFolder}",
                "UDOS_CURRENT_ROLE": "wizard",
                "UDOS_ACCESS_LEVEL": "100",
                "UDOS_DEV_MODE": "true"
            },
            "cwd": "${workspaceFolder}",
            "args": [],
            "stopOnEntry": false
        },
        {
            "name": "🐛 Debug uDOS Core",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/uCORE/code/ucode.sh",
            "cwd": "${workspaceFolder}",
            "args": [
                "--debug"
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "🐛 Debug Launcher",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/uCORE/launcher/universal/start-udos.sh",
            "cwd": "${workspaceFolder}",
            "args": [
                "--dev"
            ],
            "console": "integratedTerminal"
        },
        {
            "name": "🔧 Debug Development Scripts",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/dev/scripts/${input:scriptName}",
            "cwd": "${workspaceFolder}",
            "args": [],
            "console": "integratedTerminal"
        }
    ],
    "inputs": [
        {
            "id": "scriptName",
            "description": "Script to debug",
            "default": "convert-to-udata.sh",
            "type": "promptString"
        }
    ]
}
