{
  "folders": [
    {
      "name": "uDOS",
      "path": "."
    },
    {
      "name": "@dev",
      "path": "dev"
    },
    {
      "name": "@docs",
      "path": "dev/docs"
    },
    {
      "name": "@goblin",
      "path": "dev/goblin"
    }
  ],
  "settings": {
    "explorer.excludeGitIgnore": false,
    "files.associations": {
      "*.ucode": "markdown",
      "*.udos": "markdown"
    },
    "files.exclude": {
      "**/node_modules": true,
      "**/__pycache__": true,
      "**/*.pyc": true,
      "**/.venv": false
    },
    "search.exclude": {
      "**/.venv": true,
      "**/__pycache__": true,
      "**/node_modules": true,
      "dev/files": true,
      "dev/relecs": true,
      "dev/dev-work": true,
      "dev/testing": true
    },
    "python.defaultInterpreterPath": "${workspaceFolder:uDOS}/.venv/bin/python",
    "python.terminal.executeInFileDir": true,
    "terminal.integrated.defaultProfile.osx": "zsh",
    "terminal.integrated.profiles.osx": {
      "zsh": {
        "path": "/bin/zsh",
        "args": [
          "-l",
          "-i"
        ],
        "icon": "terminal"
      },
      "bash": {
        "path": "/bin/bash",
        "args": [
          "-l"
        ],
        "icon": "terminal-bash"
      }
    },
    "terminal.integrated.env.osx": {
      "VIRTUAL_ENV": "${workspaceFolder:uDOS}/.venv",
      "PATH": "${workspaceFolder:uDOS}/.venv/bin:${env:PATH}",
      "PYTHONPATH": "${workspaceFolder:uDOS}",
      "UDOS_ROOT": "${workspaceFolder:uDOS}",
      "UDOS_DEV_ROOT": "${workspaceFolder:uDOS}/dev",
      "UDOS_DEV_GOBLIN_ROOT": "${workspaceFolder:uDOS}/dev/goblin",
      "UDOS_WIZARD_PORT_FILE": "${workspaceFolder:uDOS}/.wizard-port",
      "VAULT_ROOT": "/Users/fredbook/Documents/vault-md",
      "PAGER": "cat",
      "PYTHONUNBUFFERED": "1"
    },
    "terminal.integrated.shellArgs.osx": [
      "-l",
      "-i"
    ]
  },
  "extensions": {
    "recommendations": [
      "GitHub.copilot",
      "GitHub.copilot-chat",
      "ms-python.python",
      "ms-python.vscode-pylance"
    ],
    "unwantedRecommendations": [
      "hbenl.vscode-test-explorer",
      "LittleFoxTeam.vscode-python-test-adapter"
    ]
  },
  "tasks": {
    "version": "2.0.0",
    "tasks": [
      {
        "label": "uDOS: @dev Vibe Status",
        "type": "shell",
        "command": "/bin/bash",
        "args": [
          "-lc",
          "printf 'STATUS\\n' | ${workspaceFolder:uDOS}/bin/vibe"
        ],
        "presentation": {
          "reveal": "always",
          "panel": "dedicated",
          "focus": true,
          "clear": true
        },
        "problemMatcher": []
      },
      {
        "label": "uDOS: @dev Run Tests",
        "type": "shell",
        "command": "/bin/bash",
        "args": [
          "-lc",
          "printf 'TEST\\n' | ${workspaceFolder:uDOS}/bin/vibe"
        ],
        "presentation": {
          "reveal": "always",
          "panel": "dedicated",
          "focus": true,
          "clear": true
        },
        "problemMatcher": []
      },
      {
        "label": "uDOS: @dev Lint",
        "type": "shell",
        "command": "/bin/bash",
        "args": [
          "-lc",
          "printf 'LINT\\n' | ${workspaceFolder:uDOS}/bin/vibe"
        ],
        "presentation": {
          "reveal": "always",
          "panel": "dedicated",
          "focus": true,
          "clear": true
        },
        "problemMatcher": []
      },
      {
        "label": "uDOS: @dev Health Check",
        "type": "shell",
        "command": "/bin/bash",
        "args": [
          "-lc",
          "printf 'HEALTH\\n' | ${workspaceFolder:uDOS}/bin/vibe"
        ],
        "presentation": {
          "reveal": "always",
          "panel": "dedicated",
          "focus": true,
          "clear": true
        },
        "problemMatcher": []
      },
      {
        "label": "uDOS: @dev Tail Logs",
        "type": "shell",
        "command": "/bin/bash",
        "args": [
          "-lc",
          "printf 'TAIL LOGS\\n' | ${workspaceFolder:uDOS}/bin/vibe"
        ],
        "presentation": {
          "reveal": "always",
          "panel": "dedicated",
          "focus": true,
          "clear": true
        },
        "problemMatcher": []
      },
      {
        "label": "uDOS: Start Wizard Services",
        "type": "shell",
        "command": "/bin/bash",
        "args": [
          "-lc",
          "printf 'WIZARD start\\n' | ${workspaceFolder:uDOS}/bin/vibe"
        ],
        "presentation": {
          "reveal": "always",
          "panel": "dedicated",
          "focus": true,
          "clear": true
        },
        "problemMatcher": []
      },
      {
        "label": "uDOS: uCODE Cycle Test",
        "type": "shell",
        "command": "/bin/bash",
        "args": [
          "-lc",
          "${workspaceFolder:uDOS}/.venv/bin/python ${workspaceFolder:uDOS}/bin/ucode-cycle.py"
        ],
        "presentation": {
          "reveal": "always",
          "panel": "dedicated",
          "focus": true,
          "clear": true
        },
        "problemMatcher": []
      },
      {
        "label": "Wizard: Run MCP (stdio)",
        "type": "process",
        "command": "${workspaceFolder:uDOS}/.venv/bin/python",
        "args": [
          "${workspaceFolder:uDOS}/mcp/wizard/mcp_server.py"
        ],
        "presentation": {
          "reveal": "always",
          "panel": "dedicated",
          "focus": true,
          "clear": true
        },
        "problemMatcher": []
      }
    ]
  },
  "launch": {
    "configurations": []
  }
}
