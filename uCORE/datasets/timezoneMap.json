    "format": "uDOS timezone dataset",
    "fields": ["timezone_code", "timezone_name", "utc_offset", "country", "major_city", "tile_reference", "dst_observed", "region", "latitude", "longitude"]
  },
  "schema": {
    "timezone_code": {
      "type": "string",
      "description": "Standard timezone abbreviation",
      "required": true
    },
    "timezone_name": {
      "type": "string", 
      "description": "Full timezone name",
      "required": true
    },
    "utc_offset": {
      "type": "string",
      "description": "UTC offset in ±HH:MM format",
      "pattern": "^[+-][0-9]{2}:[0-9]{2}$"
    },
    "country": {
      "type": "string",
      "description": "Primary country for this timezone"
    },
    "major_city": {
      "type": "string", 
      "description": "Representative major city"
    },
    "tile_reference": {
      "type": "string",
      "description": "Map tile coordinate where this timezone is represented"
    },
    "dst_observed": {
      "type": "boolean",
      "description": "Whether daylight saving time is observed"
    },
    "region": {
      "type": "string",
      "description": "Geographic region classification"
    },
    "latitude": {
      "type": "number",
      "description": "Representative latitude coordinate"
    },
    "longitude": {
      "type": "number",
      "description": "Representative longitude coordinate"
    }
  },
