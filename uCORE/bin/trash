#!/usr/bin/env bash
#==================================================
# 🗑️ uDOS TRASH MANAGEMENT SYSTEM
# Enhanced system cleanup with smart backup integration
#==================================================

set -euo pipefail

# Configuration
TRASH_ROOT="/Users/agentdigital/uDOS/trash"
UDOS_ROOT="/Users/agentdigital/uDOS"
MAX_TRASH_SIZE_MB=500
BACKUP_RETENTION_DAYS=30
DEPRECATED_RETENTION_DAYS=90
CLEANUP_RETENTION_DAYS=7
SYSTEM_RETENTION_DAYS=1

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Logging function
log() {
    echo -e "${GREEN}[TRASH]${NC} $1"
}

warn() {
    echo -e "${YELLOW}[WARNING]${NC} $1"
}

error() {
    echo -e "${RED}[ERROR]${NC} $1"
}

# Initialize trash structure
init_trash() {
    log "Initializing trash system..."
    mkdir -p "$TRASH_ROOT"/{deprecated,backups,cleanup,system}
    
    # Create .gitignore for trash
    cat > "$TRASH_ROOT/.gitignore" << 'EOF'
# Trash folder - not tracked in git
*
!.gitignore
!README.md
EOF
    
    log "Trash system initialized"
}

# Move file to appropriate trash category
trash_file() {
    local file="$1"
    local category="${2:-cleanup}"
    
    if [[ ! -f "$file" ]]; then
        error "File not found: $file"
        return 1
    fi
    
    local basename_file
    basename_file=$(basename "$file")
    local timestamp
    timestamp=$(date +"%Y%m%d-%H%M%S")
    local trash_name="${timestamp}-${basename_file}"
    
    mv "$file" "$TRASH_ROOT/$category/$trash_name"
    log "Moved to trash/$category: $basename_file"
}

# Move directory to trash
trash_directory() {
    local dir="$1"
    local category="${2:-cleanup}"
    
    if [[ ! -d "$dir" ]]; then
        error "Directory not found: $dir"
        return 1
    fi
    
    local basename_dir
    basename_dir=$(basename "$dir")
    local timestamp
    timestamp=$(date +"%Y%m%d-%H%M%S")
    local trash_name="${timestamp}-${basename_dir}"
    
    mv "$dir" "$TRASH_ROOT/$category/$trash_name"
    log "Moved directory to trash/$category: $basename_dir"
}

# Clean old files based on retention policy
cleanup_by_age() {
    local category="$1"
    local days="$2"
    
    log "Cleaning $category files older than $days days..."
    
    if [[ -d "$TRASH_ROOT/$category" ]]; then
        find "$TRASH_ROOT/$category" -type f -mtime +$days -delete 2>/dev/null || true
        find "$TRASH_ROOT/$category" -type d -empty -delete 2>/dev/null || true
    fi
}

# Get directory size in MB
get_size_mb() {
    local dir="$1"
    if [[ -d "$dir" ]]; then
        du -sm "$dir" 2>/dev/null | cut -f1
    else
        echo "0"
    fi
}

# Compress old files
compress_old_files() {
    log "Compressing files older than 7 days..."
    
    for category in deprecated backups cleanup system; do
        local category_dir="$TRASH_ROOT/$category"
        if [[ -d "$category_dir" ]]; then
            find "$category_dir" -type f -mtime +7 -name "*.gz" -prune -o -type f -mtime +7 -exec gzip {} \; 2>/dev/null || true
        fi
    done
}

# Manage backup retention (keep 1 most recent + 1 largest)
optimize_backups() {
    log "Optimizing backup retention..."
    
    # Find all backup files in the system
    local backup_files=()
    while IFS= read -r -d '' file; do
        backup_files+=("$file")
    done < <(find "$UDOS_ROOT" -name "*.backup" -type f -print0 2>/dev/null)
    
    if [[ ${#backup_files[@]} -le 2 ]]; then
        log "Only ${#backup_files[@]} backup files found, keeping all"
        return
    fi
    
    # Sort by modification time (newest first)
    local newest_backup
    newest_backup=$(printf '%s\n' "${backup_files[@]}" | xargs ls -t | head -1)
    
    # Sort by size (largest first)
    local largest_backup
    largest_backup=$(printf '%s\n' "${backup_files[@]}" | xargs ls -S | head -1)
    
    log "Keeping newest: $(basename "$newest_backup")"
    log "Keeping largest: $(basename "$largest_backup")"
    
    # Move other backups to trash
    for backup in "${backup_files[@]}"; do
        if [[ "$backup" != "$newest_backup" && "$backup" != "$largest_backup" ]]; then
            trash_file "$backup" "backups"
        fi
    done
}

# Empty specific trash category
empty_category() {
    local category="$1"
    
    if [[ ! -d "$TRASH_ROOT/$category" ]]; then
        warn "Category not found: $category"
        return
    fi
    
    warn "Emptying trash/$category..."
    rm -rf "$TRASH_ROOT/$category"/*
    log "Emptied trash/$category"
}

# Empty entire trash
empty_all() {
    warn "Emptying entire trash system..."
    for category in deprecated backups cleanup system; do
        if [[ -d "$TRASH_ROOT/$category" ]]; then
            rm -rf "$TRASH_ROOT/$category"/*
        fi
    done
    log "Emptied all trash categories"
}

# Show trash status
show_status() {
    echo -e "\n${BLUE}=== 🗑️ TRASH SYSTEM STATUS ===${NC}"
    
    for category in deprecated backups cleanup system; do
        if [[ -d "$TRASH_ROOT/$category" ]]; then
            local count
            count=$(find "$TRASH_ROOT/$category" -type f 2>/dev/null | wc -l)
            local size
            size=$(get_size_mb "$TRASH_ROOT/$category")
            echo -e "${GREEN}$category:${NC} $count files, ${size}MB"
        fi
    done
    
    local total_size
    total_size=$(get_size_mb "$TRASH_ROOT")
    echo -e "\n${BLUE}Total trash size:${NC} ${total_size}MB (limit: ${MAX_TRASH_SIZE_MB}MB)"
    
    if [[ $total_size -gt $MAX_TRASH_SIZE_MB ]]; then
        warn "Trash size exceeds limit! Consider emptying trash."
    fi
}

# Auto-cleanup routine
auto_cleanup() {
    log "Running automatic cleanup..."
    
    # Clean by retention policy
    cleanup_by_age "deprecated" $DEPRECATED_RETENTION_DAYS
    cleanup_by_age "backups" $BACKUP_RETENTION_DAYS
    cleanup_by_age "cleanup" $CLEANUP_RETENTION_DAYS
    cleanup_by_age "system" $SYSTEM_RETENTION_DAYS
    
    # Compress old files
    compress_old_files
    
    # Check size and force cleanup if needed
    local total_size
    total_size=$(get_size_mb "$TRASH_ROOT")
    if [[ $total_size -gt $MAX_TRASH_SIZE_MB ]]; then
        warn "Force cleanup triggered - trash size: ${total_size}MB"
        # Remove oldest files first
        find "$TRASH_ROOT" -type f -printf '%T@ %p\n' | sort -n | head -10 | cut -d' ' -f2- | xargs rm -f
    fi
    
    log "Auto-cleanup completed"
}

# Main command handler
main() {
    case "${1:-status}" in
        "init")
            init_trash
            ;;
        "file")
            shift
            trash_file "$@"
            ;;
        "dir"|"directory")
            shift
            trash_directory "$@"
            ;;
        "empty")
            case "${2:-all}" in
                "all")
                    empty_all
                    ;;
                "deprecated"|"backups"|"cleanup"|"system")
                    empty_category "$2"
                    ;;
                *)
                    error "Invalid category: $2"
                    echo "Valid categories: all, deprecated, backups, cleanup, system"
                    exit 1
                    ;;
            esac
            ;;
        "optimize")
            optimize_backups
            ;;
        "cleanup")
            auto_cleanup
            ;;
        "status")
            show_status
            ;;
        "help"|"-h"|"--help")
            echo -e "\n${BLUE}🗑️ uDOS TRASH MANAGEMENT SYSTEM${NC}"
            echo ""
            echo "Usage: $(basename "$0") [command] [options]"
            echo ""
            echo "Commands:"
            echo "  init                    Initialize trash system"
            echo "  file <path> [category]  Move file to trash"
            echo "  dir <path> [category]   Move directory to trash"
            echo "  empty [category]        Empty trash (all/deprecated/backups/cleanup/system)"
            echo "  optimize               Optimize backup retention"
            echo "  cleanup                Run automatic cleanup"
            echo "  status                 Show trash status (default)"
            echo "  help                   Show this help"
            echo ""
            echo "Categories: deprecated, backups, cleanup, system"
            echo ""
            ;;
        *)
            error "Unknown command: $1"
            echo "Use 'trash help' for usage information"
            exit 1
            ;;
    esac
}

# Initialize if needed
if [[ ! -d "$TRASH_ROOT" ]]; then
    init_trash
fi

# Run main function
main "$@"
