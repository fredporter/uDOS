  "uScript: Advanced Mission Template": {
    "prefix": "advanced-mission",
    "body": [
      "' uDOS Advanced Mission Template",
      "' Mission: ${1:Mission Name}",
      "' Created: ${CURRENT_DATE}",
      "' Role: ${2|Wizard,Sorcerer,Imp,Drone,Ghost|}",
      "' Priority: ${3|High,Medium,Low|}",
      "",
      "SET mission_id = \"${4:mission-id}\"",
      "SET mission_name = \"${1:Mission Name}\"", 
      "SET role = \"${2:Wizard}\"",
      "SET priority = \"${3:Medium}\"",
      "SET location = [${5:40.7831}, ${6:-73.9712}]",
      "",
      "LOG \"🎯 Starting mission: \" + mission_name",
      "LOG \"📋 Role: \" + role + \" | Priority: \" + priority",
      "",
      "' Mission validation",
      "IF validate_mission(mission_id) = \"passed\" THEN",
      "    LOG \"✅ Mission validation passed\"",
      "    ",
      "    ' Create initial milestone",
      "    CREATE MILESTONE \"${7:Initial Setup}\"",
      "    ",
      "    ' Mission logic here",
      "    ${8:' Add mission implementation}",
      "    ",
      "    ' Complete mission",
      "    SET mission_status = \"completed\"",
      "    LOG \"🎉 Mission completed successfully\"",
      "ELSE",
      "    LOG \"❌ Mission validation failed\"",
      "    EXIT 1",
      "END IF",
      "",
      "' Update mission analytics", 
      "CALL update_analytics(mission_id, \"completed\")",
      ""
    ],
    "description": "Advanced uScript mission template with role-based features"
  },

  "uScript: Companion Integration": {
    "prefix": "use-companion",
    "body": [
      "' uDOS User Companion Integration",
      "' Companion: ${1|Chester,Sorcerer,Imp,Drone,Ghost|}",
      "",
      "SET companion_type = \"${1:Chester}\"",
      "SET task_description = \"${2:Task description}\"",
      "",
      "LOG \"🤝 Requesting assistance from \" + companion_type",
      "",
      "IF companion_type = \"Chester\" OR companion_type = \"Sorcerer\" THEN",
      "    ' AI-connected assistants",
      "    CALL start_ai_assistant(companion_type, task_description)",
      "ELSE",
      "    ' Offline companions",
      "    CALL start_offline_companion(companion_type, task_description)",
      "END IF",
      "",
      "LOG \"✅ Companion assistance requested\"",
      ""
    ],
    "description": "Integrate User Companions into uScript workflow"
  },

  "uScript: Analytics Integration": {
    "prefix": "track-analytics",
    "body": [
      "' uDOS Analytics Tracking",
      "' Event: ${1:Event Name}",
      "",
      "SET event_name = \"${1:Event Name}\"",
      "SET event_data = {",
      "    \"timestamp\": CURRENT_TIMESTAMP,",
      "    \"mission_id\": \"${2:mission-id}\",", 
      "    \"user_role\": \"${3|Wizard,Sorcerer,Imp,Drone,Ghost|}\",",
      "    \"event_type\": \"${4|mission_start,milestone_complete,system_update,user_action|}\"",
      "}",
      "",
      "' Log to analytics",
      "CALL track_event(event_name, event_data)",
      "LOG \"📊 Analytics event tracked: \" + event_name",
      ""
    ],
    "description": "Add analytics tracking to uScript"
  }
