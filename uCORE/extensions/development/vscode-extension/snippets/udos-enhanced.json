  "Mission Control: Create Mission": {
    "prefix": "new-mission",
    "body": [
      "#!/bin/bash",
      "# Create new uDOS mission using Mission Control System",
      "",
      "./uCode/mission-system.sh create \"${1:Mission Name}\" \"${2:Mission Description}\" ${3:40.7831} ${4:-73.9712}",
      ""
    ],
    "description": "Create a new uDOS mission with location coordinates"
  },
  
