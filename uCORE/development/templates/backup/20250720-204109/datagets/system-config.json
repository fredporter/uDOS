{
    "title": "⚙️ System Configuration",
    "description": "Configure uDOS system settings, display options, and advanced features",
    "category": "configuration",
    "version": "1.0.0",
    "fields": [
        {
            "name": "display_mode",
            "label": "🖥️ Display Mode",
            "type": "choice",
            "options": ["micro", "mini", "compact", "console", "wide", "full", "mega", "ultra"],
            "required": true,
            "noblank": true,
            "help": "Select display resolution: micro (80×45) to ultra (640×480)",
            "default": "console"
        },
        {
            "name": "border_style",
            "label": "🎨 ASCII Border Style",
            "type": "choice",
            "options": ["single", "double", "heavy", "rounded", "minimal"],
            "required": false,
            "noblank": true,
            "help": "Choose ASCII border style for interface blocks",
            "default": "single"
        },
        {
            "name": "color_scheme",
            "label": "🌈 Color Scheme",
            "type": "choice",
            "options": ["default", "high_contrast", "monochrome", "terminal_green", "cyberpunk", "matrix"],
            "required": false,
            "noblank": true,
            "help": "Select color scheme for terminal interface",
            "default": "default"
        },
        {
            "name": "logging_level",
            "label": "📝 Logging Level",
            "type": "choice",
            "options": ["ERROR", "WARN", "INFO", "DEBUG", "TRACE"],
            "required": true,
            "noblank": true,
            "help": "Set the verbosity level for system logging",
            "default": "INFO"
        },
        {
            "name": "enable_debug_mode",
            "label": "🔧 Enable Debug Mode",
            "type": "boolean",
            "required": false,
            "noblank": true,
            "help": "Enable detailed debugging and diagnostic information",
            "default": false
        },
        {
            "name": "verbose_output",
            "label": "💬 Verbose Output",
            "type": "boolean",
            "required": false,
            "noblank": true,
            "help": "Show detailed command execution information",
            "default": false,
            "conditional": {
                "show_when": "enable_debug_mode",
                "equals": true
            }
        },
        {
            "name": "auto_backup_interval",
            "label": "💾 Auto Backup Interval",
            "type": "choice",
            "options": ["disabled", "hourly", "daily", "weekly", "monthly"],
            "required": false,
            "noblank": true,
            "help": "Frequency of automatic system backups",
            "default": "daily"
        },
        {
            "name": "backup_retention",
            "label": "🗂️ Backup Retention",
            "type": "choice",
            "options": ["7_days", "30_days", "90_days", "1_year", "indefinite"],
            "required": false,
            "noblank": true,
            "help": "How long to keep backup files",
            "default": "30_days",
            "conditional": {
                "show_when": "auto_backup_interval",
                "not_equals": "disabled"
            }
        },
        {
            "name": "max_log_size",
            "label": "📊 Max Log File Size",
            "type": "choice",
            "options": ["1MB", "5MB", "10MB", "50MB", "100MB", "unlimited"],
            "required": false,
            "noblank": true,
            "help": "Maximum size for individual log files before rotation",
            "default": "10MB"
        },
        {
            "name": "terminal_history_size",
            "label": "📜 Terminal History Size",
            "type": "choice",
            "options": ["100", "500", "1000", "5000", "unlimited"],
            "required": false,
            "noblank": true,
            "help": "Number of commands to keep in terminal history",
            "default": "1000"
        },
        {
            "name": "enable_experimental_features",
            "label": "🧪 Enable Experimental Features",
            "type": "boolean",
            "required": false,
            "noblank": true,
            "help": "Access bleeding-edge features (may be unstable)",
            "default": false
        },
        {
            "name": "network_timeout",
            "label": "🌐 Network Timeout (seconds)",
            "type": "number",
            "required": false,
            "noblank": true,
            "validation": "^[0-9]{1,3}$",
            "help": "Timeout for network operations (10-999 seconds)",
            "default": "30"
        },
        {
            "name": "command_aliases",
            "label": "⚡ Enable Command Aliases",
            "type": "boolean",
            "required": false,
            "noblank": true,
            "help": "Allow custom command aliases and shortcuts",
            "default": true
        },
        {
            "name": "system_password",
            "label": "🔐 System Password",
            "type": "password",
            "required": false,
            "noblank": false,
            "help": "Set system-level password for admin functions (leave blank for no password)",
            "default": ""
        }
    ],
    "actions": {
        "save": "auto",
        "validate": "real_time",
        "output_format": "json",
        "restart_services": false,
        "apply_immediately": true
    },
    "output_files": [
        {
            "path": "uMemory/config/system-config.json",
            "format": "json"
        },
        {
            "path": "uMemory/config/system-env.sh",
            "format": "env_vars"
        },
        {
            "path": "uMemory/config/display-config.sh",
            "format": "bash_script",
            "template": "display-config-template"
        }
    ],
    "post_actions": [
        {
            "action": "update_system_variables",
            "target": "uTemplate/variables/system-vars.json"
        },
        {
            "action": "apply_display_settings",
            "restart_required": false
        },
        {
            "action": "configure_logging",
            "create_log_dirs": true
        },
        {
            "action": "setup_backup_schedule",
            "conditional": {
                "field": "auto_backup_interval",
                "not_equals": "disabled"
            }
        }
    ]
}
