{
    "uDOS": {
        "version": "1.2",
        "distributionTypes": {
            "minimal": {
                "name": "uDOS Minimal",
                "description": "Core functionality only - ultra-lightweight",
                "targetUsers": ["guest", "user"],
                "size": "~1MB",
                "features": {
                    "core": true,
                    "basicMemory": true,
                    "simpleScripting": false,
                    "templates": "basic",
                    "extensions": false,
                    "gaming": false,
                    "ai": false,
                    "development": false
                },
                "components": {
                    "required": [
                        "uCore/ucode.sh",
                        "uCore/setup.sh",
                        "uDocs/LOC-[A2]-User-Manual.md",
                        "uTemplate/system/basic"
                    ],
                    "optional": [],
                    "excluded": [
                        "uExtensions/*",
                        "uDev/*",
                        "vscode/*"
                    ]
                },
                "installation": {
                    "installer": "uInstall/minimal/install-minimal.sh",
                    "config": "uInstall/minimal/minimal-config.json",
                    "duration": "< 30 seconds",
                    "requirements": {
                        "os": "Any Unix-like",
                        "shell": "bash 3.0+",
                        "memory": "10MB RAM",
                        "storage": "5MB disk"
                    }
                },
                "deployment": {
                    "method": "single-file",
                    "offline": true,
                    "portable": true,
                    "network": false
                }
            },
            "standard": {
                "name": "uDOS Standard",
                "description": "User-friendly installation with essential features",
                "targetUsers": ["user", "powerUser"],
                "size": "~10MB",
                "features": {
                    "core": true,
                    "basicMemory": true,
                    "simpleScripting": true,
                    "templates": "standard",
                    "extensions": "curated",
                    "gaming": false,
                    "ai": "basic",
                    "development": false
                },
                "components": {
                    "required": [
                        "uCore/*",
                        "uMemory/templates",
                        "uScript/templates",
                        "uTemplate/system",
                        "uTemplate/user",
                        "uDocs/LOC-[A2]-User-Manual.md",
                        "uDocs/LOC-[E1]-Tutorial-Basics.md",
                        "uSandbox/templates"
                    ],
                    "optional": [
                        "uExtensions/editors/micro",
                        "uExtensions/creative/ascii-generator",
                        "uExtensions/ai/gemini-cli"
                    ],
                    "excluded": [
                        "uExtensions/gaming/*",
                        "uExtensions/development/*",
                        "uDev/*"
                    ]
                },
                "installation": {
                    "installer": "uInstall/standard/install-standard.sh",
                    "config": "uInstall/standard/standard-config.json",
                    "duration": "2-3 minutes",
                    "requirements": {
                        "os": "Linux, macOS, *BSD",
                        "shell": "bash 4.0+",
                        "memory": "50MB RAM",
                        "storage": "25MB disk"
                    }
                },
                "deployment": {
                    "method": "package-based",
                    "offline": true,
                    "portable": true,
                    "network": "optional"
                }
            },
            "developer": {
                "name": "uDOS Developer",
                "description": "Full development environment with advanced tools",
                "targetUsers": ["developer", "powerUser"],
                "size": "~100MB",
                "features": {
                    "core": true,
                    "basicMemory": true,
                    "simpleScripting": true,
                    "templates": "full",
                    "extensions": "development",
                    "gaming": "optional",
                    "ai": "advanced",
                    "development": true
                },
                "components": {
                    "required": [
                        "uCore/*",
                        "uMemory/*",
                        "uScript/*",
                        "uTemplate/*",
                        "uKnowledge/*",
                        "uDev/*",
                        "uDocs/*",
                        "uSandbox/*"
                    ],
                    "optional": [
                        "uExtensions/development/vscode-extension",
                        "uExtensions/editors/*",
                        "uExtensions/ai/gemini-cli",
                        "uExtensions/ai/gemini",
                        "uExtensions/gaming/nethack"
                    ],
                    "excluded": []
                },
                "installation": {
                    "installer": "uInstall/developer/install-developer.sh",
                    "config": "uInstall/developer/dev-config.json",
                    "duration": "5-10 minutes",
                    "requirements": {
                        "os": "Linux, macOS",
                        "shell": "bash 4.0+",
                        "memory": "256MB RAM",
                        "storage": "200MB disk",
                        "tools": ["git", "node.js (optional)", "python3 (optional)"]
                    }
                },
                "deployment": {
                    "method": "full-install",
                    "offline": "partial",
                    "portable": false,
                    "network": "recommended"
                }
            },
            "wizard": {
                "name": "uDOS Master Wizard",
                "description": "Complete system with all extensions and drone spawning",
                "targetUsers": ["wizard", "administrator", "developer"],
                "size": "~500MB",
                "features": {
                    "core": true,
                    "basicMemory": true,
                    "simpleScripting": true,
                    "templates": "complete",
                    "extensions": "all",
                    "gaming": true,
                    "ai": "full",
                    "development": true,
                    "droneSpawning": true
                },
                "components": {
                    "required": [
                        "uCore/*",
                        "uMemory/*",
                        "uScript/*",
                        "uTemplate/*",
                        "uKnowledge/*",
                        "uDev/*",
                        "uDocs/*",
                        "uSandbox/*",
                        "uExtensions/*",
                        "uInstall/drone/*"
                    ],
                    "optional": [],
                    "excluded": []
                },
                "installation": {
                    "installer": "uInstall/wizard/install-wizard.sh",
                    "config": "uInstall/wizard/wizard-config.json",
                    "duration": "15-30 minutes",
                    "requirements": {
                        "os": "macOS 10.15+, Linux (modern)",
                        "shell": "bash 4.0+",
                        "memory": "1GB RAM",
                        "storage": "1GB disk",
                        "tools": ["git", "node.js 18+", "python3.8+", "VS Code (recommended)"]
                    }
                },
                "deployment": {
                    "method": "comprehensive",
                    "offline": false,
                    "portable": false,
                    "network": "required"
                }
            },
            "drone": {
                "name": "uDOS Drone",
                "description": "Deployment-ready, offline-capable system",
                "targetUsers": ["user", "powerUser", "administrator"],
                "size": "~5MB",
                "features": {
                    "core": true,
                    "basicMemory": true,
                    "simpleScripting": true,
                    "templates": "deployment",
                    "extensions": "essential",
                    "gaming": false,
                    "ai": false,
                    "development": false,
                    "offlineCapable": true
                },
                "components": {
                    "required": [
                        "uCore/ucode.sh",
                        "uCore/setup.sh",
                        "uCore/validation.sh",
                        "uMemory/system",
                        "uScript/core",
                        "uTemplate/drone",
                        "uTemplate/system",
                        "uDocs/LOC-[A2]-User-Manual.md"
                    ],
                    "optional": [
                        "uExtensions/essential-bundle/*",
                        "uExtensions/ai/gemini-cli"
                    ],
                    "excluded": [
                        "uExtensions/gaming/*",
                        "uExtensions/development/*",
                        "uDev/*"
                    ]
                },
                "installation": {
                    "installer": "uInstall/drone/install-drone.sh",
                    "config": "uInstall/drone/drone-config.json",
                    "duration": "1-2 minutes",
                    "requirements": {
                        "os": "Any Unix-like",
                        "shell": "bash 4.0+",
                        "memory": "25MB RAM",
                        "storage": "15MB disk"
                    }
                },
                "deployment": {
                    "method": "self-contained",
                    "offline": true,
                    "portable": true,
                    "network": false,
                    "spawnable": true
                }
            },
            "enterprise": {
                "name": "uDOS Enterprise",
                "description": "Multi-user enterprise installation with management features",
                "targetUsers": ["administrator", "wizard"],
                "size": "~1GB",
                "features": {
                    "core": true,
                    "basicMemory": true,
                    "simpleScripting": true,
                    "templates": "enterprise",
                    "extensions": "all",
                    "gaming": "optional",
                    "ai": "enterprise",
                    "development": true,
                    "multiUser": true,
                    "centralManagement": true
                },
                "components": {
                    "required": [
                        "uCore/*",
                        "uMemory/*", 
                        "uScript/*",
                        "uTemplate/*",
                        "uKnowledge/*",
                        "uDev/*",
                        "uDocs/*",
                        "uExtensions/*",
                        "uInstall/enterprise/*"
                    ],
                    "optional": [
                        "uExtensions/gaming/*"
                    ],
                    "excluded": []
                },
                "installation": {
                    "installer": "uInstall/enterprise/install-enterprise.sh",
                    "config": "uInstall/enterprise/enterprise-config.json",
                    "duration": "30-60 minutes",
                    "requirements": {
                        "os": "Linux Server, macOS Server",
                        "shell": "bash 4.0+",
                        "memory": "2GB RAM",
                        "storage": "5GB disk",
                        "tools": ["git", "node.js 18+", "python3.8+", "docker (optional)"],
                        "network": "required",
                        "database": "optional"
                    }
                },
                "deployment": {
                    "method": "server-based",
                    "offline": false,
                    "portable": false,
                    "network": "required",
                    "clustering": true
                }
            }
        },
        "distributionMatrix": {
            "compatibility": {
                "minimal": ["guest", "user"],
                "standard": ["user", "powerUser"],
                "developer": ["powerUser", "developer"],
                "wizard": ["developer", "administrator", "wizard"],
                "drone": ["user", "powerUser", "administrator"],
                "enterprise": ["administrator", "wizard"]
            },
            "upgradePaths": {
                "minimal": ["standard", "drone"],
                "standard": ["developer", "drone"],
                "developer": ["wizard"],
                "wizard": ["enterprise"],
                "drone": ["standard", "developer"],
                "enterprise": []
            },
            "migrationSupport": {
                "dataPortability": true,
                "configMigration": true,
                "extensionMigration": "conditional",
                "rollbackSupport": true
            }
        }
    }
}
