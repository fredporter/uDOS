{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "🐍 Debug uDOS Server",
            "type": "node",
            "request": "launch",
            "program": "${workspaceFolder}/uSERVER/server.py",
            "console": "integratedTerminal",
            "env": {
                "UDOS_ROOT": "${workspaceFolder}",
                "UDOS_CURRENT_ROLE": "wizard",
                "UDOS_ACCESS_LEVEL": "100",
                "UDOS_DEV_MODE": "true"
            },
            "cwd": "${workspaceFolder}",
            "args": [],
            "stopOnEntry": false
        }
    ]
}
