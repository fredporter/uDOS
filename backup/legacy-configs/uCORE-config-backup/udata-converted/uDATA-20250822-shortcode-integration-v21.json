ssing": true, "cache_results": true, "error_handling": "graceful_fallback"}, "dataset_integration": {"cache_duration": 3600, "auto_refresh": true, "validate_references": true, "fallback_to_cache": true}, "cross_reference_integration": {"validate_on_save": true, "auto_update_links": true, "bidirectional_links": true, "broken_link_warnings": true}, "variable_integration": {"type_validation": true, "scope_isolation": true, "auto_save": true, "conflict_resolution": "newest_wins"}}, "processing_order": ["instance_variables", "input_variables", "dataset_references", "cross_references", "calculated_variables", "template_shortcodes", "final_validation"], "error_handling": {"missing_datasets": "use_fallback_values", "broken_references": "show_warning_continue", "invalid_variables": "prompt_user_correction", "calculation_errors": "show_error_use_default", "template_not_found": "show_available_templates"}}
