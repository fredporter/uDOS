{"shortcode_system": {"name": "uDOS Enhanced Shortcode System", "version": "2.1.0", "description": "Comprehensive shortcode system with template, dataset, and cross-reference integration", "last_updated": "2025-07-18", "features": ["template_integration", "dataset_access", "cross_references", "interactive_processing"]}, "template_shortcodes": {"description": "Shortcodes for template management and generation", "prefix": "template", "commands": {"generate": {"syntax": "[template:generate template_name]", "description": "Generate document from template", "args": {"template_name": {"type": "string", "required": true, "description": "Template identifier"}, "name": {"type": "string", "required": false, "description": "Document name"}, "interactive": {"type": "boolean", "default": false, "description": "Interactive mode"}, "validate": {"type": "boolean", "default": true, "description": "Validate input"}, "output": {"type": "enum", "values": ["markdown", "html", "pdf"], "default": "markdown"}}, "examples": ["[template:generate mission]", "[template:generate mission --name=\"Project Alpha\"]", "[template:generate mission --interactive --validate]"]}, "list": {"syntax": "[template:list]", "description": "List available templates", "args": {"category": {"type": "string", "required": false, "description": "Filter by category"}, "format": {"type": "enum", "values": ["table", "list", "json"], "default": "table"}}, "examples": ["[template:list]", "[template:list --category=planning]", "[template:list --format=json]"]}, "info": {"syntax": "[template:info template_name]", "description": "Show template information", "args": {"template_name": {"type": "string", "required": true, "description": "Template identifier"}, "detail": {"type": "enum", "values": ["basic", "full", "variables"], "default": "basic"}}, "examples": ["[template:info mission]", "[template:info mission --detail=full]", "[template:info mission --detail=variables]"]}, "update": {"syntax": "[template:update document_path]", "description": "Update existing document with fresh template data", "args": {"document_path": {"type": "file", "required": true, "description": "Path to document"}, "refresh_data": {"type": "boolean", "default": true, "description": "Refresh dataset references"}, "validate": {"type": "boolean", "default": true, "description": "Validate after update"}, "backup": {"type": "boolean", "default": true, "description": "Create backup before update"}}, "examples": ["[template:update mission.md]", "[template:update mission.md --refresh-data --validate]"]}, "validate": {"syntax": "[template:validate target]", "description": "Validate templates or documents", "args": {"target": {"type": "string", "required": true, "description": "Template name or 'all'"}, "strict": {"type": "boolean", "default": false, "description": "Strict validation mode"}}, "examples": ["[template:validate mission]", "[template:validate all --strict]"]}}}, "dataset_shortcodes": {"description": "Shortcodes for dataset access and manipulation", "prefix": "dataset", "commands": {"query": {"syntax": "[dataset:query dataset_name filter]", "description": "Query dataset with filter", "args": {"dataset_name": {"type": "string", "required": true, "description": "Dataset identifier"}, "filter": {"type": "string", "required": false, "description": "Query filter"}, "limit": {"type": "number", "default": 100, "description": "Maximum results"}, "format": {"type": "enum", "values": ["table", "json", "csv"], "default": "table"}}, "examples": ["[dataset:query cities \"population > 1000000\"]", "[dataset:query countries --filter=\"continent=Asia\" --limit=20]", "[dataset:query cities --format=json]"]}, "get": {"syntax": "[dataset:get path]", "description": "Get specific dataset value", "args": {"path": {"type": "string", "required": true, "description": "Dataset path (collection.key.field)"}}, "examples": ["[dataset:get cities.london.population]", "[dataset:get countries.australia.capital]", "[dataset:get currencies.usd.symbol]"]}, "list": {"syntax": "[dataset:list]", "description": "List available datasets", "args": {"category": {"type": "string", "required": false, "description": "Filter by category"}, "detail": {"type": "enum", "values": ["names", "summary", "full"], "default": "summary"}}, "examples": ["[dataset:list]", "[dataset:list --category=geographic]", "[dataset:list --detail=full]"]}, "search": {"syntax": "[dataset:search term]", "description": "Search across all datasets", "args": {"term": {"type": "string", "required": true, "description": "Search term"}, "dataset": {"type": "string", "required": false, "description": "Specific dataset to search"}, "field": {"type": "string", "required": false, "description": "Specific field to search"}}, "examples": ["[dataset:search \"Tokyo\"]", "[dataset:search \"USD\" --dataset=currencies]", "[dataset:search \"London\" --field=name]"]}, "export": {"syntax": "[dataset:export dataset_name format]", "description": "Export dataset to file", "args": {"dataset_name": {"type": "string", "required": true, "description": "Dataset identifier"}, "format": {"type": "enum", "values": ["json", "csv", "yaml", "xml"], "required": true}, "filter": {"type": "string", "required": false, "description": "Export filter"}, "output": {"type": "file", "required": false, "description": "Output file path"}}, "examples": ["[dataset:export cities csv]", "[dataset:export countries json --filter=\"continent=Europe\"]", "[dataset:export currencies yaml --output=currencies.yaml]"]}, "update": {"syntax": "[dataset:update dataset_name]", "description": "Update dataset from external sources", "args": {"dataset_name": {"type": "string", "required": true, "description": "Dataset identifier or 'all'"}, "source": {"type": "enum", "values": ["external", "backup", "manual"], "default": "external"}, "validate": {"type": "boolean", "default": true, "description": "Validate after update"}}, "examples": ["[dataset:update cities]", "[dataset:update all --source=external]", "