    "unified_commands": [
        {
            "command": "HELP",
            "languages": [
                "uCODE",
                "Shortcode",
                "VB",
                "System"
            ],
            "category": "system",
            "priority": 1,
            "role_access": [
                "GHOST",
                "TOMB",
                "CRYPT",
                "DRONE",
                "KNIGHT",
                "IMP",
                "SORCERER",
                "WIZARD"
            ],
            "syntax": {
                "ucode": "HELP [command] [language]",
                "shortcode": "[HELP|COMMAND*lang]",
                "vb": "VB.HELP [command]",
                "system": "HELP <command>"
            },
            "description": "Dynamic help system with context-aware assistance",
            "examples": {
                "basic": [
                    "HELP",
                    "HELP PRINT",
                    "HELP GRID"
                ],
                "filtered": [
                    "HELP ROLE:WIZARD",
                    "HELP CATEGORY:ugrid"
                ],
                "interactive": [
                    "HELP --interactive",
                    "HELP --examples"
                ]
            },
            "parameters": [
                {
                    "name": "command",
                    "type": "string",
                    "required": false,
                    "description": "Specific command to get help for"
                },
                {
                    "name": "language",
                    "type": "enum",
                    "values": [
                        "ucode",
                        "shortcode",
                        "vb",
                        "system"
                    ],
                    "description": "Filter by command language"
                },
                {
                    "name": "category",
                    "type": "enum",
                    "values": [
                        "system",
                        "ugrid",
                        "data",
                        "workflow",
                        "git",
                        "debug"
                    ],
                    "description": "Filter by category"
                },
                {
                    "name": "role",
                    "type": "enum",
                    "values": [
                        "GHOST",
                        "TOMB",
                        "CRYPT",
                        "DRONE",
                        "KNIGHT",
                        "IMP",
                        "SORCERER",
                        "WIZARD"
                    ],
                    "description": "Filter by role access"
                }
            ],
            "features": [
                "Interactive command explorer",
                "Role-based filtering",
                "Real-time syntax validation",
                "Context-aware examples",
                "Cross-reference related commands"
            ],
            "integration": {
                "script": "uCORE/core/help-engine-v1.3.3.sh",
                "datasets": [
                    "unified-command-system.json"
                ],
                "ui_components": [
                    "help-dashboard",
                    "command-explorer",
                    "syntax-validator"
                ]
            }
        },
        {
            "command": "GRID",
            "languages": [
                "uCODE",
                "Shortcode"
            ],
            "category": "ugrid",
            "priority": 5,
            "role_access": [
                "IMP",
                "SORCERER",
                "WIZARD"
            ],
            "syntax": {
                "ucode": "GRID <operation> [parameters]",
                "shortcode": "[GRID|OPERATION*params]"
            },
            "description": "uGRID display system operations",
            "operations": [
                {
                    "name": "INIT",
                    "description": "Initialize grid with dimensions",
                    "syntax": "GRID INIT <width>/<height>",
                    "examples": [
                        "GRID INIT 80/30",
                        "GRID INIT 120/40"
                    ]
                },
                {
                    "name": "TILE",
                    "description": "Create grid tile",
                    "syntax": "GRID TILE CREATE <x>/<y> <content>",
                    "examples": [
                        "GRID TILE CREATE 0/0 'Header'",
                        "GRID TILE CREATE 10/5 {USER-NAME}"
                    ]
                },
                {
                    "name": "WIDGET",
                    "description": "Create widget in grid",
                    "syntax": "GRID WIDGET CREATE <name> <x>/<y> <w>/<h>",
                    "examples": [
                        "GRID WIDGET CREATE status 0/0 40/8",
                        "GRID WIDGET CREATE chart 20/10 60/20"
                    ]
                }
            ],
            "integration": {
                "script": "uCORE/core/ugrid-engine-v1.3.3.sh",
                "datasets": [
                    "grid-layouts.json",
                    "widget-definitions.json"
                ],
                "ui_components": [
                    "grid-renderer",
                    "widget-manager"
                ]
            }
        },
        {
            "command": "ROLE",
            "languages": [
                "uCODE",
                "Shortcode",
                "System"
            ],
            "category": "system",
            "priority": 3,
            "role_access": [
                "DRONE",
                "KNIGHT",
                "IMP",
                "SORCERER",
                "WIZARD"
            ],
            "syntax": {
                "ucode": "ROLE <operation> [role_name]",
                "shortcode": "[ROLE|OPERATION*role]",
                "system": "ROLE <action>"
            },
            "description": "8-role system management",
            "operations": [
                {
                    "name": "CURRENT",
                    "description": "Show current active role",
                    "examples": [
                        "ROLE CURRENT"
                    ]
                },
                {
                    "name": "SWITCH",
                    "description": "Switch to different role",
                    "examples": [
                        "ROLE SWITCH WIZARD",
                        "ROLE SWITCH IMP"
                    ],
                    "validation": "role_permission_check"
                },
                {
                    "name": "LIST",
                    "description": "List available roles and permissions",
                    "examples": [
                        "ROLE LIST",
                        "ROLE LIST --detailed"
                    ]
                }
            ],
            "integration": {
                "script": "uCORE/core/role-manager-v1.3.3.sh",
                "datasets": [
                    "user-roles.json"
                ],
                "validation": "role_permission_validator"
