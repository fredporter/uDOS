{
    "metadata": {
        "name": "uDOS Enhanced Variable Management System",
        "version": "2.1.3",
        "description": "Comprehensive variable and environment management for uDOS v1.3.3 with dataset integration",
        "last_updated": "2025-08-23",
        "system": "uDOS-v1.3.3",
        "format": "uDATA-v1",
        "features": [
            "instance_variables",
            "dataset_integration",
            "cross_references",
            "calculated_variables",
            "ugrid_variables",
            "role_based_variables"
        ]
    }
}
{
    "type": "instance_variable",
    "name": "INSTANCE-TIME",
    "value": "{auto:current-timestamp}",
    "data_type": "datetime",
    "format": "ISO8601",
    "readonly": true,
    "description": "Current timestamp in ISO 8601 format",
    "scope": "global"
}
{
    "type": "instance_variable",
    "name": "INSTANCE-LOCATION",
    "value": "{auto:hostname}",
    "data_type": "string",
    "readonly": true,
    "description": "Current system hostname/location identifier",
    "scope": "global"
}
{
    "type": "instance_variable",
    "name": "INSTANCE-USER",
    "value": "{auto:current-user}",
    "data_type": "string",
    "readonly": true,
    "description": "Current system user identifier",
    "scope": "global"
}
{
    "type": "instance_variable",
    "name": "INSTANCE-PATH",
    "value": "{auto:current-path}",
    "data_type": "string",
    "readonly": true,
    "description": "Current working directory path",
    "scope": "global"
}
{
    "type": "instance_variable",
    "name": "INSTANCE-SHELL",
    "value": "{auto:shell}",
    "data_type": "string",
    "readonly": true,
    "description": "Current shell environment",
    "scope": "global"
}
{
    "type": "instance_variable",
    "name": "INSTANCE-PLATFORM",
    "value": "{auto:platform}",
    "data_type": "string",
    "readonly": true,
    "description": "Operating system platform",
    "scope": "global"
}
{
    "type": "instance_variable",
    "name": "INSTANCE-ARCHITECTURE",
    "value": "{auto:arch}",
    "data_type": "string",
    "readonly": true,
    "description": "System architecture",
    "scope": "global"
}
{
    "type": "instance_variable",
    "name": "INSTANCE-MEMORY",
    "value": "{auto:memory}",
    "data_type": "string",
    "readonly": true,
    "description": "System memory information",
    "scope": "global"
}
{
    "type": "instance_variable",
    "name": "INSTANCE-CPU",
    "value": "{auto:cpu}",
    "data_type": "string",
    "readonly": true,
    "description": "CPU information",
    "scope": "global"
}
{
    "type": "dataset_variable",
    "name": "TIMEZONE-AUTO",
    "value": "{dataset:timezone-auto}",
    "data_type": "object",
    "readonly": true,
    "description": "Auto-detected timezone information",
    "scope": "global"
}
{
    "type": "dataset_variable",
    "name": "LOCATION-AUTO",
    "value": "{dataset:location-auto}",
    "data_type": "object",
    "readonly": true,
    "description": "Auto-detected geographic location",
    "scope": "global"
}
{
    "type": "dataset_variable",
    "name": "GRID-SIZE",
    "value": "{dataset:grid-dimensions}",
    "data_type": "string",
    "readonly": false,
    "description": "Current uGRID dimensions",
    "scope": "session"
}
{
    "type": "dataset_variable",
    "name": "ROLE-CURRENT",
    "value": "{dataset:current-role}",
    "data_type": "string",
    "readonly": false,
    "description": "Currently active user role",
    "scope": "session"
}
{
    "type": "system_variable",
    "name": "UDOS-VERSION",
    "value": "1.3.3",
    "data_type": "string",
    "readonly": true,
    "description": "uDOS system version",
    "scope": "global"
}
{
    "type": "system_variable",
    "name": "UDATA-FORMAT",
    "value": "v1",
    "data_type": "string",
    "readonly": true,
    "description": "uDATA format version",
    "scope": "global"
}
{
    "type": "system_variable",
    "name": "DEFAULT-PALETTE",
    "value": "polaroid_colors",
    "data_type": "string",
    "readonly": false,
    "description": "Default color palette name",
    "scope": "global"
}
{
    "type": "ugrid_variable",
    "name": "GRID-MAX-WIDTH",
    "value": "160",
    "data_type": "integer",
    "readonly": false,
    "description": "Maximum grid width in columns",
    "scope": "session"
}
{
    "type": "ugrid_variable",
    "name": "GRID-MAX-HEIGHT",
    "value": "60",
    "data_type": "integer",
    "readonly": false,
    "description": "Maximum grid height in rows",
    "scope": "session"
}
{
    "type": "ugrid_variable",
    "name": "WIDGET-COUNT",
    "value": "{calculated:widget-count}",
    "data_type": "integer",
    "readonly": true,
    "description": "Current widget count",
    "scope": "session"
}
{
    "type": "template_variable",
    "name": "TEMPLATE-ROOT",
    "value": "{path:uTemplate}",
    "data_type": "string",
    "readonly": true,
    "description": "Template system root path",
    "scope": "global"
}
{
    "type": "template_variable",
    "name": "MEMORY-ROOT",
    "value": "{path:uMemory}",
    "data_type": "string",
    "readonly": true,
    "description": "Memory system root path",
    "scope": "global"
}
{
    "type": "template_variable",
    "name": "SCRIPT-ROOT",
    "value": "{path:uScript}",
    "data_type": "string",
    "readonly": true,
    "description": "Script system root path",
    "scope": "global"
}
{
    "type": "command",
    "name": "set",
    "syntax": "SET <variable_name> = <value>",
    "description": "Set variable value with type validation",
    "category": "variable_management"
}
{
    "type": "command",
    "name": "unset",
    "syntax": "UNSET <variable_name>",
    "description": "Remove variable",
    "category": "variable_management"
}
{
    "type": "command",
    "name": "list",
    "syntax": "LIST [scope]",
    "description": "List all variables in scope",
    "category": "variable_management"
}
{
    "type": "command",
    "name": "export",
    "syntax": "EXPORT <variable_name>",
    "description": "Export variable to system environment",
    "category": "variable_management"
}
{
    "type": "command",
    "name": "import",
    "syntax": "IMPORT <env_variable>",
    "description": "Import system environment variable",
    "category": "variable_management"
}
{
    "type": "template_syntax",
    "name": "variable_substitution",
    "syntax": "{VARIABLE-NAME}",
    "description": "Replace with variable value in templates (v1.3.3 format)",
    "category": "templating"
}
{
    "type": "template_syntax",
    "name": "conditional_blocks",
    "syntax": "{#if VARIABLE-NAME} content {/if}",
    "description": "Conditional content based on variable value",
    "category": "templating"
}
{
    "type": "template_syntax",
    "name": "loops",
    "syntax": "{#each ARRAY-VARIABLE} {this} {/each}",
    "description": "Iterate over array variables",
    "category": "templating"
}
{
    "type": "template_syntax",
    "name": "role_conditional",
    "syntax": "{#role ACCESS-LEVEL} content {/role}",
    "description": "Role-based conditional content",
    "category": "templating"
}
