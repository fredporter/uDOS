# v1.5 @dev workspace: track only the distributable scaffold.
*
!.gitignore
!AGENTS.md
!README.md
!extension.json
!docs/
!docs/**
!goblin/
!goblin/**
!ops/
!ops/**

# Keep local/private contributor state out of sync.
files/
relecs/
dev-work/
testing/

# Ignore generated clutter inside tracked payload paths.
**/__pycache__/
**/.pytest_cache/
**/.mypy_cache/
**/.DS_Store
**/*.pyc
**/*.pyo
**/.env
**/.env.*
