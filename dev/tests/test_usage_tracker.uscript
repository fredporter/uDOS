# ============================================================================
# test_usage_tracker.uscript
# Usage Tracker Test Script for v1.0.12
# ============================================================================
# Tests the UsageTracker service and enhanced HELP commands
# ============================================================================

# ----------------------------------------------------------------------------
# Execute some commands to build usage history
# ----------------------------------------------------------------------------
HELP
STATUS
LIST
HELP STATUS
GRID
HELP
STATUS
MAP STATUS
HELP SEARCH file
LIST
STATUS
HELP CATEGORY system

# ----------------------------------------------------------------------------
# Test 1: HELP RECENT - Show recently used commands
# ----------------------------------------------------------------------------
HELP RECENT

# ----------------------------------------------------------------------------
# Test 2: HELP STATS - Show most used commands
# ----------------------------------------------------------------------------
HELP STATS

# ----------------------------------------------------------------------------
# Test 3: HELP SESSION - Show current session statistics
# ----------------------------------------------------------------------------
HELP SESSION

# ----------------------------------------------------------------------------
# Execute more commands
# ----------------------------------------------------------------------------
HELP
STATUS
HELP
HELP
STATUS

# ----------------------------------------------------------------------------
# Test 4: Check updated statistics
# ----------------------------------------------------------------------------
HELP RECENT
HELP STATS
HELP SESSION
