# Test script for v1.0.17 debugger
# This script tests basic debugging functionality

# Set some variables
SET x = 10
SET y = 20
SET name = "Debug Test"

# Do some math
SET sum = x + y
SET product = x * y

# Test a loop
FOR i IN RANGE 1 TO 5
    SET counter = i * 2
    # This line will be a breakpoint test
    SET result = counter + x
END

# Final output
SET final_message = "Debugging complete!"
