# uCODE Conditionals Test Script
# Tests IF/ELSE/ENDIF with various conditions

# Test 1: Simple IF
SET age = 25
IF age > 18
  SET status = adult
ENDIF
GET status

# Test 2: IF with ELSE
SET score = 85
IF score >= 90
  SET grade = A
ELSE
  SET grade = B
ENDIF
GET grade

# Test 3: Comparison operators
SET x = 10
SET y = 20

IF x < y
  SET result = x is less than y
ENDIF
GET result

IF x == 10
  SET check = x equals 10
ENDIF
GET check

IF x != y
  SET different = yes, they are different
ENDIF
GET different

# Test 4: Logical operators (AND)
SET temp = 75
SET sunny = true

IF temp > 70 AND sunny == true
  SET weather = Perfect day!
ENDIF
GET weather

# Test 5: Logical operators (OR)
SET day = Saturday
IF day == Saturday OR day == Sunday
  SET weekend = true
ELSE
  SET weekend = false
ENDIF
GET weekend

# Test 6: NOT operator
SET raining = false
IF NOT raining
  SET activity = Go outside
ELSE
  SET activity = Stay inside
ENDIF
GET activity

# Test 7: Nested IF
SET level = 15
IF level > 10
  SET rank = intermediate
  IF level > 20
    SET rank = expert
  ENDIF
ENDIF
GET rank

# Test 8: Multiple conditions
SET balance = 1000
IF balance > 500
  SET account_status = good
  IF balance > 5000
    SET account_status = excellent
  ENDIF
ELSE
  SET account_status = low
ENDIF
GET account_status

# Test 9: Complex expression
SET age = 30
SET has_license = true
IF age >= 18 AND has_license == true
  SET can_drive = Yes
ELSE
  SET can_drive = No
ENDIF
GET can_drive

# Display all variables
VARS
