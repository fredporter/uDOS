{
  "id": "dev-mode",
  "name": "Dev Mode",
  "version": "1.5.0",
  "status": "active",
  "entry": "implicit-dev-extension-lane",
  "runtime_owner": "wizard",
  "framework_root": "/dev",
  "activation": {
    "explicit": false,
    "implicit": true,
    "install_owner": "wizard-gui",
    "profile": "dev",
    "permissions": ["admin", "dev_mode"]
  },
  "commands": {
    "status": {
      "aliases": ["stat", "mode", "state"]
    },
    "on": {
      "aliases": ["activate", "start"]
    },
    "off": {
      "aliases": ["deactivate", "stop"]
    },
    "restart": {
      "aliases": []
    },
    "logs": {
      "aliases": ["log"]
    },
    "health": {
      "aliases": []
    },
    "clear": {
      "aliases": []
    }
  },
  "syntax": "Wizard-managed Dev Mode extension lifecycle with contributor TUI access once active",
  "summary": "Permission-gated Dev extension framework for contributor workflows, Dev-specific TUI tooling, GitHub sync, and isolated contributor roadmap management."
}
