# ══════════════════════════════════════════════════
# uDOS v1.4 Clean Distribution .gitignore
# Role/User/Backup Isolation System
# ══════════════════════════════════════════════════

# ════════════════════════════════════════════════════════════════
# 🎯 uDOS DISTRIBUTION STRATEGY v1.4
# ════════════════════════════════════════════════════════════════
# ✅ Keep: Core system, role installers, shared frameworks
# 🚫 Exclude: User data, role installations, backup files
# 🔄 Sync: Only distribution components, no personal content

# ════════════════════════════════════════════════════════════════
# 🔒 COMPLETE LOCAL-ONLY EXCLUSIONS
# ════════════════════════════════════════════════════════════════

# Role installations (local only after install)
/ROLE/

# User data isolation (local only)
/USER/

# Centralized backup system (local only)
/BACKUP/

# ════════════════════════════════════════════════════════════════
# 🛠️ DEVELOPMENT FRAMEWORK EXCLUSIONS
# ════════════════════════════════════════════════════════════════

# Keep core dev tools, exclude user dev data
dev/USER/
dev/**/*.user.*
dev/**/*.personal.*
dev/**/*.working
dev/**/*.tmp

# Keep core sandbox framework, exclude user sandbox data
sandbox/USER/
sandbox/**/*.user.*
sandbox/**/*.personal.*
sandbox/**/*.working
sandbox/**/*.tmp

# ════════════════════════════════════════════════════════════════
# 🏗️ SYSTEM COMPONENT EXCLUSIONS
# ════════════════════════════════════════════════════════════════

# uMEMORY: Keep system templates, exclude user/role data
uMEMORY/user/
uMEMORY/role/
uMEMORY/**/*.user.*
uMEMORY/**/*.personal.*

# Wizard: Keep distribution notes/tools, exclude user sessions
wizard/USER/
wizard/**/*.user.*
wizard/**/*.personal.*
wizard/**/*.session.*

# ════════════════════════════════════════════════════════════════
# 🚫 STANDARD EXCLUSIONS
# ════════════════════════════════════════════════════════════════

# Logs and temporary files
**/*.log
**/*.tmp
**/*.working
**/*.cache
**/*.temp

# Development environments and build artifacts
**/venv/
**/venv3/
**/.venv/
**/node_modules/
**/__pycache__/
*.pyc
**/cache/
**/Cache/
**/dist/
**/build/
**/out/
*.dmg
*.zip
*.tar.gz

# System files
.DS_Store
**/.DS_Store

# Personal configurations
.env
.env.local
*.user.*
*.personal.*
personal-*
user-*

# IDE configurations (keep shared configs, exclude personal)
.vscode/settings.json
.vscode/launch.json
.idea/

# ════════════════════════════════════════════════════════════════
# ✅ uDOS v1.4 DISTRIBUTION INCLUDES
# ════════════════════════════════════════════════════════════════
# ✅ uCORE/ - Core system with role installers
# ✅ dev/ - Development framework (core tools only)
# ✅ sandbox/ - Sandbox framework (core templates only)
# ✅ docs/ - Complete documentation
# ✅ shared/ - Shared resources and templates
# ✅ extensions/ - Core extensions
# ✅ wizard/ - Distribution notes and tools
# ✅ install.sh - Main installer
# ✅ README.md, LICENSE, documentation files

# ════════════════════════════════════════════════════════════════
# 🚫 uDOS v1.4 DISTRIBUTION EXCLUDES
# =============================================================================
# uDOS v1.4 - Clean Distribution Configuration
# DEV/Sandbox/uMEMORY isolation system
# =============================================================================

# ════════════════════════════════════════════════════════════════
# 🔧 DEV MODE (Wizard + DEV activated) - Core uDOS Development
# ════════════════════════════════════════════════════════════════
# ✅ Sync: Framework tools, templates, core scripts
# 🚫 Local: Active development work, personal tools

dev/active/                     # Core dev work (LOCAL ONLY)
dev/scripts/*.local.*           # Local development scripts
dev/tools/*.personal.*          # Personal development tools
dev/**/*.working                # Work-in-progress files
dev/**/*.tmp                    # Temporary dev files

# ════════════════════════════════════════════════════════════════
# 🚀 SANDBOX (All roles) - User workspace (FLUSHABLE)
# ════════════════════════════════════════════════════════════════
# ✅ Sync: Framework structure, guides, templates
# 🚫 Local: ALL user content (designed to be flushable)

sandbox/current-session.md      # Current session data
sandbox/scripts/                # User scripts (flushable)
sandbox/experiments/            # User experiments (flushable)
sandbox/tasks/                  # Current tasks (flushable)
sandbox/sessions/               # Session data (flushable → archive)
sandbox/logs/                   # Session logs (flushable → archive)
sandbox/dev/                    # User dev work (flushable)
sandbox/**/*.user.*             # User-specific content
sandbox/**/*.session.*          # Session-specific content
sandbox/**/*.working            # Work-in-progress files
sandbox/**/*.tmp                # Temporary files

# ════════════════════════════════════════════════════════════════
# 🧠 uMEMORY - Memory archive system
# ════════════════════════════════════════════════════════════════
# ✅ Sync: Framework structure, core memory, system memory
# 🚫 Local: Role/user memory archives

uMEMORY/role/                   # Role memory archives (LOCAL ONLY)
uMEMORY/user/                   # User memory archives (LOCAL ONLY)

# Keep framework structure (these stay on GitHub)
!uMEMORY/
!uMEMORY/README.md
!uMEMORY/core/
!uMEMORY/system/
!uMEMORY/role/README.md
!uMEMORY/user/README.md

# ════════════════════════════════════════════════════════════════
# 📦 OTHER SYSTEMS
# ════════════════════════════════════════════════════════════════

# Centralized backup system (local only)
BACKUP/
uSCRIPT/venv/

# Dev folder patterns - sync templates and docs, exclude active work
dev/active/
dev/scripts/maintenance/temp-*
dev/tools/temp-*
dev/copilot/temp-*

# Keep these for collaboration
!dev/templates/
!dev/docs/
!dev/roadmaps/
!dev/copilot/instructions/
!dev/copilot/context/
!dev/vscode/configs/
