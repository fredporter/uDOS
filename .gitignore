# ──────────────────────────────────────────────
# uDOS v1.3 .gitignore
# Clean Repository Architecture - Production Ready
# ──────────────────────────────────────────────

# ════════════════════════════════════════════════════════════════
# 🔒 SECURITY MODEL ENFORCEMENT
# ════════════════════════════════════════════════════════════════

# 🔐 Level 1: uMEMORY - Private User Files (NEVER in repo)
# Contains personal data, logs, state, missions, moves
uMEMORY/
uMEMORY.backup/

# 🔐 Level 2: Sandbox Personal Data
sandbox/user.md
sandbox/user-data/
sandbox/experiments/
sandbox/drafts/
sandbox/personal/

# ════════════════════════════════════════════════════════════════
# 🚫 BUILD ARTIFACTS & DEVELOPMENT FILES
# ════════════════════════════════════════════════════════════════

# Build and compilation artifacts
__pycache__/
*.pyc
*.pyo
*.so
*.out
*.exe
dist/
build/
out/

# Package manager files
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# Large demo files and assets (should be downloaded separately)
**/demo/
**/demos/
**/data/input.*
**/data/output.*
**/fonts/*.ttf
**/fonts/*.ttc
*.gif
*.mp4
*.avi
*.mov
*.webm

# Generated/downloaded content
downloads/
cache/
temp-downloads/

# Logs and temporary files
**/*.log
*.tmp
*.working
validation-*.log
test.log
test-*.log
test-output-*
gemini-*.log

# macOS system files
.DS_Store
**/.DS_Store
.ipynb_checkpoints/
Thumbs.db

# Distribution archives and installation artifacts
*.zip
*.tar.gz
*.dmg
*.vsix
uDOS-v*.tar.gz
uDOS-v*.zip

# Local installation artifacts (generated during install)
install-udos.log
installation.log
validation-*.log
user-config.local
setup-complete.flag

# ════════════════════════════════════════════════════════════════
# 🛠️ DEVELOPMENT ENVIRONMENT FILES
# ════════════════════════════════════════════════════════════════

# uDEV wizard development environment - personal logs and sessions
uDEV/logs/
uDEV/summaries/
uDEV/.dev-session-*
*.uLOG

# ════════════════════════════════════════════════════════════════
# �️ EDITOR & IDE ARTIFACTS
# ════════════════════════════════════════════════════════════════

# VS Code personal settings (keep workspace config)
.vscode/settings.json.local
.env
.env.local

# Gemini CLI authentication
.gemini/
~/.gemini/

# ════════════════════════════════════════════════════════════════
# 📱 DISTRIBUTION ARTIFACTS (built locally)
# ════════════════════════════════════════════════════════════════

# Generated distribution packages
release/
dist-packages/
uCORE/launcher/uDOS.app/Contents/
uCORE/launcher/build/
uCORE/launcher/*.dmg
uCORE/launcher/uDOS_installation.log

# Local user modifications and configs
user.config
local.settings
*.user.md
personal-*.md

# Generated documentation exports
exports/
generated-docs/

# ════════════════════════════════════════════════════════════════
# 🧪 TESTING & DEVELOPMENT
# ════════════════════════════════════════════════════════════════

# Test environments
/tmp/
temp/
testing/
scratch/

# Development progress tracking
dev-notes/
personal-notes/

# User-specific configurations
config.local.*
settings.local.*

# Generated files that should be rebuilt on install
system-info.txt
installation-report.txt

# ════════════════════════════════════════════════════════════════
# 🗑️ TRASH SYSTEM - Archived and deprecated files
# ════════════════════════════════════════════════════════════════
# Contains old/deprecated files moved during cleanup
# This folder is tracked to maintain cleanup history
trash/

# ════════════════════════════════════════════════════════════════
# ✅ WHAT STAYS IN REPOSITORY (uDOS v1.3)
# ════════════════════════════════════════════════════════════════
# ✅ uCORE/ - Core system architecture and functionality
# ✅ uDEV/ - Wizard development environment (tools only, not logs)
# ✅ uKNOWLEDGE/ - Knowledge base system
# ✅ docs/ - Consolidated documentation system
# ✅ sandbox/ - User workspace templates and task management
# ✅ Core files: README.md, LICENSE, CHANGELOG.md, etc.
# ✅ VS Code workspace configuration (.vscode/)
# ════════════════════════════════════════════════════════════════
