# ══════════════════════════════════════════════════
# uDOS v1.0.4.1 Clean Distribution .gitignore
# Simple Directory-Based Exclusion Strategy
# ══════════════════════════════════════════════════

# ════════════════════════════════════════════════════════════════
# 🎯 uDOS DISTRIBUTION STRATEGY v1.0.4.1
# ════════════════════════════════════════════════════════════════
# ✅ Include: Core system, shared templates, framework
# 🚫 Exclude: User data, runtime files, personal content

# ════════════════════════════════════════════════════════════════
# 📁 DIRECTORY-BASED EXCLUSIONS
# ════════════════════════════════════════════════════════════════

# Development workspace (exclude active development)
dev/active/                     # Active development work (LOCAL ONLY)
dev/roadmaps/archive/           # Roadmap archives (LOCAL ONLY)
dev/scripts/maintenance/        # Maintenance scripts (LOCAL ONLY)
dev/tools/temp/                 # Temporary tools (LOCAL ONLY)

# User workspace (exclude all user content)
sandbox/logs/                   # All user logging
sandbox/sessions/               # Session data
sandbox/scripts/                # User scripts
sandbox/experiments/            # User experiments
sandbox/tasks/                  # User tasks
sandbox/generated/              # Generated content
sandbox/workflow/               # Workflow data
sandbox/user/                   # User subdirectory

# Memory system (exclude user/role data)
uMEMORY/user/                   # User memory archives
uMEMORY/role/                   # Role configurations

# System directories (exclude runtime/cache)
**/cache/                       # All cache directories
**/logs/                        # All log directories
**/temp/                        # All temp directories
**/tmp/                         # All tmp directories
backup/                         # Backup directory
trash/                          # Trash directory

# ════════════════════════════════════════════════════════════════
# � FILE PATTERN EXCLUSIONS
# ════════════════════════════════════════════════════════════════

# User-specific files
sandbox/user.md                 # User profile
*.user.*                        # User-specific files
*.personal.*                    # Personal files
*testuser*                      # Test user content
environment-*.sh                # User environment configs

# Runtime files
*.log                           # Log files
*.tmp                           # Temporary files
*.cache                         # Cache files
*.session.*                     # Session files
*.working                       # Work-in-progress files

# Development files
**/__pycache__/                 # Python cache
**/node_modules/                # Node modules
**/venv/                        # Python virtual environments
**/.env                         # Environment files

# System files
.DS_Store                       # macOS system files
**/.DS_Store                    # macOS system files (recursive)

# ════════════════════════════════════════════════════════════════
# ✅ CLEAN DISTRIBUTION INCLUDES
# ════════════════════════════════════════════════════════════════
# ✅ uCORE/ - Core system
# ✅ uNETWORK/ - Network layer
# ✅ uSCRIPT/ - Script system
# ✅ uKNOWLEDGE/ - Knowledge base
# ✅ extensions/ - Extension framework
# ✅ docs/ - Documentation
# ✅ dev/templates/ - Development templates
# ✅ dev/docs/ - Architecture docs
# ✅ dev/copilot/ - AI context
# ✅ dev/vscode/ - VS Code configs
# ✅ sandbox/README.md - Framework docs
# ✅ uMEMORY/system/ - System templates
# ✅ uMEMORY/templates/ - Memory templates
