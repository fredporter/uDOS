# ──────────────────────────────────────────────
# uDOS .gitignore — excludes system/cache/local content
# ──────────────────────────────────────────────

# Python + general build artifacts
__pycache__/
*.pyc
*.pyo
**/*.log
*.zip
*.so
*.out
*.exe

# Editor/IDE cruft
.env
.vscode/
.idea/
*.DS_Store

# Docker override (local config)
docker-compose.override.yml

# uMemory — personal, private, local-only storage
uMemory/
sandbox/

# System files
/tmp/
.ipynb_checkpoints/