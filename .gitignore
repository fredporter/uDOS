*.user.*
*.personal.*
*-user-*
user-*
*user*
environment-*.sh
identity.*
installation.id
installation.md
user.md
current-session.*
*session*
*.session*

# Memory and data
uMEMORY/data/
uMEMORY/user/
uMEMORY/role/
uMEMORY/logs/
uMEMORY/installation.id
uKNOWLEDGE/data/

