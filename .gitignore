# ============================================================
# uDOS - Git Ignore Configuration
# ============================================================

# Environment & Secrets
# ----------------------
.env
.env.local
*.key

# Gmail OAuth2 credentials and tokens (v1.2.9+)
memory/system/user/gmail_credentials.json
memory/system/user/.gmail_token.enc
*.gmail_token*

# Python Runtime
# ----------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/

# Virtual Environments
# ----------------------
.venv/
venv/
env/
ENV/
pip-selfcheck.json

# IDE & System Files
# ----------------------
.DS_Store
.vscode/settings.json
.idea/
*.swp
*.swo
*~
.cache/
.pytest_cache/

# Extensions - Clone Management
# ----------------------
# Track uDOS-native web applications and setup scripts
# Ignore all cloned third-party repositories
!extensions/
!extensions/web/
!extensions/web/**
!extensions/*.sh
!extensions/**/*.md
!extensions/**/README.md

# Ignore all cloned repositories and embedded git repos
extensions/clone/
extensions/native/
extensions/cloned/
extensions/web/c64css3/
extensions/clone/monaspace-fonts/
# But track clone directories structure
!extensions/clone/
!extensions/native/
!extensions/cloned/
!extensions/clone/.gitkeep
!extensions/native/.gitkeep
!extensions/cloned/.gitkeep

# Sandbox - DEPRECATED (v1.2.12+)
# ----------------------
# Sandbox directory deprecated - use memory/ instead
# Only track DEPRECATED.md notice file
sandbox/
!sandbox/DEPRECATED.md

# Memory - Working Directory (User Workspace)
# ----------------------
# Core scripts and tests are tracked in memory/ucode/
# Everything else is user workspace (gitignored)
memory/
!memory/ucode/
!memory/ucode/**
!memory/README.md
!memory/README-*.md
!memory/.gitkeep
!memory/pytest.ini
!memory/structure.txt

# User Customization Files (Track Templates Only)
# ----------------------
# .UDC = User Data Configuration (user-specific overrides)
# .UDT = UDO Template (tracked templates, ignore user instances)
*.UDC
data/STORY.UDO
data/USER.UDO

# Keep templates tracked
!data/*.UDT
!knowledge/**/*.UDT
!memory/templates/*.UDT

# Session & Server State
# ----------------------
memory/workflows/logs/
memory/workflows/logs/**/*
*.pid
*.state

# Wiki Deployment
# ----------------------
# Keep source in /wiki, ignore deployed clone
uDOS.wiki/

# Backups & Archives (v1.1.16+)
# ----------------------
# Universal .archive/ folders (version history, backups, soft-deletes)
.archive/
**/.archive/
backups/
*.backup
*.bak

# Output Files
# ----------------------
# Prevent root-level working directories from being created/tracked
/output/
/output
/data/
/data
*.output

# Test Files - Only in Proper Locations
# ----------------------
# Prevent test files from being created in root
/test_*.py
/test_*.uscript
/test_*.sh
/*.test.*
/tmp_*
/temp_*

# Allow tests in proper directories
!memory/tests/
!memory/tests/**/*
!sandbox/tests/

# Data Architecture Separation (v1.0.20b)
# ----------------------
# /knowledge/system/ - TRACKED (core reference data, ships with uDOS)
!knowledge/
!knowledge/**/*

# /memory/ - UNIFIED USER WORKSPACE (v1.1.13+)
# ----------------------
# Track: ucode/ (core distributable scripts and tests)
# Ignore: Everything else (user data, active work, logs)

memory/
memory/**/*

# Track core distributable scripts and tests
!memory/ucode/
!memory/ucode/**/*
!memory/README.md
!memory/README-v1.1.13.md
!memory/.gitignore

# Track directory structure (empty placeholders)
!memory/missions/
!memory/missions/.gitkeep
!memory/workflows/
!memory/workflows/.gitkeep
# Ignore all user data and active work
memory/workflows/**/*
memory/system/**/*
memory/shared/**/*
memory/bank/**/*
memory/docs/**/*
memory/drafts/**/*

# User databases and logs (always ignore)
*.db
*.sqlite
*.sqlite3
*.log

# Development Workspace (v1.1.13 - tracked in git)
# ----------------------
!dev/
!dev/**/*

# Sandbox - DEPRECATED (v1.1.13 - use /memory/ instead)
# ----------------------
sandbox/
sandbox/**/*
!sandbox/README.md
!sandbox/.gitkeep

# /knowledge/ - TRACKED (core knowledge library, ships with uDOS)
!knowledge/
!knowledge/**/*

# /history/ - TRACKED (system history templates)
!history/
!history/**/*
