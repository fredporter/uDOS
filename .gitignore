# ──────────────────────────────────────────────
# uDOS .gitignore — v1.7.1 Reorganized Architecture
# ──────────────────────────────────────────────

# Python + general build artifacts
__pycache__/
*.pyc
*.pyo
**/*.log
*.zip
*.so
*.out
*.exe

# Editor/IDE cruft  
.env
*.DS_Store

# VS Code settings (keep workspace config but exclude personal settings)
.vscode/settings.json.local

# uMemory — personal, private, local-only storage (reorganized)
uMemory/

# System files
/tmp/
.ipynb_checkpoints/

# macOS launcher generated files
launcher/uDOS-Modern.app/Contents/MacOS/
launcher/uDOS_installation.log