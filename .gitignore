# ══════════════════════════════════════════════════
# uDOS v1.4 Clean Distribution .gitignore
# Development/User/Memory Isolation System
# ══════════════════════════════════════════════════

# ════════════════════════════════════════════════════════════════
# 🎯 uDOS DISTRIBUTION STRATEGY v1.4
# ════════════════════════════════════════════════════════════════
# ✅ Keep: Core system, dev framework, shared templates
# 🚫 Exclude: User data, active development, personal content
# 🔄 Sync: Only collaborative components

# ════════════════════════════════════════════════════════════════
# � DEV FOLDER - Wizard Role + DEV Mode Development
# ════════════════════════════════════════════════════════════════
# ✅ Sync: Templates, docs, copilot context, shared configs
# 🚫 Local: Active development work, personal tools, temp files

dev/active/                     # Core development work (LOCAL ONLY)
dev/scripts/maintenance/temp-*  # Temporary maintenance scripts
dev/tools/temp-*               # Temporary development tools
dev/**/*.local.*               # Local development files
dev/**/*.personal.*            # Personal development tools
dev/**/*.working               # Work-in-progress files
dev/**/*.tmp                   # Temporary dev files

# Keep collaborative dev content
!dev/templates/                 # Development templates (SYNCED)
!dev/docs/                     # Architecture docs (SYNCED)
!dev/roadmaps/                 # Project roadmaps (SYNCED)
!dev/copilot/                  # AI assistant context (SYNCED)
!dev/vscode/                   # VS Code configs (SYNCED)
!dev/scripts/build/            # Build scripts (SYNCED)
!dev/scripts/test/             # Test scripts (SYNCED)
!dev/scripts/deploy/           # Deploy scripts (SYNCED)

# ════════════════════════════════════════════════════════════════
# 🚀 SANDBOX - All Roles User Workspace (FLUSHABLE)
# ════════════════════════════════════════════════════════════════
# ✅ Sync: Framework structure only
# 🚫 Local: ALL user content (designed to be flushable)

sandbox/logs/                   # All logging (LOCAL ONLY)
sandbox/sessions/               # Session data (LOCAL ONLY)
sandbox/scripts/                # User scripts (LOCAL ONLY)
sandbox/experiments/            # User experiments (LOCAL ONLY)
sandbox/tasks/                  # Current tasks (LOCAL ONLY)
sandbox/documents/              # Document processing (LOCAL ONLY)
sandbox/data/                   # Data processing (LOCAL ONLY)
sandbox/**/*.user.*             # User-specific content
sandbox/**/*.session.*          # Session-specific content
sandbox/**/*.working            # Work-in-progress files
sandbox/**/*.tmp                # Temporary files

# Keep framework structure only
!sandbox/README.md
!sandbox/STRUCTURE.md

# ════════════════════════════════════════════════════════════════
# 🧠 uMEMORY - Memory Archive System
# ════════════════════════════════════════════════════════════════
# ✅ Sync: Framework structure and templates
# 🚫 Local: User/role data archives

uMEMORY/user/                   # User memory archives (LOCAL ONLY)
uMEMORY/role/                   # Role memory archives (LOCAL ONLY)
uMEMORY/**/*.user.*             # User-specific data
uMEMORY/**/*.personal.*         # Personal memory data

# Keep framework structure
!uMEMORY/README.md
!uMEMORY/templates/
!uMEMORY/user/README.md
!uMEMORY/role/README.md

# ════════════════════════════════════════════════════════════════
# � STANDARD DEVELOPMENT EXCLUSIONS
# ════════════════════════════════════════════════════════════════

# Development environments
**/venv/
**/venv3/
**/.venv/
**/node_modules/
**/__pycache__/
*.pyc
**/cache/
**/Cache/
**/dist/
**/build/
**/out/

# Logs and temporary files
**/*.log
**/*.tmp
**/*.working
**/*.cache
**/*.temp
**/*.bak
**/*.old

# System files
.DS_Store
**/.DS_Store

# Personal configurations
.env
.env.local
*.user.*
*.personal.*
personal-*
user-*

# IDE configurations (exclude personal, keep shared)
.vscode/settings.json
.vscode/launch.json
.idea/

# Build artifacts
*.dmg
*.zip
*.tar.gz

# ════════════════════════════════════════════════════════════════
# 🗑️ CLEANUP EXCLUSIONS
# ════════════════════════════════════════════════════════════════

# Trash and backup directories
trash/
backup/
BACKUP/

# Legacy and cleanup files
**/legacy/
**/deprecated/
**/*.legacy.*
**/*.deprecated.*

# ════════════════════════════════════════════════════════════════
# ✅ DISTRIBUTION INCLUDES SUMMARY
# ════════════════════════════════════════════════════════════════
# ✅ uCORE/ - Core system
# ✅ dev/templates/ - Development templates
# ✅ dev/docs/ - Architecture documentation  
# ✅ dev/copilot/ - AI assistant context
# ✅ dev/vscode/ - Shared VS Code configs
# ✅ docs/ - User documentation
# ✅ extensions/ - Extension system
# ✅ uNETWORK/ - Network components
# ✅ uSCRIPT/ - Script system
# ✅ uKNOWLEDGE/ - Knowledge base
# ✅ README.md, LICENSE, CHANGELOG.md
