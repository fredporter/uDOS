# ============================================================
# uDOS - Git Ignore Configuration
# ============================================================

# Environment & Secrets
# ----------------------
.env
.env.local
*.key

# Python Runtime
# ----------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/

# Virtual Environments
# ----------------------
.venv/
venv/
env/
ENV/
pip-selfcheck.json

# IDE & System Files
# ----------------------
.DS_Store
.vscode/settings.json
.idea/
*.swp
*.swo
*~
.cache/
.pytest_cache/

# Extensions - Clone Management
# ----------------------
# Track uDOS-native web applications and setup scripts
# Ignore all cloned third-party repositories
!extensions/
!extensions/web/
!extensions/web/**
!extensions/*.sh
!extensions/**/*.md
!extensions/**/README.md

# Ignore all cloned repositories and embedded git repos
extensions/clone/
extensions/native/
extensions/cloned/
extensions/web/c64css3/
extensions/clone/monaspace-fonts/
# But track clone directories structure
!extensions/clone/
!extensions/native/
!extensions/cloned/
!extensions/clone/.gitkeep
!extensions/native/.gitkeep
!extensions/cloned/.gitkeep

# Sandbox - Working Directory (User Workspace)
# ----------------------
# This is NOT tracked - users work here temporarily
sandbox/san
sandbox/*.txt
sandbox/*.md
sandbox/*.json
sandbox/.server_state.json
sandbox/tests/*.uscript
sandbox/tests/*.udo
sandbox/tests/*.py
sandbox/tests/*.sh

# User Customization Files (Track Templates Only)
# ----------------------
# .UDC = User Data Configuration (user-specific overrides)
# .UDT = UDO Template (tracked templates, ignore user instances)
*.UDC
data/STORY.UDO
data/USER.UDO

# Keep templates tracked
!data/*.UDT
!knowledge/**/*.UDT
!memory/templates/*.UDT

# Session & Server State
# ----------------------
memory/logs/
memory/logs/**/*
*.pid
*.state

# Wiki Deployment
# ----------------------
# Keep source in /wiki, ignore deployed clone
uDOS.wiki/

# Backups & Archives
# ----------------------
backups/
*.backup
*.bak

# Output Files
# ----------------------
# Prevent root-level working directories from being created/tracked
/output/
/output
/data/
/data
/sandbox/
/sandbox
*.output

# Test Files - Only in Proper Locations
# ----------------------
# Prevent test files from being created in root
/test_*.py
/test_*.uscript
/test_*.sh
/*.test.*
/tmp_*
/temp_*

# Allow tests in proper directories
!memory/tests/
!memory/tests/**/*
!sandbox/tests/

# Data Architecture Separation (v1.0.20b)
# ----------------------
# /knowledge/system/ - TRACKED (core reference data, ships with uDOS)
!knowledge/
!knowledge/**/*

# /memory/ - USER DATA (gitignored, user-writable workspace)
# v1.1.0: Track templates and tests for distribution, ignore user content
memory/
memory/**/*

# Track structure, templates, and tests
!memory/README.md
!memory/.gitignore
!memory/config/
!memory/config/.gitkeep

# Sandbox directories (v2.0.0 structure - development workspace)
!sandbox/
!sandbox/README.md
!sandbox/.gitkeep
!sandbox/peek/
!sandbox/peek/.gitkeep
!sandbox/dev/
!sandbox/dev/README.md
!sandbox/dev/planning/
!sandbox/dev/planning/**/*
sandbox/dev/sessions/
sandbox/dev/notes/
sandbox/dev/archive/
sandbox/logs/
sandbox/drafts/
sandbox/docs/
sandbox/trash/
sandbox/workflow/
sandbox/scripts/
sandbox/tests/
sandbox/ucode/
sandbox/user/
sandbox/user.json
sandbox/.server_state.json
sandbox/.pytest_cache/

# Memory tiers (4-tier system)
!memory/community/  # Public tier (user-generated content)
!memory/shared/     # Shared tier (explicit sharing)
!memory/groups/     # Groups tier
!memory/user/
!memory/user/.gitkeep
!memory/planet/
!memory/planet/.gitkeep

# User databases and logs (always ignore)
*.db
*.sqlite
*.sqlite3

# Old memory structure (pre-v1.1.0 deprecated paths)
memory/logs/
memory/sandbox/
memory/workflow/
memory/private/
memory/public/
memory/personal/
memory/workspace/
memory/legacy/
memory/missions/
memory/scenarios/

# /knowledge/ - TRACKED (core knowledge library, ships with uDOS)
!knowledge/
!knowledge/**/*

# /history/ - TRACKED (system history templates)
!history/
!history/**/*
