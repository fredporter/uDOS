# ──────────────────────────────────────────────
# uDOS Alpha v1.0 .gitignore
# Clean Repository Architecture - Production Ready
# ──────────────────────────────────────────────

# ════════════════════════════════════════════════════════════════
# 🔒 SECURITY MODEL ENFORCEMENT
# ════════════════════════════════════════════════════════════════

# 🔐 Level 1: uMemory - Private User Files (NEVER in repo)
# Contains personal data, logs, state, missions, moves
uMemory/

# ════════════════════════════════════════════════════════════════
# 🚫 BUILD ARTIFACTS & DEVELOPMENT FILES
# ════════════════════════════════════════════════════════════════

# Build and compilation artifacts
__pycache__/
*.pyc
*.pyo
*.so
*.out
*.exe
dist/
build/
out/

# Package manager files
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Logs and temporary files
**/*.log
*.tmp
*.working
validation-*.log
test.log
test-*.log
test-output-*

# macOS system files
.DS_Store
**/.DS_Store
.ipynb_checkpoints/
Thumbs.db

# Distribution archives and installation artifacts
*.zip
*.tar.gz
*.dmg
*.vsix
uDOS-v*.tar.gz
uDOS-v*.zip

# Local installation artifacts (generated during install)
install-udos.log
installation.log
validation-*.log
user-config.local
setup-complete.flag

# Old/backup folders and files
uDOS-clean-dist/
uDOS-Extension/
uExtension/
*.backup
*.bak
*.old

# Development progress tracking (archived)
progress/

# Test files (temporary)
test-destroy.sh
test-trash.sh
test-*.sh

# ════════════════════════════════════════════════════════════════
# 🛠️ EDITOR & IDE ARTIFACTS
# ════════════════════════════════════════════════════════════════

# VS Code personal settings (keep workspace config)
.vscode/settings.json.local
.env

# ════════════════════════════════════════════════════════════════
# 📱 DISTRIBUTION ARTIFACTS (built locally)
# ════════════════════════════════════════════════════════════════

# Generated distribution packages
release/
dist-packages/
launcher/uDOS.app/Contents/
launcher/build/
launcher/*.dmg
launcher/uDOS_installation.log

# Local user modifications and configs
user.config
local.settings
*.user.md
personal-*.md

# Generated documentation exports
exports/
generated-docs/

# ════════════════════════════════════════════════════════════════
# 🧪 TESTING & DEVELOPMENT
# ════════════════════════════════════════════════════════════════

# Test environments
/tmp/
temp/
testing/
scratch/

# Generated sandbox content (daily workspace files)
sandbox/sessions/*
sandbox/temp/*
!sandbox/sessions/.gitkeep
!sandbox/temp/.gitkeep

# uCompanion system state (optional persistence)
uCompanion/state/
uCompanion/.companion-state
uCompanion/temp/

# Development progress tracking (archived in progress/ folder)
dev-notes/
personal-notes/

# User-specific configurations
config.local.*
settings.local.*

# Generated files that should be rebuilt on install
system-info.txt
installation-report.txt

# ════════════════════════════════════════════════════════════════
# 📝 ALPHA v1.0 - WHAT STAYS IN REPOSITORY
# ════════════════════════════════════════════════════════════════
# ✅ uCode/ - Core system scripts with Alpha v1.0 enhancements
# ✅ uKnowledge/ - Documentation and knowledge base
# ✅ uScript/ - System automation scripts
# 🗑️  TRASH SYSTEM - Old/deprecated files
# Contains archived progress, deprecated code, and deleted items
trash/

# ✅ uTemplate/ - Standard templates and datasets
# ✅ extension/ - VS Code extension (renamed from uExtension)
# ✅ package/ - Package management system (NEW)
# ✅ install/ - Installation and build scripts (NEW)
# ✅ sandbox/ - Daily workspace structure (NEW)
# ✅ Distribution scripts (install-udos.sh, etc.)
# ✅ Core documentation (README.md, roadmaps, etc.)
# ✅ VS Code workspace configuration (.vscode/tasks.json)
# ════════════════════════════════════════════════════════════════
