# ──────────────────────────────────────────────
# uOS .gitignore — excludes system/cache/local content
# ──────────────────────────────────────────────

# Ignore system-generated internals inside the .app
macos/Launch🌀uOS.app/Contents/
macos/Launch🌀uOS.app/_CodeSignature/
macos/Launch🌀uOS.app/Resources/
macos/Launch🌀uOS.app/Icon
macos/Launch🌀uOS.app/document.wflow
macos/Launch🌀uOS.app/*.lproj
macos/Launch🌀uOS.app/*.icns
macos/Launch🌀uOS.app/Assets.car
macos/Launch🌀uOS.app/Info.plist

# Keep base .app folder for packaging/distribution
!macos/Launch🌀uOS.app/

# Keep launcher shell scripts
!macos/Launch-uOS.command
!macos/Quit-uOS.command

# Python + general build artifacts
__pycache__/
*.pyc
*.pyo
*.log
*.zip

# Editor/IDE cruft
.env
.vscode/
.idea/
*.DS_Store

# Docker override (local config)
docker-compose.override.yml

# uMemory — personal, private, local-only storage
uMemory/