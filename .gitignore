# ──────────────────────────────────────────────
# uDOS .gitignore — v1.0 Release Clean Architecture
# ──────────────────────────────────────────────

# Python + general build artifacts
__pycache__/
*.pyc
*.pyo
**/*.log
*.zip
*.so
*.out
*.exe

# Node.js dependencies and build artifacts
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# VS Code Extension build artifacts
uExtension/dist/
uExtension/out/
uExtension/*.vsix
uExtension/node_modules/

# Complete uExtension folder (development artifacts)
uExtension/

# Editor/IDE cruft  
.env
*.DS_Store

# VS Code settings (keep workspace config but exclude personal settings)
.vscode/settings.json.local

# uMemory — personal, private, local-only storage
uMemory/

# Progress tracking and development files
progress/

# Backup and working files
*.bak
*.working
*.tmp
*.backup

# System files
/tmp/
.ipynb_checkpoints/

# macOS launcher generated files
launcher/uDOS.app/Contents/MacOS/
launcher/uDOS_installation.log

# Test output files
test-*.log
test-output-*