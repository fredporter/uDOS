# ============================================================
# uDOS - Git Ignore Configuration
# ============================================================

# Environment & Secrets
# ----------------------
.env
.env.local
*.key

# Python Runtime
# ----------------------
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/

# Virtual Environments
# ----------------------
.venv/
venv/
env/
ENV/
pip-selfcheck.json

# IDE & System Files
# ----------------------
.DS_Store
.vscode/settings.json
.idea/
*.swp
*.swo
*~
.pytest_cache/

# Extensions - Clone Management
# ----------------------
# Track uDOS-native web applications and setup scripts
# Ignore all cloned third-party repositories
!extensions/
!extensions/web/
!extensions/web/**
!extensions/*.sh
!extensions/**/*.md
!extensions/**/README.md

# Ignore all cloned repositories and embedded git repos
extensions/clone/
extensions/native/
extensions/cloned/
extensions/web/c64css3/
extensions/clone/monaspace-fonts/
# But track clone directories structure
!extensions/clone/
!extensions/native/
!extensions/cloned/
!extensions/clone/.gitkeep
!extensions/native/.gitkeep
!extensions/cloned/.gitkeep

# Sandbox - Working Directory (User Workspace)
# ----------------------
# This is NOT tracked - users work here temporarily
sandbox/san
sandbox/*.txt
sandbox/*.md
sandbox/*.json
sandbox/.server_state.json
sandbox/tests/*.uscript
sandbox/tests/*.udo
sandbox/tests/*.py
sandbox/tests/*.sh

# User Customization Files (Track Templates Only)
# ----------------------
# .UDC = User Data Configuration (user-specific overrides)
# .UDT = UDO Template (tracked templates, ignore user instances)
*.UDC
data/STORY.UDO
data/USER.UDO

# Keep templates tracked
!data/*.UDT
!knowledge/**/*.UDT
!memory/templates/*.UDT

# Session & Server State
# ----------------------
memory/logs/
memory/logs/**/*
*.pid
*.state

# Development Workspace (v1.0.27+)
# ----------------------
# /dev/ = Development workspace (mostly NOT distributed)
# /dev/planning/ = Roadmaps and specs (TRACKED for contributors)
# /dev/archive/ = Development history (NOT tracked, local only)
# /dev/notes/ = Personal notes (NOT tracked, local only)
# /wiki/ = User-facing documentation (distributed with uDOS)

# Ignore most of /dev except planning and tools
/dev/archive/
/dev/notes/
# Track these for contributors:
!/dev/
!/dev/README.md
!/dev/planning/
!/dev/planning/**/*
!/dev/tools/
!/dev/tools/**/*

# Wiki Deployment
# ----------------------
# Keep source in /wiki, ignore deployed clone
uDOS.wiki/

# Backups & Archives
# ----------------------
backups/
*.backup
*.bak

# Output Files
# ----------------------
output/
*.output

# Test Files - Only in Proper Locations
# ----------------------
# Prevent test files from being created in root
/test_*.py
/test_*.uscript
/test_*.sh
/*.test.*
/tmp_*
/temp_*

# Allow tests in proper directories
!memory/tests/
!memory/tests/**/*
!sandbox/tests/

# Data Architecture Separation (v1.0.20b)
# ----------------------
# /knowledge/system/ - TRACKED (core reference data, ships with uDOS)
!knowledge/
!knowledge/**/*

# /memory/ - USER DATA (gitignored, user-writable workspace)
# v1.0.27: Track templates and tests for distribution, ignore user content
memory/
memory/**/*

# Track structure, templates, and tests
!memory/README.md
!memory/.gitignore
!memory/config/
!memory/config/.gitkeep
!memory/sandbox/
!memory/sandbox/.gitkeep
!memory/workflow/
!memory/workflow/README.md
!memory/workflow/.gitkeep
!memory/tests/
!memory/tests/**/*

# User databases and logs (always ignore)
*.db
*.sqlite
*.sqlite3
memory/logs/

# 4-Tier Memory System (user content ignored)
memory/private/
memory/shared/
memory/groups/
memory/public/
memory/personal/
memory/workspace/
memory/legacy/
memory/missions/
memory/scenarios/

# /knowledge/ - TRACKED (core knowledge library, ships with uDOS)
!knowledge/
!knowledge/**/*

# /history/ - TRACKED (system history templates)
!history/
!history/**/*
