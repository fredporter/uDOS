#!/usr/bin/env python3
"""
Wizard Secrets CLI
------------------

Manage the encrypted Wizard tomb without touching OS keychain/keyring.
Commands: add, list, rotate, export-public.

Usage examples:
  bin/wizard-secrets add --key-id github-main --provider github
  bin/wizard-secrets list
  bin/wizard-secrets rotate --key-id github-main
"""

import argparse
import getpass
import json
from datetime import datetime
from typing import Any, Dict

from wizard.services.secret_store import (
    SecretEntry,
    get_secret_store,
    SecretStoreError,
)


def _now() -> str:
    return datetime.utcnow().isoformat() + "Z"


def _prompt_secret(prompt: str = "Secret value: ") -> str:
    value = getpass.getpass(prompt)
    if not value:
        raise SystemExit("Secret value is required")
    return value


def cmd_add(args):
    store = get_secret_store()
    store.unlock(args.key)
    value = args.value or _prompt_secret()
    entry = SecretEntry(
        key_id=args.key_id,
        provider=args.provider,
        value=value,
        version=1,
        created_at=_now(),
        metadata={"notes": args.notes} if args.notes else {},
    )
    store.set(entry)
    print(f"Added secret: {args.key_id} (provider={args.provider})")


def cmd_list(args):
    store = get_secret_store()
    store.unlock(args.key)
    entries = store.list()
    for ent in entries:
        print(
            f"{ent.key_id}\tprovider={ent.provider}\tversion={ent.version}\t"
            f"created={ent.created_at}\trotated={ent.rotated_at or '-'}"
        )


def cmd_rotate(args):
    store = get_secret_store()
    store.unlock(args.key)
    new_value = args.value or _prompt_secret("New secret value: ")
    store.rotate(args.key_id, new_value=new_value, rotated_at=_now())
    print(f"Rotated secret: {args.key_id}")


def cmd_export_public(args):
    store = get_secret_store()
    store.unlock(args.key)
    payload = []
    for ent in store.list():
        payload.append(
            {
                "key_id": ent.key_id,
                "provider": ent.provider,
                "version": ent.version,
                "created_at": ent.created_at,
                "rotated_at": ent.rotated_at,
                "metadata": ent.metadata,
            }
        )
    print(json.dumps({"secrets": payload}, indent=2))


def build_parser() -> argparse.ArgumentParser:
    parser = argparse.ArgumentParser(description="Wizard Secrets tomb manager")
    parser.add_argument(
        "--key",
        dest="key",
        help="Unlock key (defaults to WIZARD_KEY / WIZARD_KEY_PEER env)",
    )
    sub = parser.add_subparsers(dest="command", required=True)

    add_p = sub.add_parser("add", help="Add a new secret")
    add_p.add_argument("--key-id", required=True, help="Secret key identifier")
    add_p.add_argument("--provider", required=True, help="Provider name (github, ai, notion)")
    add_p.add_argument("--notes", help="Optional notes for metadata")
    add_p.add_argument("--value", help="Secret value (omit to prompt securely)")
    add_p.set_defaults(func=cmd_add)

    list_p = sub.add_parser("list", help="List secrets (metadata only)")
    list_p.set_defaults(func=cmd_list)

    rot_p = sub.add_parser("rotate", help="Rotate an existing secret")
    rot_p.add_argument("--key-id", required=True, help="Secret key identifier")
    rot_p.add_argument("--value", help="New secret value (omit to prompt)")
    rot_p.set_defaults(func=cmd_rotate)

    pub_p = sub.add_parser("export-public", help="Export metadata without values")
    pub_p.set_defaults(func=cmd_export_public)

    return parser


def main():
    parser = build_parser()
    args = parser.parse_args()
    try:
        args.func(args)
    except SecretStoreError as exc:
        raise SystemExit(f"Secret store error: {exc}")


if __name__ == "__main__":
    main()
