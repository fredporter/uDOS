FUNCTION IsValidStatus(status AS STRING) AS BOOLEAN
FUNCTION GenerateMissionTemplate(name AS STRING, desc AS STRING, priority AS STRING, deadline AS STRING, id AS STRING) AS STRING
FUNCTION ParseMissionFile(filepath AS STRING) AS Object
FUNCTION FindMissionFile(idOrName AS STRING) AS STRING
