# uDOS Environment Configuration
# Copy this file to .env and fill in your values
# DO NOT commit .env to version control!

# =============================================================================
# GEMINI API CONFIGURATION
# =============================================================================
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# =============================================================================
# USER CONFIGURATION
# =============================================================================
# Your username (used throughout uDOS)
UDOS_USERNAME=user

# Your location (for planet/map features)
UDOS_LOCATION=Unknown

# Your timezone (e.g., UTC, America/New_York, Australia/Sydney)
UDOS_TIMEZONE=UTC

# =============================================================================
# INSTALLATION SETTINGS
# =============================================================================
# Installation path (auto-detected, rarely needs changing)
UDOS_INSTALL_PATH=/Users/fredbook/Code/uDOS

# Installation ID (unique identifier for this installation)
UDOS_INSTALLATION_ID=default

# Version (auto-updated by system)
UDOS_VERSION=1.5.0

# =============================================================================
# DEV MODE CONFIGURATION (v1.5.0+)
# =============================================================================
# Master user password (required for DEV MODE)
# Use a strong password (12+ characters, mixed case, numbers, symbols)
# UDOS_MASTER_PASSWORD=your_secure_password_here

# Master user name (must match UDOS_USERNAME for dev access)
# UDOS_MASTER_USER=user

# =============================================================================
# ADVANCED SETTINGS (Optional)
# =============================================================================
# Debug mode (true/false)
# UDOS_DEBUG=false

# Default theme (default, dungeon, cyberpunk)
# UDOS_THEME=default

# Grid size (width,height in cells)
# UDOS_GRID_SIZE=22,15

# Viewport mode (auto, terminal, mobile, desktop)
# UDOS_VIEWPORT_MODE=auto

# =============================================================================
# API KEYS (Optional Third-Party Services)
# =============================================================================
# GitHub API token (for extension marketplace, optional)
# GITHUB_TOKEN=your_github_token_here

# OpenAI API key (for future multi-LLM support, optional)
# OPENAI_API_KEY=your_openai_key_here

# =============================================================================
# NOTES
# =============================================================================
# - This file is loaded on uDOS startup
# - Changes require restart to take effect (or use CONFIG RELOAD in DEV MODE)
# - Keep this file secure - it contains API keys!
# - Never commit .env to version control (it's in .gitignore)
