# uDOS Environment Configuration
# Edit values using CLI: udos config set <key> <value>

# User Information
USERNAME=user
PASSWORD=
ROLE=admin

# Planet Configuration
PLANET=Earth

# Theme Configuration
ACTIVE_THEME=dungeon

# Gemini AI API Key
GEMINI_API_KEY=

# System Timezone (auto-detected at installation)
TIMEZONE=UTC
TIMEZONE_OS=+00:00

# Unique Installation ID (auto-generated)
INSTALLATION_ID=default

# System Configuration
OFFLINE_MODE_ALLOWED=true
AUTO_UPDATE_CHECK=true
TELEMETRY_ENABLED=false

# Editor Preferences
CLI_EDITOR=micro
WEB_EDITOR=typo
