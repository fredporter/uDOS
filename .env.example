# uDOS Environment Configuration
# Edit using: CONFIG SET <key> <value>

# AI API Keys
GEMINI_API_KEY=''
OPENROUTER_API_KEY=''
ANTHROPIC_API_KEY=''
OPENAI_API_KEY=''
GITHUB_TOKEN=''

# Installation Identity (not user identity - see memory/system/user/user.json for username)
UDOS_INSTALLATION_ID='default'

# Theme Configuration
THEME='dungeon'

# Server Configuration
AUTO_START_WEB='false'
AUTO_START_SERVER='false'
HTTP_SERVER_PORT='8080'

# Session Settings
MAX_SESSION_HISTORY='100'
AUTO_SAVE_SESSION='true'

# Editor Preferences
CLI_EDITOR='micro'
WEB_EDITOR='typo'

# Gmail Cloud Sync (v1.2.9+)
# GMAIL_TOKEN_ENCRYPTION_KEY=  # Auto-generated on first login
