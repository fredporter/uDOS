  "validation_rules": {
    "city_name": {
      "required": true,
      "type": "string",
      "min_length": 2,
      "max_length": 100,
      "pattern": "^[\\p{L}\\p{M}\\p{N}\\p{Pc}\\p{Pd}\\s]+$"
    },
    "coordinates": {
      "latitude": {
        "required": true,
        "type": "number",
        "min": -90,
        "max": 90,
        "precision": 6
      },
      "longitude": {
        "required": true,
        "type": "number",
        "min": -180,
        "max": 180,
        "precision": 6
      }
    },
    "timezone": {
      "required": true,
      "type": "string",
      "format": "iana_timezone",
      "examples": ["America/New_York", "Europe/London", "Asia/Tokyo"]
    },
    "population": {
      "type": "integer",
      "min": 0,
      "max": 50000000
    }
  },
