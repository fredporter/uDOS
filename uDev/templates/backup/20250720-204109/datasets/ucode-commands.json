[
  {
    "command": "HELP",
    "category": "system",
    "syntax": "HELP [command]",
    "description": "Display help information for all commands or specific command",
    "examples": ["HELP", "HELP PRINT", "HELP SET"],
    "version": "1.0.0"
  },
  {
    "command": "PRINT",
    "category": "output",
    "syntax": "PRINT <string|variable>",
    "description": "Output text or variable value to console",
    "examples": ["PRINT \"Hello World\"", "PRINT $username", "PRINT \"Current time: \" + $time"],
    "version": "1.0.0"
  },
  {
    "command": "SET",
    "category": "variables",
    "syntax": "SET <variable> = <value>",
    "description": "Assign a value to a variable",
    "examples": ["SET $name = \"John\"", "SET $count = 42", "SET $active = true"],
    "version": "1.0.0"
  },
  {
    "command": "GET",
    "category": "variables",
    "syntax": "GET <variable>",
    "description": "Retrieve and display the value of a variable",
    "examples": ["GET $name", "GET $count", "GET $user.email"],
    "version": "1.0.0"
  },
  {
    "command": "IF",
    "category": "control",
    "syntax": "IF <condition> THEN <command> [ELSE <command>]",
    "description": "Conditional execution of commands",
    "examples": ["IF $count > 10 THEN PRINT \"Large\"", "IF $name = \"admin\" THEN LOGIN ELSE DENY"],
    "version": "1.0.0"
  },
  {
    "command": "FOR",
    "category": "control",
    "syntax": "FOR <variable> = <start> TO <end> [STEP <increment>]",
    "description": "Loop execution with counter variable",
    "examples": ["FOR $i = 1 TO 10", "FOR $x = 0 TO 100 STEP 5"],
    "version": "1.0.0"
  },
  {
    "command": "WHILE",
    "category": "control",
    "syntax": "WHILE <condition>",
    "description": "Loop execution while condition is true",
    "examples": ["WHILE $count < 100", "WHILE $status = \"running\""],
    "version": "1.0.0"
  },
  {
    "command": "HOOK",
    "category": "file",
    "syntax": "HOOK <filename>",
    "description": "Import and execute another script file",
    "examples": ["HOOK \"utils.uc\"", "HOOK $script_path", "HOOK \"../common/setup.uc\""],
    "version": "1.0.0"
  },
  {
    "command": "LOAD",
    "category": "file",
    "syntax": "LOAD <filename> INTO <variable>",
    "description": "Load file content into a variable",
    "examples": ["LOAD \"data.txt\" INTO $content", "LOAD $file_path INTO $data"],
    "version": "1.0.0"
  },
  {
    "command": "SAVE",
    "category": "file",
    "syntax": "SAVE <variable> TO <filename>",
    "description": "Save variable content to a file",
    "examples": ["SAVE $content TO \"output.txt\"", "SAVE $report TO $filename"],
    "version": "1.0.0"
  },
  {
    "command": "WAIT",
    "category": "timing",
    "syntax": "WAIT <seconds>",
    "description": "Pause execution for specified time",
    "examples": ["WAIT 5", "WAIT $delay", "WAIT 0.5"],
    "version": "1.0.0"
  },
  {
    "command": "TIME",
    "category": "timing",
    "syntax": "TIME [format]",
    "description": "Get current time in specified format",
    "examples": ["TIME", "TIME \"YYYY-MM-DD\"", "TIME \"HH:mm:ss\""],
    "version": "1.0.0"
  },
  {
    "command": "DATE",
    "category": "timing",
    "syntax": "DATE [format]",
    "description": "Get current date in specified format",
    "examples": ["DATE", "DATE \"MM/DD/YYYY\"", "DATE \"DD-MM-YY\""],
    "version": "1.0.0"
  },
  {
    "command": "EXEC",
    "category": "system",
    "syntax": "EXEC <command>",
    "description": "Execute system command and return result",
    "examples": ["EXEC \"ls -la\"", "EXEC \"git status\"", "EXEC $system_cmd"],
    "version": "1.0.0"
  },
  {
    "command": "GOTO",
    "category": "file",
    "syntax": "GOTO <directory>",
    "description": "Change current working directory",
    "examples": ["GOTO \"/home/user\"", "GOTO $workspace", "GOTO \"../parent\""],
    "version": "1.0.0"
  },
  {
    "command": "SHOW",
    "category": "file",
    "syntax": "SHOW",
    "description": "Print current working directory",
    "examples": ["SHOW"],
    "version": "1.0.0"
  },
  {
    "command": "LIST",
    "category": "file",
    "syntax": "LIST [directory] [options]",
    "description": "List directory contents",
    "examples": ["LIST", "LIST \"/home\"", "LIST -la", "LIST $path -R"],
    "version": "1.0.0"
  },
  {
    "command": "MAKE",
    "category": "file",
    "syntax": "MAKE <directory>",
    "description": "Create a new directory",
    "examples": ["MAKE \"new_folder\"", "MAKE $project_dir", "MAKE -p \"path/to/deep/folder\""],
    "version": "1.0.0"
  },
  {
    "command": "KILL",
    "category": "file",
    "syntax": "KILL <file|directory> [options]",
    "description": "Remove files or directories",
    "examples": ["KILL \"file.txt\"", "KILL -rf \"folder\"", "KILL $temp_file"],
    "version": "1.0.0"
  },
  {
    "command": "COPY",
    "category": "file",
    "syntax": "COPY <source> <destination>",
    "description": "Copy files or directories",
    "examples": ["COPY \"file.txt\" \"backup.txt\"", "COPY -r \"folder\" \"backup_folder\""],
    "version": "1.0.0"
  },
  {
    "command": "MOVE",
    "category": "file",
    "syntax": "MOVE <source> <destination>",
    "description": "Move or rename files/directories",
    "examples": ["MOVE \"old.txt\" \"new.txt\"", "MOVE \"folder\" \"../new_location\""],
    "version": "1.0.0"
  },
  {
    "command": "FIND",
    "category": "search",
    "syntax": "FIND <pattern> [IN <location>] [TYPE <file|dir>]",
    "description": "Search for files and directories",
    "examples": ["FIND \"*.txt\"", "FIND \"config\" IN \"/etc\"", "FIND \"backup\" TYPE dir"],
    "version": "1.0.0"
  },
  {
    "command": "PEEK",
    "category": "search",
    "syntax": "PEEK <pattern> [IN <file>] [options]",
    "description": "Search for text patterns in files",
    "examples": ["PEEK \"error\" IN \"log.txt\"", "PEEK -i \"warning\" IN $logfile"],
    "version": "1.0.0"
  },
  {
    "command": "REPLACE",
    "category": "text",
    "syntax": "REPLACE <old_text> WITH <new_text> IN <variable|file>",
    "description": "Replace text in variables or files",
    "examples": ["REPLACE \"old\" WITH \"new\" IN $content", "REPLACE \"error\" WITH \"warning\" IN \"log.txt\""],
    "version": "1.0.0"
  },
  {
    "command": "SPLIT",
    "category": "text",
    "syntax": "SPLIT <string> BY <delimiter> INTO <array_variable>",
    "description": "Split string into array by delimiter",
    "examples": ["SPLIT $csv_line BY \",\" INTO $fields", "SPLIT \"a,b,c\" BY \",\" INTO $parts"],
    "version": "1.0.0"
  },
  {
    "command": "JOIN",
    "category": "text",
    "syntax": "JOIN <array_variable> WITH <delimiter> INTO <string_variable>",
    "description": "Join array elements into string with delimiter",
    "examples": ["JOIN $words WITH \" \" INTO $sentence", "JOIN $items WITH \",\" INTO $csv"],
    "version": "1.0.0"
  },
  {
    "command": "LENGTH",
    "category": "text",
    "syntax": "LENGTH <string|array> INTO <variable>",
    "description": "Get length of string or array",
    "examples": ["LENGTH $text INTO $count", "LENGTH $array INTO $size"],
    "version": "1.0.0"
  },
  {
    "command": "HTTP",
    "category": "network",
    "syntax": "HTTP <method> <url> [HEADERS <headers>] [BODY <body>] INTO <variable>",
    "description": "Make HTTP requests",
    "examples": ["HTTP GET \"https://api.example.com\" INTO $response", "HTTP POST \"https://api.com\" BODY $data INTO $result"],
    "version": "1.0.0"
  },
  {
    "command": "JSON",
    "category": "data",
    "syntax": "JSON <operation> <data> [PATH <json_path>] INTO <variable>",
    "description": "Parse and manipulate JSON data",
    "examples": ["JSON PARSE $response INTO $object", "JSON GET $data PATH \"user.name\" INTO $name"],
    "version": "1.0.0"
  },
  {
    "command": "CSV",
    "category": "data",
    "syntax": "CSV <operation> <data> [DELIMITER <char>] INTO <variable>",
    "description": "Parse and manipulate CSV data",
    "examples": ["CSV PARSE $content INTO $table", "CSV GET $table ROW 1 INTO $row"],
    "version": "1.0.0"
  },
  {
    "command": "LOG",
    "category": "debug",
    "syntax": "LOG <level> <message>",
    "description": "Write log messages with specified level",
    "examples": ["LOG INFO \"Process started\"", "LOG ERROR $error_msg", "LOG DEBUG \"Variable: \" + $var"],
    "version": "1.0.0"
  },
  {
    "command": "DEBUG",
    "category": "debug",
    "syntax": "DEBUG <ON|OFF>",
    "description": "Enable or disable debug mode",
    "examples": ["DEBUG ON", "DEBUG OFF"],
    "version": "1.0.0"
  },
  {
    "command": "TRY",
    "category": "error",
    "syntax": "TRY <command> CATCH <error_variable> <error_handler>",
    "description": "Execute command with error handling",
    "examples": ["TRY EXEC $cmd CATCH $error LOG ERROR $error"],
    "version": "1.0.0"
  },
  {
    "command": "THROW",
    "category": "error",
    "syntax": "THROW <error_message>",
    "description": "Throw custom error",
    "examples": ["THROW \"Invalid input\"", "THROW \"File not found: \" + $filename"],
    "version": "1.0.0"
  },
  {
    "command": "FUNCTION",
    "category": "functions",
    "syntax": "FUNCTION <name>(<parameters>) ... END",
    "description": "Define reusable function",
    "examples": ["FUNCTION greet($name) PRINT \"Hello \" + $name END"],
    "version": "1.1.0"
  },
  {
    "command": "CALL",
    "category": "functions",
    "syntax": "CALL <function_name>(<arguments>) [INTO <variable>]",
    "description": "Call defined function",
    "examples": ["CALL greet(\"John\")", "CALL calculate($x, $y) INTO $result"],
    "version": "1.1.0"
  },
  {
    "command": "RETURN",
    "category": "functions",
    "syntax": "RETURN [value]",
    "description": "Return value from function",
    "examples": ["RETURN $result", "RETURN \"success\"", "RETURN"],
    "version": "1.1.0"
  },
  {
    "command": "IMPORT",
    "category": "modules",
    "syntax": "IMPORT <module> [AS <alias>]",
    "description": "Import module or library",
    "examples": ["IMPORT \"math\"", "IMPORT \"utils\" AS util", "IMPORT $module_path"],
    "version": "1.1.0"
  },
  {
    "command": "EXPORT",
    "category": "modules",
    "syntax": "EXPORT <function|variable>",
    "description": "Export function or variable for other modules",
    "examples": ["EXPORT greet", "EXPORT $config", "EXPORT calculate"],
    "version": "1.1.0"
  },
  {
    "command": "ENV",
    "category": "system",
    "syntax": "ENV <operation> [variable] [value]",
    "description": "Manage environment variables",
    "examples": ["ENV GET PATH", "ENV SET NODE_ENV production", "ENV LIST"],
    "version": "1.1.0"
  },
  {
    "command": "CONFIG",
    "category": "system",
    "syntax": "CONFIG <operation> [key] [value]",
    "description": "Manage configuration settings",
    "examples": ["CONFIG GET debug", "CONFIG SET timeout 30", "CONFIG LOAD \"config.json\""],
    "version": "1.1.0"
  },
  {
    "command": "VALIDATE",
    "category": "data",
    "syntax": "VALIDATE <data> AGAINST <schema|pattern>",
    "description": "Validate data against schema or pattern",
    "examples": ["VALIDATE $email AGAINST EMAIL", "VALIDATE $data AGAINST $schema"],
    "version": "1.1.0"
  },
  {
    "command": "TRANSFORM",
    "category": "data",
    "syntax": "TRANSFORM <data> USING <transformer> INTO <variable>",
    "description": "Transform data using specified transformer",
    "examples": ["TRANSFORM $xml USING xml2json INTO $json", "TRANSFORM $data USING uppercase INTO $upper"],
    "version": "1.1.0"
  },
  {
    "command": "SCHEDULE",
    "category": "timing",
    "syntax": "SCHEDULE <command> AT <time|interval>",
    "description": "Schedule command execution",
    "examples": ["SCHEDULE backup() AT \"2:00 AM\"", "SCHEDULE cleanup() EVERY \"1 hour\""],
    "version": "1.1.0"
  },
  {
    "command": "CANCEL",
    "category": "timing",
    "syntax": "CANCEL <scheduled_id>",
    "description": "Cancel scheduled command",
    "examples": ["CANCEL $backup_job", "CANCEL \"daily_cleanup\""],
    "version": "1.1.0"
  },
  {
    "command": "PARALLEL",
    "category": "control",
    "syntax": "PARALLEL <command1> AND <command2> [AND ...]",
    "description": "Execute multiple commands in parallel",
    "examples": ["PARALLEL download($file1) AND download($file2)", "PARALLEL backup() AND cleanup() AND notify()"],
    "version": "1.1.0"
  },
  {
    "command": "SEQUENCE",
    "category": "control",
    "syntax": "SEQUENCE <command1> THEN <command2> [THEN ...]",
    "description": "Execute commands in sequence",
    "examples": ["SEQUENCE validate($data) THEN process($data) THEN save($result)"],
    "version": "1.1.0"
  },
  {
    "command": "PIPELINE",
    "category": "control",
    "syntax": "PIPELINE <input> | <command1> | <command2> | ... INTO <output>",
    "description": "Chain commands in pipeline",
    "examples": ["PIPELINE $data | filter(\"active\") | sort(\"name\") | format(\"csv\") INTO $result"],
    "version": "1.1.0"
  },
  {
    "command": "QUIT",
    "category": "system",
    "syntax": "QUIT [exit_code]",
    "description": "Exit the uCode interpreter",
    "examples": ["QUIT", "QUIT 0", "QUIT $exit_status"],
    "version": "1.0.0"
  },
  {
    "command": "EXIT",
    "category": "system",
    "syntax": "EXIT [exit_code]",
    "description": "Alias for QUIT command",
    "examples": ["EXIT", "EXIT 1", "EXIT $code"],
    "version": "1.0.0"
  }
]
