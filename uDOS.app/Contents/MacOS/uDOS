#!/bin/bash
# uDOS macOS App Launcher v1.3.1
# Native macOS application launcher with enhanced startup choices

set -euo pipefail

# Terminal configuration
export TERM="${TERM:-xterm-256color}"
export UDOS_ROOT="/Users/agentdigital/uDOS"
export UDOS_TERMINAL_PROFILE="uDOS"

# Color definitions for output
readonly RED='\033[0;31m'
readonly GREEN='\033[0;32m'
readonly YELLOW='\033[1;33m'
readonly BLUE='\033[0;34m'
readonly PURPLE='\033[0;35m'
readonly CYAN='\033[0;36m'
readonly WHITE='\033[1;37m'
readonly NC='\033[0m' # No Color

# uDOS branding
show_udos_banner() {
    echo -e "${CYAN}"
    echo "   ██╗   ██╗██████╗  ██████╗ ███████╗"
    echo "   ██║   ██║██╔══██╗██╔═══██╗██╔════╝"
    echo "   ██║   ██║██║  ██║██║   ██║███████╗"
    echo "   ██║   ██║██║  ██║██║   ██║╚════██║"
    echo "   ╚██████╔╝██████╔╝╚██████╔╝███████║"
    echo "    ╚═════╝ ╚═════╝  ╚═════╝ ╚══════╝"
    echo -e "${NC}"
    echo -e "${WHITE}Universal Development Operating System${NC}"
    echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
}

# Check system prerequisites
check_prerequisites() {
    echo -e "${BLUE}🔍 Checking system prerequisites...${NC}"
    
    # Check if uDOS exists
    if [[ ! -d "$UDOS_ROOT" ]]; then
        echo -e "${RED}❌ uDOS not found at $UDOS_ROOT${NC}"
        offer_git_install
        return 1
    fi
    
    # Check for git
    if ! command -v git >/dev/null 2>&1; then
        echo -e "${YELLOW}⚠️  Git not found. Some features may be limited.${NC}"
    fi
    
    # Check for VS Code
    if command -v code >/dev/null 2>&1; then
        export VSCODE_AVAILABLE=true
        echo -e "${GREEN}✅ VS Code detected${NC}"
    else
        export VSCODE_AVAILABLE=false
        echo -e "${YELLOW}ℹ️  VS Code not detected (wizard dev mode unavailable)${NC}"
    fi
    
    echo -e "${GREEN}✅ Prerequisites checked${NC}"
    echo ""
}

# Offer Git installation of uDOS
offer_git_install() {
    echo ""
    echo -e "${YELLOW}🚀 uDOS Installation Required${NC}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "uDOS needs to be installed from Git."
    echo ""
    echo -e "${WHITE}Installation Options:${NC}"
    echo -e "  ${GREEN}[1]${NC} 📥 Install uDOS automatically"
    echo -e "  ${GREEN}[2]${NC} 📋 Show manual install instructions"
    echo -e "  ${GREEN}[3]${NC} ❌ Cancel"
    echo ""
    read -p "👉 Choose installation method (1-3): " install_choice
    
    case "$install_choice" in
        1)
            install_udos_from_git
            ;;
        2)
            show_manual_install_instructions
            ;;
        3)
            echo -e "${YELLOW}Installation cancelled${NC}"
            exit 0
            ;;
        *)
            echo -e "${RED}Invalid choice${NC}"
            exit 1
            ;;
    esac
}

# Automatic Git installation
install_udos_from_git() {
    echo -e "${BLUE}📥 Installing uDOS from Git...${NC}"
    
    # Check for git
    if ! command -v git >/dev/null 2>&1; then
        echo -e "${RED}❌ Git not found. Installing Xcode Command Line Tools...${NC}"
        xcode-select --install
        echo "⏳ Please complete the Xcode installation and run uDOS again."
        exit 1
    fi
    
    # Clone repository
    echo "🔄 Cloning uDOS repository..."
    git clone "https://github.com/fredporter/uDOS.git" "$UDOS_ROOT"
    
    if [[ -d "$UDOS_ROOT" ]]; then
        echo -e "${GREEN}✅ uDOS installed successfully!${NC}"
        echo ""
        main # Restart the launcher
    else
        echo -e "${RED}❌ Installation failed${NC}"
        exit 1
    fi
}

# Show manual installation instructions
show_manual_install_instructions() {
    echo ""
    echo -e "${BLUE}📋 Manual Installation Instructions${NC}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo "1. Open Terminal"
    echo "2. Run the following command:"
    echo ""
    echo -e "${CYAN}   git clone https://github.com/fredporter/uDOS.git ~/uDOS${NC}"
    echo ""
    echo "3. Launch uDOS again after installation"
    echo ""
    read -p "Press Enter to exit..."
    exit 0
}

# Detect available roles based on installation
detect_available_roles() {
    local roles=()
    
    # Check each role directory
    for role in ghost tomb drone imp sorcerer wizard; do
        if [[ -d "$UDOS_ROOT/$role" ]]; then
            roles+=("$role")
        fi
    done
    
    echo "${roles[@]}"
}

# Show startup menu with role choices
show_startup_menu() {
    local available_roles
    available_roles=($(detect_available_roles))
    
    echo -e "${WHITE}🚀 uDOS Startup Menu${NC}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo -e "${WHITE}Available Launch Modes:${NC}"
    echo ""
    
    local choice_num=1
    
    # VS Code Dev Mode (Wizard only)
    if [[ "$VSCODE_AVAILABLE" == "true" ]] && [[ " ${available_roles[*]} " =~ " wizard " ]]; then
        echo -e "  ${GREEN}[$choice_num]${NC} 🧙‍♂️ ${PURPLE}VS Code DEV Mode${NC} (Wizard - Full Development)"
        echo "      └─ Complete development environment with Git integration"
        ((choice_num++))
        echo ""
    fi
    
    # Role-based modes
    for role in "${available_roles[@]}"; do
        case "$role" in
            "ghost")
                echo -e "  ${GREEN}[$choice_num]${NC} 👻 ${CYAN}Ghost Mode${NC} (Level 10 - Demo & Evaluation)"
                echo "      └─ Limited demonstration and evaluation environment"
                ;;
            "tomb")
                echo -e "  ${GREEN}[$choice_num]${NC} ⚰️  ${YELLOW}Tomb Mode${NC} (Level 20 - Archive Management)"
                echo "      └─ Archive browsing and backup management tools"
                ;;
            "drone")
                echo -e "  ${GREEN}[$choice_num]${NC} 🤖 ${BLUE}Drone Mode${NC} (Level 40 - Automation)"
                echo "      └─ Task automation and system monitoring"
                ;;
            "imp")
                echo -e "  ${GREEN}[$choice_num]${NC} 👹 ${RED}Imp Mode${NC} (Level 60 - Development)"
                echo "      └─ Script development and creative tools"
                ;;
            "sorcerer")
                echo -e "  ${GREEN}[$choice_num]${NC} 🔮 ${PURPLE}Sorcerer Mode${NC} (Level 80 - Advanced User)"
                echo "      └─ Advanced project management and administration"
                ;;
            "wizard")
                echo -e "  ${GREEN}[$choice_num]${NC} 🧙‍♂️ ${WHITE}Wizard Mode${NC} (Level 100 - CLI Full Access)"
                echo "      └─ Complete system access and administration"
                ;;
        esac
        ((choice_num++))
        echo ""
    done
    
    # System options
    echo -e "  ${GREEN}[$choice_num]${NC} 🔧 ${CYAN}System Update${NC} (Check for updates)"
    ((choice_num++))
    echo -e "  ${GREEN}[$choice_num]${NC} 🛠️  ${YELLOW}System Repair${NC} (Repair installation)"
    ((choice_num++))
    echo -e "  ${GREEN}[$choice_num]${NC} ❌ ${WHITE}Cancel${NC}"
    echo ""
    
    read -p "👉 Choose your launch mode (1-$((choice_num-1))): " user_choice
    
    process_startup_choice "$user_choice" "${available_roles[@]}"
}

# Process user's startup choice
process_startup_choice() {
    local choice="$1"
    shift
    local available_roles=("$@")
    
    local choice_num=1
    
    # VS Code Dev Mode (if available)
    if [[ "$VSCODE_AVAILABLE" == "true" ]] && [[ " ${available_roles[*]} " =~ " wizard " ]]; then
        if [[ "$choice" == "$choice_num" ]]; then
            launch_vscode_dev_mode
            return
        fi
        ((choice_num++))
    fi
    
    # Role-based modes
    for role in "${available_roles[@]}"; do
        if [[ "$choice" == "$choice_num" ]]; then
            launch_role_mode "$role"
            return
        fi
        ((choice_num++))
    done
    
    # System options
    if [[ "$choice" == "$choice_num" ]]; then
        system_update
        return
    fi
    ((choice_num++))
    
    if [[ "$choice" == "$choice_num" ]]; then
        system_repair
        return
    fi
    ((choice_num++))
    
    if [[ "$choice" == "$choice_num" ]]; then
        echo -e "${YELLOW}👋 Cancelled${NC}"
        exit 0
    fi
    
    echo -e "${RED}❌ Invalid choice${NC}"
    exit 1
}

# Launch VS Code development mode
launch_vscode_dev_mode() {
    echo -e "${PURPLE}🧙‍♂️ Launching VS Code Development Mode...${NC}"
    echo ""
    
    cd "$UDOS_ROOT"
    
    # Apply uDOS terminal profile
    apply_terminal_profile
    
    # Open VS Code
    echo -e "${BLUE}🚀 Opening VS Code with uDOS workspace...${NC}"
    code .
    
    echo ""
    echo -e "${GREEN}✅ VS Code opened successfully!${NC}"
    echo -e "${CYAN}💡 In VS Code: Cmd+Shift+P → 'uDOS: Start Development'${NC}"
    echo ""
    
    # Keep terminal open for server operations
    echo -e "${WHITE}🖥️  CLI reserved for uSERVER operations${NC}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    start_server_operations
}

# Launch specific role mode
launch_role_mode() {
    local role="$1"
    
    echo -e "${BLUE}🚀 Launching $role mode...${NC}"
    echo ""
    
    cd "$UDOS_ROOT"
    
    # Apply uDOS terminal profile
    apply_terminal_profile
    
    # Set role environment
    export UDOS_CURRENT_ROLE="$role"
    
    # Start uSERVER first
    echo -e "${BLUE}🔧 Starting uSERVER...${NC}"
    if [[ -f "$UDOS_ROOT/uSERVER/start-server.sh" ]]; then
        chmod +x "$UDOS_ROOT/uSERVER/start-server.sh"
        "$UDOS_ROOT/uSERVER/start-server.sh" --daemon --role="$role" &
        sleep 3
        echo -e "${GREEN}✅ uSERVER started${NC}"
    else
        echo -e "${YELLOW}⚠️  uSERVER not available${NC}"
    fi
    
    # Open UI omniview
    echo -e "${BLUE}🌐 Opening UI omniview...${NC}"
    local ui_url="http://localhost:8080?role=${role}"
    open "$ui_url" 2>/dev/null || echo "Please open $ui_url in your browser"
    
    # Continue with role-specific startup
    if [[ -f "$UDOS_ROOT/uCORE/launcher/universal/start-udos.sh" ]]; then
        exec "$UDOS_ROOT/uCORE/launcher/universal/start-udos.sh" "$role"
    elif [[ -f "$UDOS_ROOT/$role/start.sh" ]]; then
        exec "$UDOS_ROOT/$role/start.sh"
    else
        # Fallback to integrated CLI
        start_integrated_cli "$role"
    fi
}

# Apply uDOS terminal profile
apply_terminal_profile() {
    if [[ -f "$UDOS_ROOT/uDOS.terminal" ]]; then
        echo -e "${CYAN}🎨 Applying uDOS terminal profile...${NC}"
        # The terminal profile will be applied automatically when opening new terminals
    fi
}

# Start server operations CLI
start_server_operations() {
    echo ""
    echo -e "${WHITE}uSERVER CLI Operations${NC}"
    echo "Available commands:"
    echo "  status    - Server status"
    echo "  logs      - Show server logs" 
    echo "  restart   - Restart server"
    echo "  update    - Check for updates"
    echo "  repair    - Repair installation"
    echo "  ui        - Open UI omniview"
    echo "  quit      - Exit"
    echo ""
    
    # Start uSERVER if available
    if [[ -f "$UDOS_ROOT/uSERVER/start-server.sh" ]]; then
        echo -e "${BLUE}🔧 Starting uSERVER...${NC}"
        "$UDOS_ROOT/uSERVER/start-server.sh" --daemon
    fi
    
    # CLI command loop
    while true; do
        read -p "uSERVER> " -r command
        
        case "$command" in
            "status")
                show_server_status
                ;;
            "logs")
                if [[ -f "$UDOS_ROOT/uSERVER/logs/server.log" ]]; then
                    tail -f "$UDOS_ROOT/uSERVER/logs/server.log"
                else
                    echo "No server logs found"
                fi
                ;;
            "restart")
                restart_server
                ;;
            "update")
                system_update
                ;;
            "repair")
                system_repair
                ;;
            "ui")
                open_ui_omniview
                ;;
            "quit"|"exit")
                echo -e "${YELLOW}👋 Exiting uDOS${NC}"
                break
                ;;
            "")
                # Empty command, continue
                ;;
            *)
                echo -e "${RED}Unknown command: $command${NC}"
                echo "Type 'quit' to exit"
                ;;
        esac
    done
}

# Show server status
show_server_status() {
    echo -e "${BLUE}📊 uSERVER Status${NC}"
    if pgrep -f "uSERVER" >/dev/null; then
        echo -e "${GREEN}✅ uSERVER is running${NC}"
    else
        echo -e "${RED}❌ uSERVER is not running${NC}"
    fi
}

# Restart server
restart_server() {
    echo -e "${YELLOW}🔄 Restarting uSERVER...${NC}"
    pkill -f "uSERVER" 2>/dev/null || true
    sleep 2
    if [[ -f "$UDOS_ROOT/uSERVER/start-server.sh" ]]; then
        "$UDOS_ROOT/uSERVER/start-server.sh" --daemon
        echo -e "${GREEN}✅ uSERVER restarted${NC}"
    else
        echo -e "${RED}❌ uSERVER start script not found${NC}"
    fi
}

# Open UI omniview
open_ui_omniview() {
    local ui_url="http://localhost:8080"
    echo -e "${BLUE}🌐 Opening UI omniview...${NC}"
    open "$ui_url" 2>/dev/null || echo "Please open $ui_url in your browser"
}

# System update
system_update() {
    echo -e "${BLUE}🔄 Checking for uDOS updates...${NC}"
    
    cd "$UDOS_ROOT"
    
    if [[ -d ".git" ]]; then
        git fetch origin --quiet
        
        local local_hash=$(git rev-parse HEAD)
        local remote_hash=$(git rev-parse origin/main)
        
        if [[ "$local_hash" != "$remote_hash" ]]; then
            echo -e "${YELLOW}📦 Updates available!${NC}"
            echo ""
            echo "Recent changes:"
            git log --oneline HEAD..origin/main | head -5
            echo ""
            read -p "Apply updates? [y/N]: " -n 1 -r
            echo
            
            if [[ $REPLY =~ ^[Yy]$ ]]; then
                echo -e "${BLUE}📥 Applying updates...${NC}"
                git reset --hard origin/main
                echo -e "${GREEN}✅ Update complete!${NC}"
            fi
        else
            echo -e "${GREEN}✅ uDOS is up to date${NC}"
        fi
    else
        echo -e "${YELLOW}⚠️  Not a Git repository. Cannot check for updates.${NC}"
    fi
    
    echo ""
    read -p "Press Enter to continue..."
}

# System repair
system_repair() {
    echo -e "${YELLOW}🔧 Repairing uDOS installation...${NC}"
    
    cd "$UDOS_ROOT"
    
    if [[ -d ".git" ]]; then
        echo "🔄 Resetting to clean state..."
        git reset --hard HEAD
        git clean -fd
        echo -e "${GREEN}✅ Repository cleaned${NC}"
    fi
    
    # Fix permissions
    echo "🔐 Fixing permissions..."
    find "$UDOS_ROOT" -name "*.sh" -exec chmod +x {} \; 2>/dev/null || true
    
    echo -e "${GREEN}✅ Repair complete!${NC}"
    echo ""
    read -p "Press Enter to continue..."
}

# Start integrated CLI for role operations
start_integrated_cli() {
    local role="$1"
    
    echo ""
    echo -e "${WHITE}🖥️  $role CLI Operations (uSERVER Integration)${NC}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo ""
    echo -e "${WHITE}Available commands:${NC}"
    echo "  status      - Show system status"
    echo "  logs        - View system logs"
    echo "  ui          - Open UI omniview"
    echo "  restart     - Restart uSERVER"
    echo "  update      - Check for updates"
    echo "  repair      - Repair installation"
    echo "  quit        - Exit"
    echo ""
    
    # CLI command loop with uSERVER integration
    while true; do
        read -p "$role> " -r command args
        
        case "$command" in
            "status")
                show_integrated_status
                ;;
            "logs")
                show_server_logs
                ;;
            "ui")
                open_ui_omniview
                ;;
            "restart")
                restart_server
                ;;
            "update")
                system_update
                ;;
            "repair")
                system_repair
                ;;
            "quit"|"exit")
                echo -e "${YELLOW}👋 Exiting $role mode${NC}"
                # Stop uSERVER on exit
                if [[ -f "$UDOS_ROOT/uSERVER/.server.pid" ]]; then
                    local pid=$(cat "$UDOS_ROOT/uSERVER/.server.pid")
                    kill "$pid" 2>/dev/null || true
                    rm -f "$UDOS_ROOT/uSERVER/.server.pid"
                fi
                break
                ;;
            "")
                # Empty command, continue
                ;;
            *)
                echo -e "${RED}Unknown command: $command${NC}"
                echo "Type 'quit' to exit"
                ;;
        esac
    done
}

# Show integrated system status
show_integrated_status() {
    echo -e "${BLUE}📊 System Status${NC}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    
    # Check uSERVER status
    if [[ -f "$UDOS_ROOT/uSERVER/.server.pid" ]]; then
        local pid=$(cat "$UDOS_ROOT/uSERVER/.server.pid")
        if kill -0 "$pid" 2>/dev/null; then
            echo -e "${WHITE}uSERVER:${NC} ${GREEN}✅ Running${NC} (PID: $pid)"
            echo -e "${WHITE}UI Access:${NC} ${CYAN}http://localhost:8080${NC}"
        else
            echo -e "${WHITE}uSERVER:${NC} ${RED}❌ Not running${NC}"
            rm -f "$UDOS_ROOT/uSERVER/.server.pid"
        fi
    else
        echo -e "${WHITE}uSERVER:${NC} ${RED}❌ Not running${NC}"
    fi
    
    # Check system components
    echo -e "${WHITE}Role:${NC} $UDOS_CURRENT_ROLE"
    echo -e "${WHITE}Root:${NC} $UDOS_ROOT"
    echo -e "${WHITE}Session:${NC} $(date)"
    echo ""
}

# Show server logs
show_server_logs() {
    local log_file="$UDOS_ROOT/uSERVER/logs/server.log"
    if [[ -f "$log_file" ]]; then
        echo -e "${BLUE}📋 Recent server logs:${NC}"
        tail -20 "$log_file"
    else
        echo -e "${YELLOW}ℹ️  No server logs found${NC}"
    fi
}

# Main launcher function
main() {
    # Set working directory
    cd "$UDOS_ROOT" 2>/dev/null || true
    
    show_udos_banner
    check_prerequisites
    show_startup_menu
}

# Launch the application
main
