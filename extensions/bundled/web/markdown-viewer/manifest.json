{
  "name": "markdown-viewer",
  "version": "1.0.21",
  "description": "Browse and render uDOS knowledge library with fuzzy search",
  "type": "web",
  "port": 9000,
  "author": "uDOS",
  "dependencies": {
    "flask": ">=2.0.0",
    "markdown2": ">=2.4.0",
    "pygments": ">=2.10.0",
    "thefuzz": ">=0.19.0"
  },
  "features": [
    "markdown-rendering",
    "fuzzy-search",
    "emoji-support",
    "syntax-highlighting",
    "knowledge-browser",
    "diagram-viewer"
  ],
  "routes": {
    "/": "Main viewer interface",
    "/api/browse": "List all files",
    "/api/search": "Fuzzy search",
    "/api/render": "Render markdown",
    "/api/categories": "Category tree",
    "/api/diagrams": "List diagrams"
  }
}
