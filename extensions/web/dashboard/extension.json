{
  "id": "dashboard",
  "name": "uDOS Dashboard",
  "version": "1.0.0",
  "description": "Real-time NES.css retro dashboard for missions, checklists, and workflows",
  "author": "uDOS Team",
  "license": "MIT",
  "type": "web",
  "category": "ui",
  "requires": {
    "udos_version": ">=1.1.14",
    "python_packages": [
      "flask>=2.0.0",
      "flask-cors>=3.0.0"
    ]
  },
  "entry_point": "server.py",
  "default_port": 5050,
  "auto_start": false,
  "dependencies": [],
  "commands": {
    "DASHBOARD": {
      "description": "Launch dashboard web interface",
      "usage": "DASHBOARD [start|stop|status]"
    }
  },
  "settings": {
    "port": 5050,
    "host": "127.0.0.1",
    "debug": false,
    "refresh_interval": 5,
    "theme": "nes-dark"
  },
  "features": [
    "Real-time mission progress tracking",
    "Checklist completion meters",
    "Workflow phase indicators",
    "XP and achievement display",
    "Retro NES.css styling",
    "5-second auto-refresh"
  ]
}
