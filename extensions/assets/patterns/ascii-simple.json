{
  "name": "ascii-simple",
  "version": "1.0.0",
  "type": "border",
  "charset": "ascii",
  "dimensions": {
    "width": 80,
    "height": 24
  },
  "components": {
    "top_left": "+",
    "top_right": "+",
    "bottom_left": "+",
    "bottom_right": "+",
    "horizontal": "-",
    "vertical": "|"
  },
  "example": [
    "+-----------------+",
    "|                 |",
    "|     Content     |",
    "|                 |",
    "+-----------------+"
  ],
  "metadata": {
    "author": "uDOS Team",
    "license": "MIT",
    "tags": [
      "border",
      "ascii",
      "simple",
      "classic"
    ],
    "description": "Classic ASCII border using + - | characters"
  }
}