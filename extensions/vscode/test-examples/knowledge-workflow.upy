# uPY v2.0.2 - Knowledge Generation Workflow

# Generate water purification guide
GENERATE (GUIDE|Water Purification Methods|category=water|complexity=detailed|include=boiling,filtration,chemical treatment)

# Create SVG diagram
GENERATE (DIAGRAM|water-filter-diagram|type=water filter cross-section|style=technical)

# Save checkpoint
CHECKPOINT (SAVE|knowledge-gen-complete)

# Verify results
STATUS (--show|generate)

# v2.0.2 conditional check
[IF {$WORKFLOW.PHASE} == 'COMPLETE' THEN: PRINT ('Success!') ELSE: PRINT ('Still working...')]
