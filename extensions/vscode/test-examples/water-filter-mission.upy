# Test Mission - Water Filter Construction

MISSION CREATE 'Water Filter Construction'
SET (priority|'high')                    # No $ in assignment
SET (location|'AA340')                   # | separator only

# Add knowledge guide
GUIDE ADD tier3 guide "DIY Water Filter"

# Navigate to location
MAP GOTO AA340 100

# Check mission status
{IF MISSION.STATUS == 'ACTIVE': CHECKPOINT SAVE 'mission-start'}
{IF MISSION.STATUS == 'ACTIVE': PRINT('Mission started at $LOCATION')}

# Complete mission
MISSION COMPLETE
