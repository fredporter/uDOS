{
  "id": "udos-viewport-manager",
  "name": "uDOS Viewport Manager",
  "version": "1.0.0",
  "description": "Chromium-based viewport management for multi-mode uDOS operations",
  "author": "uDOS Team",
  "type": "system",
  "capabilities": [
    "viewport_creation",
    "window_management", 
    "multi_mode_support",
    "chromium_integration"
  ],
  "user_modes": [
    "wizard",
    "dev", 
    "tomb",
    "imp",
    "sorcerer",
    "drone",
    "ghost",
    "admin"
  ],
  "viewport_types": [
    "development",
    "monitoring", 
    "terminal",
    "documentation",
    "logs",
    "dashboard",
    "debug",
    "administration"
  ],
  "dependencies": {
    "chromium": ">=90.0",
    "python": ">=3.8",
    "flask": ">=2.0",
    "psutil": ">=5.8"
  },
  "config": {
    "default_viewport_count": 1,
    "max_viewports_per_mode": 4,
    "default_dimensions": {
      "width": 1024,
      "height": 768
    },
    "auto_close_timeout": 300
  }
}
