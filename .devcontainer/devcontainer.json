{
  "name": "uDOS DevEnv v1.6.1",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "settings": {
    "terminal.integrated.defaultProfile.linux": "bash",
    "editor.formatOnSave": true,
    "files.exclude": {
      "**/.git": true,
      "**/.DS_Store": true
    }
  },
  "extensions": [
    "yzhang.markdown-all-in-one",
    "ms-azuretools.vscode-docker",
    "tamasfe.even-better-toml",
    "bierner.markdown-preview-github-styles"
  ],
  "mounts": [
    "source=${localWorkspaceFolder}/uMemory,target=/uDOS/uMemory,type=bind",
    "source=${localWorkspaceFolder}/sandbox,target=/uDOS/sandbox,type=bind"
  ],
  "postCreateCommand": "bash scripts/setup-dev.sh || true",
  "remoteUser": "root"
}