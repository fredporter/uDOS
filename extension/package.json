{
  "name": "udos-extension",
  "displayName": "uDOS v1.2.0 - Universal Development & Operations System",
  "description": "VS Code extension for uDOS v1.2.0 with unified architecture, OK-Assistant system, and enhanced template management",
  "version": "1.2.0",
  "publisher": "udos",
  "engines": {
    "vscode": "^1.60.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/fredporter/uDOS.git"
  },
  "license": "MIT",
  "categories": [
    "Programming Languages",
    "Snippets",
    "Other"
  ],
  "keywords": [
    "uDOS",
    "markdown",
    "shell",
    "development",
    "uScript",
    "templates",
    "ok-assistant",
    "unified-architecture",
    "analytics",
    "mapping",
    "privacy-first",
    "template-system"
  ],
  "activationEvents": [
    "onLanguage:uscript",
    "onCommand:udos.runCommand",
    "onCommand:udos.quickSetup",
    "onCommand:udos.systemStatus",
    "workspaceContains:**/uCode/ucode.sh"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "uscript",
        "aliases": ["uScript", "uscript"],
        "extensions": [".uscript", ".us"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "uscript",
        "scopeName": "source.uscript",
        "path": "./syntaxes/uscript.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "uscript",
        "path": "./snippets/uscript.json"
      },
      {
        "language": "shell",
        "path": "./snippets/udos-enhanced.json"
      },
      {
        "language": "bash",
        "path": "./snippets/udos-enhanced.json"
      }
    ],
    "commands": [
      {
        "command": "udos.quickSetup",
        "title": "🚀 Quick Setup",
        "category": "uDOS v1.2"
      },
      {
        "command": "udos.systemStatus", 
        "title": "📊 System Status",
        "category": "uDOS v1.2"
      },
      {
        "command": "udos.runCommand",
        "title": "⚡ Run Command",
        "category": "uDOS v1.2"
      },
      {
        "command": "udos.createProject",
        "title": "🎯 Create Project",
        "category": "Templates"
      },
      {
        "command": "udos.createMission",
        "title": "� Create Mission", 
        "category": "Templates"
      },
      {
        "command": "udos.createMilestone",
        "title": "⭐ Create Milestone",
        "category": "Templates"
      },
      {
        "command": "udos.listTemplates",
        "title": "📋 List Templates",
        "category": "Templates"
      },
      {
        "command": "udos.generateScript",
        "title": "🔧 Generate Script from Template",
        "category": "Templates"
      },
      {
        "command": "udos.startAssistant",
        "title": "🤖 Start OK-Assistant",
        "category": "Assistants"
      },
      {
        "command": "udos.configureAssistant",
        "title": "⚙️ Configure Assistant",
        "category": "Assistants"
      },
      {
        "command": "udos.listAssistants",
        "title": "📋 List Available Assistants",
        "category": "Assistants"
      },
      {
        "command": "udos.showDashboard",
        "title": "📊 Show Live Dashboard",
        "category": "Monitoring"
      },
      {
        "command": "udos.generateDashboard",
        "title": "🔨 Generate Dashboard",
        "category": "Monitoring"
      },
      {
        "command": "udos.updateAnalytics",
        "title": "📈 Update Analytics",
        "category": "Monitoring"
      },
      {
        "command": "udos.browseMapping",
        "title": "🗺️ Browse Geographic Data",
        "category": "uMapping"
      },
      {
        "command": "udos.processShortcodes",
        "title": "⚙️ Process Template Shortcodes",
        "category": "Templates"
      },
      {
        "command": "udos.openMemory",
        "title": "🧠 Open Memory System",
        "category": "uDOS v1.2"
      },
      {
        "command": "udos.viewWithGlow",
        "title": "📖 View with Glow",
        "category": "Tools"
      },
      {
        "command": "udos.validateInstallation",
        "title": "✅ Validate Installation",
        "category": "System"
      },
      {
        "command": "udos.showUserRole",
        "title": "👤 Show User Roles",
        "category": "System"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "udos.quickSetup",
          "when": "true"
        },
        {
          "command": "udos.systemStatus", 
          "when": "true"
        }
      ],
      "explorer/context": [
        {
          "command": "udos.processShortcodes",
          "when": "resourceExtname == .md",
          "group": "uDOS"
        },
        {
          "command": "udos.viewWithGlow",
          "when": "resourceExtname == .md", 
          "group": "uDOS"
        }
      ]
    },
    "keybindings": [
      {
        "command": "udos.quickSetup",
        "key": "ctrl+shift+u",
        "mac": "cmd+shift+u"
      },
      {
        "command": "udos.systemStatus",
        "key": "ctrl+shift+s",
        "mac": "cmd+shift+s"
      },
      {
        "command": "udos.runCommand",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^14.x",
    "@types/vscode": "^1.60.0",
    "typescript": "^4.4.4"
  }
}
