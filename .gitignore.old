# ============================================================
# uDOS v1.2.12+ - Git Ignore Configuration
# ============================================================
# Philosophy: Track distribution-ready content only
# - Core system files (core/, extensions/, knowledge/)
# - Distributable scripts (memory/ucode/{tests,stdlib,examples,adventures})
# - Structural files (.gitkeep, README, configs)
# Ignore: User data, logs, backups, active work, environment files

# ============================================================
# Environment & Secrets
# ============================================================
.env
.env.local
*.key
*.secret

# Gmail OAuth2 credentials and tokens
memory/system/user/gmail_credentials.json
memory/system/user/.gmail_token.enc
*.gmail_token*

# User configuration overrides
*.UDC
data/STORY.UDO
data/USER.UDO

# User configuration overrides
*.UDC
data/STORY.UDO
data/USER.UDO

# ============================================================
# Python Runtime
# ============================================================
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg
*.egg-info/
dist/
build/

# Virtual Environments
.venv/
venv/
env/
ENV/
pip-selfcheck.json

# Node.js
node_modules/
package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================================
# IDE & System Files
# ============================================================
.DS_Store
.DS_Store/
**/.DS_Store
.vscode/settings.json
.vscode/*.log
.idea/
*.swp
*.swo
*~
.cache/
.pytest_cache/

# ============================================================
# Extensions - Clone Management
# ============================================================
# Track: uDOS-native extensions, setup scripts, README files
# Ignore: Cloned third-party repositories

# Ignore all cloned repositories
extensions/clone/
extensions/native/
extensions/cloned/
extensions/web/c64css3/
extensions/clone/monaspace-fonts/

# Track structure and documentation
!extensions/clone/.gitkeep
!extensions/native/.gitkeep
!extensions/cloned/.gitkeep
!extensions/**/*.md
!extensions/**/*.sh

# ============================================================
# Memory - User Workspace (v1.2.12+)
# ============================================================
# Structure:
#   memory/ucode/        - Core distributable scripts
#     ├── tests/         - Test suites (TRACKED)
#     ├── stdlib/        - Standard library (TRACKED)
#     ├── examples/      - Example scripts (TRACKED)
#     ├── adventures/    - Adventure scripts (TRACKED)
#     ├── scripts/       - User scripts (IGNORED)
#     └── sandbox/       - Experimental scripts (IGNORED)
#   memory/workflows/    - Workflow automation (IGNORED except structure)
#   memory/system/       - System config (IGNORED except structure)
#   memory/bank/         - Banking data (IGNORED)
#   memory/shared/       - Community content (IGNORED)
#   memory/logs/         - Session logs (IGNORED)
#   memory/sessions/     - Session state (IGNORED)
#   memory/missions/     - Mission data (IGNORED)
#   memory/checklists/   - Checklist tracking (IGNORED)
#   memory/docs/         - User documentation (IGNORED)
#   memory/drafts/       - Draft content (IGNORED)

# Ignore entire memory/ by default
memory/
memory/**/*

# Track: Core distributable scripts and tests
!memory/ucode/
!memory/ucode/tests/
!memory/ucode/tests/**
!memory/ucode/stdlib/
!memory/ucode/stdlib/**
!memory/ucode/examples/
!memory/ucode/examples/**
!memory/ucode/adventures/
!memory/ucode/adventures/**

# Track: Structural files and demo/setup content
!memory/ucode/.gitkeep
!memory/ucode/scripts/.gitkeep
!memory/ucode/sandbox/.gitkeep
!memory/README.md
!memory/README-*.md
!memory/.gitkeep
!memory/pytest.ini
!memory/structure.txt

# Track: Required directory structure
!memory/workflows/
!memory/workflows/.gitkeep
!memory/workflows/README.md
!memory/workflows/config.json
!memory/missions/
!memory/missions/.gitkeep
!memory/system/
!memory/system/.gitkeep
!memory/system/user/
!memory/system/user/.gitkeep
!memory/system/themes/
!memory/system/themes/.gitkeep
!memory/bank/
!memory/bank/.gitkeep
!memory/bank/private/
!memory/bank/private/.gitkeep
!memory/bank/barter/
!memory/bank/barter/.gitkeep
!memory/shared/
!memory/shared/.gitkeep
!memory/shared/groups/
!memory/shared/groups/.gitkeep
!memory/shared/metadata/
!memory/shared/metadata/.gitkeep
!memory/shared/public/
!memory/shared/public/.gitkeep
!memory/shared/.submissions/
!memory/shared/.submissions/.gitkeep
!memory/logs/
!memory/logs/.gitkeep
!memory/sessions/
!memory/sessions/.gitkeep
!memory/checklists/
!memory/checklists/.gitkeep
!memory/docs/
!memory/docs/.gitkeep
!memory/drafts/
!memory/drafts/.gitkeep
!memory/drafts/ascii/
!memory/drafts/ascii/.gitkeep
!memory/drafts/svg/
!memory/drafts/svg/.gitkeep
!memory/drafts/teletext/
!memory/drafts/teletext/.gitkeep

# Explicitly ignore user workspace content
memory/ucode/scripts/*
!memory/ucode/scripts/.gitkeep
memory/ucode/sandbox/*
!memory/ucode/sandbox/.gitkeep
memory/workflows/*
!memory/workflows/.gitkeep
!memory/workflows/README.md
memory/system/**/*
memory/bank/**/*
memory/shared/**/*
memory/private/**/*
memory/logs/**/*
memory/sessions/**/*
memory/checklists/**/*
memory/missions/**/*
memory/docs/**/*
memory/drafts/**/*

# ============================================================
# Archives & Backups (v1.1.16+)
# ============================================================
# Universal .archive/ folders - version history, backups, soft-deletes
# Ignore all archive contents (generated, not source)
.archive/
**/.archive/
.archive/**/*
**/.archive/**/*

# Exclude dev/.archive/ specifically (development session archives)
dev/.archive/
dev/.archive/**/*

# Deprecated root folders (v1.2.12)
.archive/deprecated-root/

# General backup patterns
backups/
*.backup
*.bak
*~

# ============================================================
# Logs & Session State
# ============================================================
# All logs ignored (generated at runtime)
*.log
*.jsonl
*.pid
*.state
memory/logs/*.log
memory/logs/*.jsonl
memory/logs/session-*.json
memory/logs/*_server.log
memory/workflows/logs/
memory/workflows/logs/**/*

# ============================================================
# Databases
# ============================================================
# User databases (generated, not source)
*.db
*.sqlite
*.sqlite3
memory/system/user/*.db
memory/bank/*.db
sandbox/user/*.db

# ============================================================
# Deprecated Root Folders (v1.2.12+)
# ============================================================
# These folders moved to .archive/deprecated-root/
# Prevent recreation at root level
sandbox/
sandbox/**/*
data/
scripts/

# ============================================================
# Root-Level Prevention
# ============================================================
# Prevent working directories from being created at root
/output/
/tmp/
/temp/
/test_*.py
/test_*.uscript
/test_*.sh
/*.test.*
/tmp_*
/temp_*

# ============================================================
# Core System - Fully Tracked
# ============================================================
# These directories ship with uDOS - track everything
!core/
!core/**/*
!extensions/
!extensions/**/*
!knowledge/
!knowledge/**/*
!wiki/
!wiki/**/*
!dev/
!dev/**/*

# But ignore archives, backups, and build artifacts even in core/extensions
core/**/.archive/
core/**/.archive/**
extensions/**/.archive/
extensions/**/.archive/**
extensions/**/node_modules/
extensions/**/node_modules/**
extensions/**/dist/
extensions/**/*.vsix
knowledge/**/.archive/
knowledge/**/.archive/**
wiki/**/.archive/
wiki/**/.archive/**
*.bak
*.backup

# ============================================================
# Templates - Track Templates Only
# ============================================================
# .UDT = UDO Template (tracked)
# User instances ignored above
!data/*.UDT
!knowledge/**/*.UDT
!memory/templates/*.UDT

# ============================================================
# Wiki Deployment
# ============================================================
# Keep source in /wiki, ignore deployed clone
uDOS.wiki/

# ============================================================
# Project Files
# ============================================================
# Track all project documentation and configs
!*.md
!*.txt
!*.json
!*.yaml
!*.yml
!*.toml
!*.cfg
!*.ini
!requirements.txt
!setup.py
!.gitignore
!.gitattributes
!LICENSE*
!CREDITS*
!CHANGELOG*
!CONTRIBUTING*
!CODE-OF-CONDUCT*

# ============================================================
# End of uDOS .gitignore (v1.2.12+)
# ============================================================
!history/
!history/**/*
