{
  "name": "uDOS Package System",
  "version": "1.2.0",
  "packages": {
    "editors": {
      "nano": {
        "version": "latest",
        "description": "Simple command-line text editor",
        "install_command": "brew install nano",
        "ucode_commands": ["EDIT", "CREATE"],
        "auto_install": true,
        "priority": 1
      },
      "micro": {
        "version": "latest", 
        "description": "Modern terminal editor with mouse support",
        "install_command": "brew install micro",
        "ucode_commands": ["EDIT", "CREATE", "MICRO"],
        "auto_install": true,
        "priority": 2
      },
      "helix": {
        "version": "latest",
        "description": "Modal editor with built-in LSP support",
        "install_command": "brew install helix",
        "ucode_commands": ["HX", "HELIX"],
        "auto_install": false,
        "priority": 3
      }
    },
    "utils": {
      "ripgrep": {
        "version": "latest",
        "description": "Fast text search tool",
        "install_command": "brew install ripgrep",
        "ucode_commands": ["SEARCH", "GREP", "RG"],
        "auto_install": true,
        "priority": 1
      },
      "fd": {
        "version": "latest",
        "description": "Fast file finder",
        "install_command": "brew install fd",
        "ucode_commands": ["FIND", "FD"],
        "auto_install": true,
        "priority": 2
      },
      "bat": {
        "version": "latest",
        "description": "Syntax-highlighted file viewer",
        "install_command": "brew install bat",
        "ucode_commands": ["VIEW", "CAT", "BAT"],
        "auto_install": true,
        "priority": 3
      },
      "glow": {
        "version": "latest",
        "description": "Markdown renderer",
        "install_command": "brew install glow",
        "ucode_commands": ["GLOW", "MARKDOWN"],
        "auto_install": true,
        "priority": 4
      },
      "jq": {
        "version": "latest",
        "description": "JSON processor",
        "install_command": "brew install jq",
        "ucode_commands": ["JQ", "JSON"],
        "auto_install": true,
        "priority": 5
      },
      "fzf": {
        "version": "latest",
        "description": "Fuzzy finder for interactive selection",
        "install_command": "brew install fzf",
        "ucode_commands": ["FZF", "FUZZY"],
        "auto_install": true,
        "priority": 6
      }
    },
    "development": {
      "vscode-extension": {
        "version": "1.2.0",
        "description": "uDOS VS Code extension with language support",
        "install_command": "./extension/install-extension.sh",
        "ucode_commands": ["VSCODE", "EXTENSION"],
        "auto_install": true,
        "priority": 1
      },
      "gemini-cli": {
        "version": "latest",
        "description": "Google Gemini AI CLI for intelligent assistance",
        "install_command": "./uCode/packages/install-gemini.sh",
        "ucode_commands": ["GEMINI", "AI", "CHESTER"],
        "auto_install": false,
        "priority": 2
      }
    }
  },
  "startup_install_order": [
    "nano",
    "ripgrep", 
    "fd",
    "bat",
    "micro",
    "glow",
    "jq",
    "fzf",
    "vscode-extension"
  ]
}
