        "conditions": ["AVAILABLE", "ALLOCATED", "OVERALLOCATED", "UNAVAILABLE"]
      },
      "milestone": {
        "properties": ["target_date", "dependencies", "critical_path", "buffer_time"],
        "rarity_levels": ["MINOR", "MAJOR", "CRITICAL", "GO_NO_GO"],
        "conditions": ["UPCOMING", "ON_TRACK", "AT_RISK", "MISSED"]
      },
      "document": {
        "properties": ["version", "approval_status", "stakeholder_review", "compliance"],
        "rarity_levels": ["DRAFT", "INTERNAL", "CLIENT_FACING", "REGULATORY"],
        "conditions": ["DRAFT", "UNDER_REVIEW", "APPROVED", "ARCHIVED"]
