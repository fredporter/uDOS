# =============================================================================
# TEST 6: CONDITIONALS & LOGIC
# =============================================================================

PRINT("")
PRINT(":six: TEST 6: Conditionals & Logic")

$HP = 100
$GOLD = 50
$LEVEL = 5

# Inline conditionals
IF {$HP == 100 | PRINT("  :heart: HP is full")}
IF {$GOLD >= 50 | PRINT("  :coin: You have enough gold")}
IF {$LEVEL > 3 | PRINT("  :star: Level is above 3")}

# Nested conditionals in function
FUNCTION [@EVALUATE-PLAYER($HP, $GOLD, $LEVEL)
    IF {$HP <= 0 | RETURN ':skull: dead'}
    IF {$GOLD < 10 | RETURN ':warning: broke'}
    IF {$LEVEL < 5 | RETURN ':info: beginner'}
    RETURN ':star: experienced'
]

$PLAYER-STATUS = @EVALUATE-PLAYER($HP, $GOLD, $LEVEL)
PRINT("  Player status: $PLAYER-STATUS")
PRINT("  :check: Conditional logic working")
$TEST-COUNT = $TEST-COUNT + 4
$PASS-COUNT = $PASS-COUNT + 4

