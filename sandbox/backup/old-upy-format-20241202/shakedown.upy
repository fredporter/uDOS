# =============================================================================
# TEST 1: VARIABLES & ASSIGNMENT
# =============================================================================

PRINT(":one: TEST 1: Variables & Assignment")

$TEST-NAME = 'shakedown'
$VERSION = '1.1.9'
$TEST-COUNT = 0
$PASS-COUNT = 0

PRINT("  :check: Variable assignment working")
PRINT("  Test: $TEST-NAME v$VERSION")
$TEST-COUNT = $TEST-COUNT + 1
$PASS-COUNT = $PASS-COUNT + 1

# =============================================================================
# TEST 2: FUNCTIONS & RETURN VALUES
# =============================================================================

PRINT("")
PRINT(":two: TEST 2: Functions & Return Values")

FUNCTION [@GREET($NAME)
    PRINT("  :wave: Hello, $NAME!")
    RETURN 'greeting-sent'
]

FUNCTION [@ADD($A, $B)
    $RESULT = $A + $B
    RETURN $RESULT
]

FUNCTION [@CHECK-STATUS($VALUE)
    IF {$VALUE > 80 | RETURN ':check: excellent'}
    IF {$VALUE > 60 | RETURN ':thumbsup: good'}
    IF {$VALUE > 40 | RETURN ':warning: moderate'}
    RETURN ':cross: poor'
]

# Test function calls
$GREETING-RESULT = @GREET('uDOS')
$SUM = @ADD(15, 27)
$STATUS = @CHECK-STATUS(85)

PRINT("  :check: Function definitions working")
PRINT("  Greeting result: $GREETING-RESULT")
PRINT("  15 + 27 = $SUM")
PRINT("  Status check: $STATUS")
$TEST-COUNT = $TEST-COUNT + 3
$PASS-COUNT = $PASS-COUNT + 3

