# STORY Integration Test
# Tests STORY command in uDOS main loop

PRINT("=== STORY Integration Test ===")
PRINT("")

PRINT("📖 Test 1: List available adventures")
[STORY|LIST]
PRINT("")

PRINT("🎮 Test 2: Start tutorial adventure")
[STORY|START*first-steps]
PRINT("")

PRINT("📊 Test 3: Show adventure status")
[STORY|STATUS]
PRINT("")

PRINT("🚪 Test 4: Quit adventure (without saving)")
[STORY|QUIT*nosave]
PRINT("")

PRINT("✅ STORY command integration test complete!")
