{
  "version": "1.7.1",
  "description": "uDOS Error Handling Configuration",
  "error_levels": {
    "FATAL": {
      "symbol": "🔥",
      "color": "red",
      "action": "exit",
      "log_location": "errors/fatal",
      "notify": true
    },
    "ERROR": {
      "symbol": "❌", 
      "color": "red",
      "action": "retry",
      "log_location": "errors/critical",
      "notify": true
    },
    "WARN": {
      "symbol": "⚠️",
      "color": "yellow", 
      "action": "continue",
      "log_location": "errors/warnings",
      "notify": false
    },
    "INFO": {
      "symbol": "ℹ️",
      "color": "blue",
      "action": "continue", 
      "log_location": "logs/info",
      "notify": false
    },
    "DEBUG": {
      "symbol": "🐛",
      "color": "gray",
      "action": "continue",
      "log_location": "logs/debug", 
      "notify": false
    }
  },
  "recovery_strategies": {
    "file_not_found": {
      "description": "Automatic file/directory creation",
      "actions": [
        "create_missing_directories",
        "create_empty_files",
        "copy_from_template"
      ],
      "max_attempts": 3
    },
    "permission_denied": {
      "description": "Permission fixing",
      "actions": [
        "fix_file_permissions",
        "change_ownership",
        "suggest_manual_fix"
      ],
      "max_attempts": 2
    },
    "command_not_found": {
      "description": "Command installation",
      "actions": [
        "check_package_managers",
        "install_from_scripts", 
        "suggest_alternatives"
      ],
      "max_attempts": 1
    },
    "network_error": {
      "description": "Network retry mechanisms",
      "actions": [
        "retry_with_backoff",
        "test_connectivity",
        "use_offline_mode"
      ],
      "max_attempts": 5
    },
    "script_execution": {
      "description": "Script execution fixes",
      "actions": [
        "fix_permissions",
        "validate_syntax",
        "check_dependencies"
      ],
      "max_attempts": 3
    },
    "memory_error": {
      "description": "Memory management",
      "actions": [
        "cleanup_temp_files",
        "compress_logs",
        "free_cached_data"
      ],
      "max_attempts": 2
    }
  },
  "retry_settings": {
    "max_retries": 3,
    "base_delay": 1,
    "backoff_multiplier": 2,
    "max_delay": 30,
    "jitter": true
  },
  "logging": {
    "max_log_size": "10MB",
    "log_rotation": 30,
    "compression": true,
    "include_stack_trace": true,
    "include_system_info": true
  },
  "monitoring": {
    "error_rate_threshold": 10,
    "error_rate_window": 3600,
    "alert_on_threshold": true,
    "dashboard_integration": true
  },
  "cleanup": {
    "auto_cleanup": true,
    "cleanup_interval": 24,
    "keep_recent_errors": 7,
    "archive_old_errors": true
  }
}
