# ============================================
# DISPLAY AND SAVE
# ============================================

# Display map
[PANEL|SHOW*world_layer0]

# Embed in markdown
[PANEL|EMBED*world_layer0*data/maps/world_layer0.md]

# Save panel info
[PANEL|INFO*world_layer0]

# ============================================
# USAGE NOTES
# ============================================
# Grid Coordinate Format: AA-RR (columns) + 1-270 (rows)
# Example: M240 = Column M (13th), Row 240
#
# TZONE Codes: See data/system/geography/tzone.json
# EST, PST, CST, GMT, CET, AEST, JST, etc.
#
# Terrain Characters:
#   █ ocean_deep    ▓ ocean         ▒ ocean_shallow  ░ coast
#   · plains        ≈ grassland     ♠ forest         ∴ desert
#   ▲ mountains     ∩ hills         ● city marker
#
# Map Scale: 1 character = ~80km (approximate)
# Total coverage: ~38,400km × ~21,600km
#
# Layer System:
#   Layer 0: Base terrain (this file)
#   Layer 1: Political boundaries
#   Layer 2: Transportation networks
#   Layer 3: Climate zones
#   Layer 4: Population density
#   Layer 5: Resource locations
