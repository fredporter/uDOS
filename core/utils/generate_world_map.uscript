# World Map Generator (Layer 0)
# Creates 480×270 character world map using teletext block graphics
# Integrates with TZONE grid coordinate system

# ============================================
# WORLD MAP LAYER 0 - BASE TERRAIN
# ============================================
# Resolution: 480×270 characters (Tier 14: 8K Max)
# Grid cells: AA-RR columns (480), 1-270 rows
# Each character = 1 grid cell

# Create base map panel
[PANEL|CREATE*world_layer0*480*270*14]

# ============================================
# OCEAN BASINS - Deep Ocean (█)
# ============================================
# Pacific Ocean (largest)
[PANEL|TERRAIN*world_layer0*0*0*200*270*ocean_deep]

# Atlantic Ocean
[PANEL|TERRAIN*world_layer0*280*0*200*270*ocean_deep]

# Indian Ocean
[PANEL|TERRAIN*world_layer0*320*140*160*130*ocean_deep]

# Arctic Ocean
[PANEL|TERRAIN*world_layer0*150*0*180*40*ocean_deep]

# Southern Ocean
[PANEL|TERRAIN*world_layer0*0*240*480*30*ocean_deep]

