{
  "_comment": "Tree/hierarchy diagram template with chunky blocks",
  "_style": "branching tree structure with labeled nodes",

  "config": {
    "node_width": 20,
    "node_height": 3,
    "branch_style": "heavy",
    "indent": 4
  },

  "components": {
    "root_node": {
      "top": "▐▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▀▌",
      "middle": "▐ {label:^16} ▌",
      "bottom": "▐▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▄▌"
    },
    "child_node": {
      "top": "┏━━━━━━━━━━━━━━━━━━┓",
      "middle": "┃ {label:^16} ┃",
      "bottom": "┗━━━━━━━━━━━━━━━━━━┛"
    },
    "connectors": {
      "vertical": "┃",
      "horizontal": "━",
      "branch_down": "┳",
      "branch_right": "┣",
      "elbow": "┗━",
      "tee": "┣━"
    }
  },

  "example": {
    "title": "Shelter Types Hierarchy",
    "structure": {
      "root": "Emergency Shelter",
      "children": [
        {
          "label": "Natural",
          "children": ["Cave", "Tree hollow", "Rock overhang"]
        },
        {
          "label": "Constructed",
          "children": ["Lean-to", "Debris hut", "A-frame"]
        },
        {
          "label": "Improvised",
          "children": ["Tarp shelter", "Snow cave", "Dugout"]
        }
      ]
    }
  }
}
