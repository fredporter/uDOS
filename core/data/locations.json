  "tile_system": {
    "_COMMENT": "Hierarchical alphanumeric TILE codes replace lat/long storage",

    "encoding": "CONTINENT-COUNTRY-CITY[-DISTRICT[-BLOCK]]",
    "coordinate_system": "uDOS MAP grid (480x270 cells, 16x16px each)",
    "grid_format": "Column-Row (e.g., AB320 = Column AB, Row 320 - always 2 letters)",

    "levels": {
      "world": {
        "description": "7 continent tiles",
        "tiles": ["AS", "EU", "NA", "SA", "AF", "OC", "AN"],
        "zoom": 1,
        "layer": 100
      },
      "region": {
        "description": "Country within continent (ISO 3166-1 alpha-2)",
        "example": "AS-JP (Asia, Japan)",
        "zoom": 2,
        "layer": 200
      },
      "city": {
        "description": "Major city (IATA-like 3-letter codes)",
        "example": "AS-JP-TYO (Tokyo)",
        "zoom": 3,
        "layer": 300
      },
      "district": {
        "description": "City districts (A1-Z9 grid, 26×9=234 tiles)",
        "example": "AS-JP-TYO-C5 (Shibuya district)",
        "zoom": 4,
        "layer": 400
      },
      "block": {
        "description": "Street blocks (01-99)",
        "example": "AS-JP-TYO-C5-42",
        "zoom": 5,
        "layer": 500
      }
    },

    "continents": {
      "AS": {"name": "Asia", "grid_range": ["AS250", "AC350"]},
      "EU": {"name": "Europe", "grid_range": ["AL235", "AR255"]},
      "NA": {"name": "North America", "grid_range": ["AA110", "AJ145"]},
      "SA": {"name": "South America", "grid_range": ["AF175", "AK195"]},
      "AF": {"name": "Africa", "grid_range": ["AM225", "AS255"]},
      "OC": {"name": "Oceania", "grid_range": ["AY330", "BE350"]},
      "AN": {"name": "Antarctica", "grid_range": ["AA360", "RL370"]}
    },

    "default_start": "OC-AU-SYD",
    "fallback": "EU-UK-LON"
  },

  "base_layer": {
    "_COMMENT": "Layer 100 - Base world map linking grid cells to TILE codes",
    "layer_id": 100,
    "layer_name": "World Base Layer",
    "description": "Teletext page 100-899 style base layer mapping grid cells to TILE codes",
    "grid_size": {
      "columns": 480,
      "rows": 270,
      "cell_size_px": [16, 16],
      "total_cells": 129600
    },
    "reference": "See extensions/assets/data/worldmap.json for full grid mapping"
  },

  "coordinate_conversion": {
    "_COMMENT": "TILE codes are the primary location format - no lat/long storage",

    "tile_to_grid": {
      "description": "Decode TILE code to grid cell reference",
      "example": "AS-JP-TYO → AB320 (Column AB, Row 320)"
    },

    "grid_to_tile": {
      "description": "Encode grid cell to nearest TILE code",
      "example": "AB320 → AS-JP-TYO",
      "precision": "city_level"
    }
  },

  "usage": {
    "startup": "Detect user timezone → Map to city → Get TILE code → Set grid position",
    "navigation": "Use TILE codes for all location storage (USER.UDT, map positions)",
    "display": "Convert TILE to human-readable (AS-JP-TYO → 'Tokyo, Japan' @ AB320)",
    "zoom": "Navigate layers by zoom level (Layer 100→200→300→400→500)",
    "grid_lookup": "Use base_layer (Layer 100) for grid cell to coordinate conversions"
  }
