#!/usr/bin/env udos
# uPY Form Validation Template v2.0
# Input validation with error handling

PRINT [==========================================]
PRINT [  User Registration Form]
PRINT [==========================================]
PRINT []

# Username validation
LABEL [USERNAME_INPUT]
INPUT [Enter username (3-20 characters):] → username
SET (username_length|LEN($username))
{IF username_length < 3: PRINT [Username too short!]}
{IF username_length < 3: BRANCH [USERNAME_INPUT]}
{IF username_length > 20: PRINT [Username too long!]}
{IF username_length > 20: BRANCH [USERNAME_INPUT]}
PRINT [✓ Username accepted]
PRINT []

# Email validation
LABEL [EMAIL_INPUT]
INPUT [Enter email address:] → email
{IF '@' NOT IN email: PRINT [Invalid email format!]}
{IF '@' NOT IN email: BRANCH [EMAIL_INPUT]}
{IF '.' NOT IN email: PRINT [Invalid email format!]}
{IF '.' NOT IN email: BRANCH [EMAIL_INPUT]}
PRINT [✓ Email accepted]
PRINT []

# Password validation
LABEL [PASSWORD_INPUT]
INPUT [Enter password (min 8 characters):] → password
SET (password_length|LEN($password))
{IF password_length < 8: PRINT [Password too short!]}
{IF password_length < 8: BRANCH [PASSWORD_INPUT]}
PRINT [✓ Password accepted]
PRINT []

# Confirm password
LABEL [PASSWORD_CONFIRM]
INPUT [Confirm password:] → password_confirm
{IF password != password_confirm: PRINT [Passwords do not match!]}
{IF password != password_confirm: BRANCH [PASSWORD_CONFIRM]}
PRINT [✓ Password confirmed]
PRINT []

# Age validation
LABEL [AGE_INPUT]
INPUT [Enter age (must be 13 or older):] → age
{IF age < 13: PRINT [You must be 13 or older to register!]}
{IF age < 13: BRANCH [AGE_INPUT]}
{IF age > 120: PRINT [Please enter a valid age!]}
{IF age > 120: BRANCH [AGE_INPUT]}
PRINT [✓ Age accepted]
PRINT []

# Summary
PRINT [==========================================]
PRINT [  Registration Summary]
PRINT [==========================================]
PRINT [Username: $username]
PRINT [Email: $email]
PRINT [Age: $age]
PRINT []
PRINT [Registration complete!]
XP [+50]
END
