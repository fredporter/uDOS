{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "🌀 Start uDOS",
            "type": "shell",
            "command": "../../uCORE/code/ucode.sh",
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": true,
                "panel": "dedicated",
                "showReuseMessage": false,
                "clear": true
            },
            "problemMatcher": [],
            "detail": "Launch uDOS shell from wizard environment"
        },
        {
            "label": "🎯 Compile VS Code Extension",
            "type": "shell",
            "command": "npx",
            "args": ["tsc"],
            "options": {
                "cwd": "${workspaceFolder}/vscode-extension"
            },
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always"
            },
            "problemMatcher": ["$tsc"],
            "detail": "Compile uDOS VS Code Extension TypeScript"
        },
        {
            "label": "📦 Install Extension Dependencies",
            "type": "shell",
            "command": "npm",
            "args": ["install"],
            "options": {
                "cwd": "${workspaceFolder}/vscode-extension"
            },
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always"
            },
            "problemMatcher": [],
            "detail": "Install uDOS VS Code Extension dependencies"
        },
        {
            "label": "⚡ Watch Extension",
            "type": "shell",
            "command": "npx",
            "args": ["tsc", "--watch"],
            "options": {
                "cwd": "${workspaceFolder}/vscode-extension"
            },
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "never",
                "panel": "dedicated"
            },
            "isBackground": true,
            "problemMatcher": "$tsc-watch",
            "detail": "Watch compile uDOS Extension for development"
        },
        {
            "label": "📋 Initialize Dev Framework",
            "type": "shell",
            "command": "../dev-utils.sh",
            "args": ["init_framework"],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": [],
            "detail": "Initialize development framework with notes, workflows, and roadmaps"
        },
        {
            "label": "📝 Start Dev Session",
            "type": "shell",
            "command": "../dev-utils.sh",
            "args": ["session", "start", "${input:sessionType}"],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": [],
            "detail": "Start development session with framework integration"
        },
        {
            "label": "🔄 End Dev Session",
            "type": "shell",
            "command": "../dev-utils.sh",
            "args": ["session", "end"],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": [],
            "detail": "End current development session"
        },
        {
            "label": "📄 Create Note",
            "type": "shell",
            "command": "../dev-utils.sh",
            "args": ["note", "${input:noteType}", "${input:noteTitle}"],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": [],
            "detail": "Create development note with framework integration"
        },
        {
            "label": "🔀 Advance Workflow",
            "type": "shell",
            "command": "../dev-utils.sh",
            "args": ["workflow", "advance", "${input:workflowName}", "${input:workflowStage}"],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": [],
            "detail": "Advance workflow stage with smart backup integration"
        },
        {
            "label": "🗺️ Update Roadmap",
            "type": "shell",
            "command": "../dev-utils.sh",
            "args": ["roadmap", "update"],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": [],
            "detail": "Update development roadmap with current progress"
        },
        {
            "label": "💾 Create Checkpoint",
            "type": "shell",
            "command": "../dev-utils.sh",
            "args": ["checkpoint", "${input:checkpointName}"],
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": [],
            "detail": "Create smart backup checkpoint with framework state"
        },
        {
            "label": "📊 Development Analytics",
            "type": "shell",
            "command": "../dev-utils.sh",
            "args": ["analytics", "${input:analyticsType}"],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": [],
            "detail": "Run development analytics and metrics"
        },
        {
            "label": "🧠 User Memory Overview",
            "type": "shell",
            "command": "../../uCORE/code/user-memory/user-memory-manager.sh",
            "args": ["overview"],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": [],
            "detail": "Show comprehensive user memory system status"
        },
        {
            "label": "🎯 Create Mission",
            "type": "shell",
            "command": "../../uCORE/code/user-memory/user-memory-manager.sh",
            "args": ["mission", "${input:missionName}", "${input:missionType}"],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": [],
            "detail": "Create new user mission"
        },
        {
            "label": "🏆 Add Milestone",
            "type": "shell",
            "command": "../../uCORE/code/user-memory/user-memory-manager.sh",
            "args": ["milestone", "${input:milestoneName}", "${input:milestoneDescription}"],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": [],
            "detail": "Record achievement milestone"
        },
        {
            "label": "📍 Log User Move",
            "type": "shell",
            "command": "../../uCORE/code/user-memory/user-memory-manager.sh",
            "args": ["move", "${input:moveType}", "${input:moveDescription}", "${input:moveLocation}"],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": [],
            "detail": "Log user activity move"
        },
        {
            "label": "🗃️ Create Legacy Archive",
            "type": "shell",
            "command": "../../uCORE/code/user-memory/user-memory-manager.sh",
            "args": ["legacy", "${input:legacyName}", "${input:legacyPath}"],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": [],
            "detail": "Archive legacy content"
        },
        {
            "label": "📋 Generate Memory Report",
            "type": "shell",
            "command": "../../uCORE/code/user-memory/user-memory-manager.sh",
            "args": ["report"],
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": [],
            "detail": "Generate comprehensive user memory report"
        }
    ],
    "inputs": [
        {
            "id": "sessionType",
            "description": "Enter session type",
            "default": "general",
            "type": "promptString"
        },
        {
            "id": "noteType",
            "description": "Enter note type",
            "default": "feature",
            "type": "pickString",
            "options": ["session", "feature", "bug", "research", "workflow", "roadmap"]
        },
        {
            "id": "noteTitle",
            "description": "Enter note title",
            "default": "New Development Note",
            "type": "promptString"
        },
        {
            "id": "workflowName",
            "description": "Enter workflow name",
            "default": "Feature Development",
            "type": "promptString"
        },
        {
            "id": "workflowStage",
            "description": "Enter workflow stage",
            "default": "implementation",
            "type": "pickString",
            "options": ["planning", "implementation", "testing", "documentation", "deployment"]
        },
        {
            "id": "checkpointName",
            "description": "Enter checkpoint name",
            "default": "manual_checkpoint",
            "type": "promptString"
        },
        {
            "id": "analyticsType",
            "description": "Enter analytics type",
            "default": "summary",
            "type": "pickString",
            "options": ["summary", "productivity", "workflow"]
        },
        {
            "id": "missionName",
            "description": "Enter mission name",
            "default": "New Mission",
            "type": "promptString"
        },
        {
            "id": "missionType",
            "description": "Enter mission type",
            "default": "learning",
            "type": "pickString",
            "options": ["learning", "work", "personal", "system", "tutorial"]
        },
        {
            "id": "milestoneName",
            "description": "Enter milestone name",
            "default": "Achievement",
            "type": "promptString"
        },
        {
            "id": "milestoneDescription",
            "description": "Enter milestone description",
            "default": "New achievement unlocked",
            "type": "promptString"
        },
        {
            "id": "moveType",
            "description": "Enter move type",
            "default": "navigation",
            "type": "pickString",
            "options": ["navigation", "development", "learning", "research", "testing", "documentation"]
        },
        {
            "id": "moveDescription",
            "description": "Enter move description",
            "default": "User activity",
            "type": "promptString"
        },
        {
            "id": "moveLocation",
            "description": "Enter move location",
            "default": "workspace/",
            "type": "promptString"
        },
        {
            "id": "legacyName",
            "description": "Enter legacy archive name",
            "default": "Archive",
            "type": "promptString"
        },
        {
            "id": "legacyPath",
            "description": "Enter path to legacy content",
            "default": "/path/to/content",
            "type": "promptString"
        }
    ]
}
