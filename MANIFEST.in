# Manifest file for package data inclusion
include README.MD
include LICENSE.txt
include CHANGELOG.md
include ROADMAP.MD
include QUICK-REFERENCE.md
include INSTALL.md
include CONTRIBUTING.md
include CREDITS.md
include requirements.txt
include start_udos.sh
include pytest.ini

# Core source code
recursive-include core *.py

# Knowledge base
recursive-include knowledge *.json
recursive-include knowledge *.md
recursive-include knowledge *.txt

# Data files
recursive-include data *.json
recursive-include data *.md
recursive-include data *.txt

# Extensions
recursive-include extensions *.html
recursive-include extensions *.css
recursive-include extensions *.js
recursive-include extensions *.json
recursive-include extensions *.md

# Exclude unnecessary files
global-exclude __pycache__
global-exclude *.py[co]
global-exclude .DS_Store
global-exclude *.swp
global-exclude *.swo
global-exclude *~

# Exclude development/testing
recursive-exclude memory *
recursive-exclude docs *
recursive-exclude wiki *
recursive-exclude .git *
recursive-exclude .github *
