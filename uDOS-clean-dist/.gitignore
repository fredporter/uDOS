# ──────────────────────────────────────────────
# uDOS v1.0 Distribution .gitignore
# Clean Repository Architecture - Security Model Compliant
# ──────────────────────────────────────────────

# ════════════════════════════════════════════════════════════════
# 🔒 SECURITY MODEL ENFORCEMENT
# ════════════════════════════════════════════════════════════════

# 🔐 Level 1: uMemory - Private User Files (NEVER in repo)
# Contains personal data, logs, state, missions, moves
uMemory/

# 🔧 Level 2: uExtension - Local Development Only (NEVER in repo)
# VS Code extension source and builds - distributed via uKnowledge packages
uExtension/

# 📦 Level 3: Local User Development & Testing
# Sandbox environments and user-specific configurations
uMemory/sandbox/
uMemory/user/
uMemory/state/
uMemory/logs/
uMemory/missions/
uMemory/moves/
uMemory/milestones/

# ════════════════════════════════════════════════════════════════
# 🚫 BUILD ARTIFACTS & DEVELOPMENT FILES
# ════════════════════════════════════════════════════════════════

# Build and compilation artifacts
__pycache__/
*.pyc
*.pyo
*.so
*.out
*.exe
*.zip
*.tar.gz
*.dmg
*.vsix
dist/
build/
out/

# Logs and temporary files
**/*.log
*.tmp
*.working
*.backup
*.bak
validation-*.log
test-*.log
test-output-*

# Node.js dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

# ════════════════════════════════════════════════════════════════
# 🛠️ EDITOR & IDE ARTIFACTS
# ════════════════════════════════════════════════════════════════

# VS Code personal settings (keep workspace config)
.vscode/settings.json.local
.env

# System cruft
*.DS_Store
.ipynb_checkpoints/
Thumbs.db

# ════════════════════════════════════════════════════════════════
# 📱 DISTRIBUTION ARTIFACTS (built locally)
# ════════════════════════════════════════════════════════════════

# Generated distribution packages
release/
launcher/uDOS.app/
launcher/build/
launcher/*.dmg
launcher/uDOS_installation.log

# Generated documentation exports
*.pdf
exports/

# ════════════════════════════════════════════════════════════════
# 🧪 TESTING & DEVELOPMENT
# ════════════════════════════════════════════════════════════════

# Test environments
/tmp/
temp/
testing/
scratch/

# Development progress tracking (use GitHub Issues instead)
progress/
dev-notes/
personal-notes/

# User-specific configurations
config.local.*
settings.local.*

# ════════════════════════════════════════════════════════════════
# 📝 NOTES: WHAT STAYS IN REPOSITORY
# ════════════════════════════════════════════════════════════════
# ✅ uCode/ - Core system scripts (read-only for most users)
# ✅ uKnowledge/ - Documentation and packages (read-only)
# ✅ uScript/ - System automation scripts (sorcerer+ access)
# ✅ uTemplate/ - Standard templates (read-only)
# ✅ Distribution scripts (install-udos.sh, etc.)
# ✅ Core documentation (README.md, roadmaps, etc.)
# ✅ VS Code workspace configuration (.vscode/tasks.json)
# ════════════════════════════════════════════════════════════════