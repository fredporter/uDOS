{
  "metadata": {
    "name": "Location and Geographic Data",
    "description": "Comprehensive geographic location data including cities, coordinates, and map tiles",
    "version": "1.0.0",
    "created": "2025-07-13",
    "updated": "2025-07-13",
    "records": 52,
    "format": "uDOS location dataset",
    "fields": ["tile", "city", "country", "latitude", "longitude", "region", "population_tier", "type"]
  },
  "schema": {
    "tile": {
      "type": "string",
      "description": "Map tile coordinate reference (e.g., AA24, CQ43)",
      "pattern": "^[A-Z]{2}[0-9]{2}$"
    },
    "city": {
      "type": "string",
      "description": "City name",
      "required": true
    },
    "country": {
      "type": "string", 
      "description": "Country name",
      "required": true
    },
    "latitude": {
      "type": "number",
      "description": "Latitude coordinate in decimal degrees",
      "range": [-90, 90]
    },
    "longitude": {
      "type": "number", 
      "description": "Longitude coordinate in decimal degrees",
      "range": [-180, 180]
    },
    "region": {
      "type": "string",
      "description": "Geographic region classification"
    },
    "population_tier": {
      "type": "string",
      "description": "City size classification",
      "enum": ["megacity", "major", "large", "medium", "small"]
    },
    "type": {
      "type": "string",
      "description": "Location type classification",
      "enum": ["capital", "major_city", "port", "economic_hub", "cultural_center"]
    }
  },
